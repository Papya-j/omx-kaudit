# Broad filesystem coverage baseline
CONFIG_EXT2_FS=y
CONFIG_EXT3_FS=y
CONFIG_EXT4_FS=y
CONFIG_XFS_FS=y
CONFIG_BTRFS_FS=y
CONFIG_F2FS_FS=y
CONFIG_JFS_FS=y
CONFIG_REISERFS_FS=y
CONFIG_OCFS2_FS=y
CONFIG_NILFS2_FS=y
CONFIG_OVERLAY_FS=y
CONFIG_SQUASHFS=y
CONFIG_EROFS_FS=y
CONFIG_UDF_FS=y
CONFIG_9P_FS=y
CONFIG_FUSE_FS=y
CONFIG_CIFS=y
CONFIG_NFS_FS=y
CONFIG_NFSD=y
CONFIG_PROC_FS=y
CONFIG_SYSFS=y
CONFIG_TMPFS=y
