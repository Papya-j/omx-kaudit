# Core KASAN + debugging baseline
CONFIG_KASAN=y
CONFIG_KASAN_GENERIC=y
CONFIG_KASAN_INLINE=y
CONFIG_KASAN_MULTI_SHOT=y
CONFIG_STACKTRACE=y
CONFIG_PAGE_OWNER=y
CONFIG_DEBUG_KERNEL=y
CONFIG_DEBUG_INFO=y
CONFIG_DEBUG_FS=y
CONFIG_FRAME_POINTER=y
CONFIG_SERIAL_8250=y
CONFIG_SERIAL_8250_CONSOLE=y
CONFIG_SERIAL_EARLYCON=y
CONFIG_SLUB_DEBUG=y
# Boot-time tracing selftests can hang under WSL2+TCG and block rdinit/PoC.
CONFIG_FTRACE_STARTUP_TEST=n
CONFIG_FTRACE_SELFTEST=n
CONFIG_KUNIT=y
CONFIG_KUNIT_ALL_TESTS=n
CONFIG_KASAN_KUNIT_TEST=y
