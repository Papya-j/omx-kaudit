@dataclass
class CmdResult:
    cmd: Sequence[str]
    returncode: int
    stdout: str


def utc_now_iso() -> str:
    return datetime.now(timezone.utc).replace(microsecond=0).isoformat().replace("+00:00", "Z")


def utc_stamp() -> str:
    return datetime.now(timezone.utc).strftime("%Y%m%dT%H%M%SZ")


def parse_datetime_iso(value: str) -> Optional[datetime]:
    text = str(value or "").strip()
    if not text:
        return None
    try:
        return datetime.fromisoformat(text.replace("Z", "+00:00"))
    except ValueError:
        return None


def parse_datetime_ymd(value: str) -> Optional[datetime]:
    text = str(value or "").strip()
    if not text:
        return None
    try:
        return datetime.strptime(text, "%Y-%m-%d").replace(tzinfo=timezone.utc)
    except ValueError:
        return None


def shlex_join(parts: Sequence[str]) -> str:
    escaped = []
    for p in parts:
        if re.fullmatch(r"[A-Za-z0-9_./:-]+", p):
            escaped.append(p)
        else:
            escaped.append("'" + p.replace("'", "'\\''") + "'")
    return " ".join(escaped)


def fail(msg: str) -> int:
    print(f"[kaudit] ERROR: {msg}", file=sys.stderr)
    return 1


def read_json(path: Path, default: Any) -> Any:
    if not path.exists():
        return default
    try:
        return json.loads(path.read_text(encoding="utf-8"))
    except json.JSONDecodeError:
        return default


def write_json(path: Path, obj: Any) -> None:
    path.parent.mkdir(parents=True, exist_ok=True)
    path.write_text(json.dumps(obj, indent=2, sort_keys=True) + "\n", encoding="utf-8")


def sha256_file(path: Path) -> str:
    h = hashlib.sha256()
    with path.open("rb") as f:
        while True:
            chunk = f.read(1024 * 1024)
            if not chunk:
                break
            h.update(chunk)
    return h.hexdigest()


def run_cmd(
    cmd: Sequence[str],
    cwd: Path,
    check: bool = True,
    env: Optional[Dict[str, str]] = None,
    input_text: Optional[str] = None,
    timeout: Optional[int] = None,
) -> CmdResult:
    proc = subprocess.run(
        cmd,
        cwd=str(cwd),
        text=True,
        capture_output=True,
        env=env,
        input=input_text,
        timeout=timeout,
    )
    out = (proc.stdout or "") + (proc.stderr or "")
    if check and proc.returncode != 0:
        raise RuntimeError(f"command failed ({proc.returncode}): {shlex_join(cmd)}\n{out}")
    return CmdResult(cmd=cmd, returncode=proc.returncode, stdout=out)


def run_logged(cmd: Sequence[str], cwd: Path, log_path: Path, env: Optional[Dict[str, str]] = None) -> CmdResult:
    log_path.parent.mkdir(parents=True, exist_ok=True)
    with log_path.open("a", encoding="utf-8") as logf:
        logf.write(f"$ {shlex_join(cmd)}\n")
        proc = subprocess.run(cmd, cwd=str(cwd), text=True, capture_output=True, env=env)
        out = (proc.stdout or "") + (proc.stderr or "")
        if out:
            logf.write(out)
        logf.write(f"[rc={proc.returncode}]\n\n")
    return CmdResult(cmd=cmd, returncode=proc.returncode, stdout=out)


def fetch_text(url: str, timeout: int = 60) -> str:
    req = Request(url, headers={"User-Agent": "kaudit/1.0"})
    with urlopen(req, timeout=timeout) as resp:
        return resp.read().decode("utf-8", errors="replace")


def fetch_json(url: str, timeout: int = 60) -> Any:
    return json.loads(fetch_text(url, timeout=timeout))


def parse_json_output(raw: str) -> Optional[Dict[str, Any]]:
    text = str(raw or "").strip()
    if not text:
        return None
    try:
        data = json.loads(text)
    except json.JSONDecodeError:
        return None
    return data if isinstance(data, dict) else None


def parse_json_output_loose(raw: str) -> Optional[Dict[str, Any]]:
    text = str(raw or "").strip()
    if not text:
        return None
    parsed = parse_json_output(text)
    if parsed is not None:
        return parsed

    start = text.find("{")
    end = text.rfind("}")
    if start >= 0 and end > start:
        return parse_json_output(text[start : end + 1])
    return None


def as_int(value: Any, default: int = 0) -> int:
    try:
        return int(value)
    except (TypeError, ValueError):
        return default


def as_float(value: Any, default: float = 0.0) -> float:
    try:
        return float(value)
    except (TypeError, ValueError):
        return default


def as_str_list(value: Any) -> List[str]:
    if not isinstance(value, list):
        return []
    out: List[str] = []
    for item in value:
        text = str(item or "").strip()
        if text:
            out.append(text)
    return out


FS_LABEL_ALIASES = {
    "adfs": "ADFS",
    "affs": "AFFS",
    "bfs": "BFS",
    "efs": "EFS",
    "freevxfs": "VxFS",
    "vxfs": "VxFS",
    "omfs": "OMFS",
    "qnx4": "QNX4",
    "qnx6": "QNX6",
}


def infer_subsystem_from_target_path(target_path: str) -> str:
    parts = [part for part in str(target_path or "").split("/") if part]
    if len(parts) >= 2 and parts[0] in {"fs", "net"}:
        return f"{parts[0]}/{parts[1]}"
    if len(parts) >= 2 and parts[0] in {"arch", "block", "drivers", "io_uring", "ipc", "kernel", "lib", "mm", "security", "sound", "virt"}:
        return f"{parts[0]}/{parts[1]}"
    if len(parts) >= 3 and parts[0] == "drivers" and parts[1] == "tty":
        return f"{parts[0]}/{parts[1]}/{parts[2]}"
    if len(parts) >= 2 and parts[0] == "drivers" and parts[1] == "tty":
        return "drivers/tty"
    if parts and parts[0] == "fs":
        return "fs"
    if parts and parts[0] == "net":
        return "net"
    return parts[0] if parts else "kernel"


def infer_component_label_from_target_path(target_path: str) -> str:
    subsystem = infer_subsystem_from_target_path(target_path)
    leaf = subsystem.split("/")[-1] if subsystem else "component"
    if subsystem == "fs":
        return "filesystem"
    if subsystem == "net":
        return "networking"
    if subsystem.startswith("net/"):
        return "networking"
    if subsystem.startswith("drivers/tty"):
        return "tty"
    if subsystem.startswith("security/"):
        return "security"
    return FS_LABEL_ALIASES.get(leaf, leaf.upper())


def infer_route_hint(case: Dict[str, Any]) -> str:
    target_path = next(iter(as_str_list(case.get("target_paths", []))), "")
    entry_surface = " ".join(
        [
            str(case.get("entry_surface", "") or ""),
            str(case.get("verification", {}).get("trigger_contract", "") or ""),
            str(case.get("attack_scenario", "") or ""),
        ]
    ).lower()
    if "getdents64" in entry_surface or "readdir" in entry_surface or "ls " in entry_surface:
        return "directory enumeration"
    if "readlink" in entry_surface:
        return "symlink resolution"
    if "netlink" in entry_surface:
        return "netlink message handling"
    if "setsockopt" in entry_surface:
        return "setsockopt()"
    if "getsockopt" in entry_surface:
        return "getsockopt()"
    if "recvmsg" in entry_surface or "recvfrom" in entry_surface:
        return "recvmsg()"
    if "sendmsg" in entry_surface or "sendto" in entry_surface:
        return "sendmsg()"
    if "ioctl" in entry_surface:
        return "ioctl()"
    if "pread" in entry_surface or "read()" in entry_surface or " read " in entry_surface or "mmap" in entry_surface:
        return "file read"
    if "statfs" in entry_surface:
        return "statfs"
    if "mount" in entry_surface:
        return "mount"
    if target_path.startswith("net/"):
        return "networking access"
    if target_path.startswith("fs/"):
        return "filesystem access"
    if target_path.startswith("io_uring/"):
        return "io_uring submission"
    if target_path.startswith("security/"):
        return "security policy handling"
    return "filesystem access"


def infer_route_hint_from_excerpt(excerpt: str, case: Dict[str, Any]) -> str:
    haystack = str(excerpt or "").lower()
    if "__x64_sys_getdents64" in haystack or "iterate_dir" in haystack or "getdents64" in haystack:
        return "directory enumeration"
    if "readlink" in haystack or "symlink" in haystack:
        return "symlink resolution"
    if "__x64_sys_mount" in haystack or "fc_mount" in haystack or "vfs_get_tree" in haystack or "path_mount" in haystack:
        return "mount"
    if "__x64_sys_setsockopt" in haystack or "setsockopt" in haystack:
        return "setsockopt()"
    if "__x64_sys_getsockopt" in haystack or "getsockopt" in haystack:
        return "getsockopt()"
    if "__x64_sys_recvmsg" in haystack or "__sys_recvmsg" in haystack or "recvmsg" in haystack:
        return "recvmsg()"
    if "__x64_sys_sendmsg" in haystack or "__sys_sendmsg" in haystack or "sendmsg" in haystack:
        return "sendmsg()"
    if "netlink" in haystack:
        return "netlink message handling"
    if "__x64_sys_ioctl" in haystack or " tty_ioctl" in haystack or "ioctl" in haystack:
        return "ioctl()"
    if "__x64_sys_pread64" in haystack or "vfs_read" in haystack or "filemap_read" in haystack or "read_folio" in haystack:
        return "file read"
    if "__x64_sys_statfs" in haystack or "statfs" in haystack:
        return "statfs"
    return infer_route_hint(case)


def extract_crash_kind(excerpt: str) -> str:
    for pattern in [r"BUG:\s+KASAN:\s*([^\n]+)", r"KASAN:\s*([^\n]+)"]:
        match = re.search(pattern, str(excerpt or ""))
        if match:
            return match.group(1).strip()
    if "UBSAN:" in str(excerpt or ""):
        match = re.search(r"UBSAN:\s*([^\n]+)", str(excerpt or ""))
        if match:
            return match.group(1).strip()
    return "kernel memory-safety failure"


def extract_crash_function(excerpt: str) -> str:
    text = str(excerpt or "")
    patterns = [
        r"BUG:\s+KASAN:\s*[^\n]+ in ([A-Za-z0-9_]+)\+",
        r"KASAN:\s*[^\n]+ in ([A-Za-z0-9_]+)\+",
        r"UBSAN:\s*[^\n]+\n(?:.*\n){0,5}.*\b([A-Za-z0-9_]+)\+0x",
        r"RIP:\s+[0-9A-Fa-f:]+:([A-Za-z0-9_]+)\+",
    ]
    for pattern in patterns:
        match = re.search(pattern, text)
        if match:
            return match.group(1).strip()
    return ""


def public_route_phrase(route_hint: str) -> str:
    route = str(route_hint or "").strip().lower()
    mapping = {
        "mount": "mount-time",
        "directory enumeration": "during getdents64()",
        "file read": "during read()",
        "symlink resolution": "during readlink()",
        "statfs": "during statfs()",
        "recvmsg()": "during recvmsg()",
        "sendmsg()": "during sendmsg()",
        "setsockopt()": "during setsockopt()",
        "getsockopt()": "during getsockopt()",
        "netlink message handling": "during netlink processing",
        "ioctl()": "during ioctl()",
        "filesystem access": "during filesystem access",
        "networking access": "during networking access",
    }
    return mapping.get(route, f"during {route}" if route else "during filesystem access")


def normalize_component_name_for_subject(target_path: str) -> str:
    subsystem = infer_subsystem_from_target_path(target_path)
    if subsystem == "net" or subsystem.startswith("net/"):
        return "net"
    if subsystem == "fs":
        return "fs"
    if subsystem.startswith("drivers/tty"):
        return "tty"
    leaf = subsystem.split("/")[-1] if subsystem else "kernel"
    return leaf.lower()


def build_public_subject(case: Dict[str, Any], excerpt: str) -> str:
    target_path = next(iter(as_str_list(case.get("target_paths", []))), "fs/")
    fs_name = normalize_component_name_for_subject(target_path)
    crash_kind = extract_crash_kind(excerpt)
    crash_func = extract_crash_function(excerpt)
    route_hint = infer_route_hint_from_excerpt(excerpt, case)
    route_phrase = public_route_phrase(route_hint)
    kind_has_function = bool(re.search(r"\bin [A-Za-z0-9_]+\+", crash_kind))
    if crash_func and not kind_has_function:
        if route_phrase == "mount-time":
            return f"[BUG] {fs_name}: mount-time {crash_kind} in {crash_func}()"
        return f"[BUG] {fs_name}: {crash_kind} in {crash_func}() {route_phrase}"
    if route_phrase == "mount-time":
        return f"[BUG] {fs_name}: mount-time {crash_kind}"
    return f"[BUG] {fs_name}: {crash_kind} {route_phrase}"


def parse_email_addresses(text: str) -> List[str]:
    addresses: List[str] = []
    for match in re.finditer(r"<([^>\\s]+@[^>\\s]+)>|\\b([A-Za-z0-9._%+-]+@[A-Za-z0-9.-]+)\\b", str(text or "")):
        addr = (match.group(1) or match.group(2) or "").strip()
        if addr and addr not in addresses:
            addresses.append(addr)
    return addresses


def get_maintainer_addresses(ctx: KernelAuditContext, target_path: str, *, include_git: bool) -> List[str]:
    cmd = ["./scripts/get_maintainer.pl"]
    if include_git:
        cmd.extend(["--git", "--git-since=2-years-ago"])
    else:
        cmd.append("--nogit")
    cmd.extend(["--remove-duplicates", "-f", target_path])
    try:
        res = run_cmd(cmd, cwd=ctx.repo_root, check=True, timeout=20)
    except Exception:
        return []
    return parse_email_addresses(res.stdout)


def suggest_public_recipients(ctx: KernelAuditContext, target_path: str) -> Dict[str, List[str]]:
    maintainers = get_maintainer_addresses(ctx, target_path, include_git=False)
    git_related = get_maintainer_addresses(ctx, target_path, include_git=True)

    to_list: List[str] = []
    cc_list: List[str] = []

    if target_path.startswith("fs/"):
        to_list.append("linux-fsdevel@vger.kernel.org")
    elif target_path.startswith("net/"):
        to_list.append("netdev@vger.kernel.org")

    for addr in maintainers:
        if addr == "linux-kernel@vger.kernel.org":
            if addr not in cc_list:
                cc_list.append(addr)
            continue
        if addr not in to_list:
            to_list.append(addr)

    if "linux-kernel@vger.kernel.org" not in cc_list:
        cc_list.append("linux-kernel@vger.kernel.org")

    for addr in git_related:
        if addr in to_list or addr in cc_list:
            continue
        if addr.endswith("@vger.kernel.org"):
            cc_list.append(addr)
        else:
            cc_list.append(addr)

    return {"to": to_list, "cc": cc_list}


def split_shell_args(raw: str) -> List[str]:
    text = str(raw or "").strip()
    if not text:
        return []
    try:
        return shlex.split(text)
    except ValueError as exc:
        raise RuntimeError(f"invalid shell-style argument string: {exc}") from exc


def has_cli_flag(tokens: Sequence[str], name: str) -> bool:
    for idx, token in enumerate(tokens):
        if token == name:
            return True
        if token.startswith(f"{name}="):
            return True
        if token == "--model" and name == "--model" and idx + 1 < len(tokens):
            return True
    return False


def has_reasoning_override(tokens: Sequence[str]) -> bool:
    return any("model_reasoning_effort" in token for token in tokens)


def signature_tokens(text: str) -> List[str]:
    words = re.findall(r"[a-z0-9_]{3,}", text.lower())
    tokens = sorted({w for w in words if w not in STOPWORDS and not w.isdigit()})
    return tokens


def jaccard(a: Iterable[str], b: Iterable[str]) -> float:
    sa = set(a)
    sb = set(b)
    if not sa or not sb:
        return 0.0
    inter = sa & sb
    union = sa | sb
    return float(len(inter)) / float(len(union))


def overlap_score(a: Iterable[str], b: Iterable[str]) -> float:
    sa = {x for x in a if x}
    sb = {x for x in b if x}
    if not sa or not sb:
        return 0.0
    inter = sa & sb
    return float(len(inter)) / float(min(len(sa), len(sb)))


def extract_paths_from_text(text: str) -> List[str]:
    paths = re.findall(r"\b([A-Za-z0-9_\-]+/[A-Za-z0-9_\-./]+\.(?:c|h))\b", text)
    out = []
    for p in paths:
        normalized = p.strip("./")
        if "/" not in normalized:
            continue
        out.append(normalized)
    return sorted(set(out))


def extract_functions_from_text(text: str) -> List[str]:
    hits = set()
    for name in re.findall(r"\b([A-Za-z_][A-Za-z0-9_]*)\s*(?:\(|\+0x| at )", text):
        lower = name.lower()
        if lower in CONTROL_KEYWORDS or lower in STOPWORDS:
            continue
        hits.add(name)
    return sorted(hits)


def classify_weakness(text: str) -> str:
    hay = text.lower()
    for kind, words in WEAKNESS_KEYWORDS.items():
        for w in words:
            if w in hay:
                return kind
    return "unknown"


def similarity_breakdown(candidate_sig: Dict[str, Any], known_sig: Dict[str, Any]) -> Dict[str, float]:
    token_score = jaccard(candidate_sig.get("tokens", []), known_sig.get("tokens", []))
    function_score = overlap_score(candidate_sig.get("functions", []), known_sig.get("functions", []))
    path_score = overlap_score(candidate_sig.get("paths", []), known_sig.get("paths", []))

    cand_w = str(candidate_sig.get("weakness", "unknown"))
    known_w = str(known_sig.get("weakness", "unknown"))
    weakness_score = 1.0 if cand_w != "unknown" and cand_w == known_w else 0.0

    score = (
        SIMILARITY_WEIGHTS["token"] * token_score
        + SIMILARITY_WEIGHTS["function"] * function_score
        + SIMILARITY_WEIGHTS["path"] * path_score
        + SIMILARITY_WEIGHTS["weakness"] * weakness_score
    )
    return {
        "score": score,
        "token": token_score,
        "function": function_score,
        "path": path_score,
        "weakness": weakness_score,
    }


def normalize_version(raw: str) -> str:
    text = str(raw or "").strip()
    if text.startswith("v"):
        text = text[1:]
    return text


def parse_semver(raw: str) -> Tuple[int, int, int]:
    text = normalize_version(raw)
    m = re.match(r"^(\d+)\.(\d+)\.(\d+)", text)
    if not m:
        return (0, 0, 0)
    return (int(m.group(1)), int(m.group(2)), int(m.group(3)))


def compare_versions(a: str, b: str) -> int:
    ta = parse_semver(a)
    tb = parse_semver(b)
    if ta < tb:
        return -1
    if ta > tb:
        return 1
    return 0


def max_version(values: Iterable[str]) -> Optional[str]:
    cleaned = [normalize_version(v) for v in values if normalize_version(v)]
    if not cleaned:
        return None
    return max(cleaned, key=parse_semver)


def normalize_target_name(raw: str) -> str:
    target = str(raw or "fs").strip().lower().replace("\\", "/")
    if target in {"", "fs"}:
        return "fs"
    if target in SUPPORTED_TARGETS:
        return target
    raise RuntimeError(f"unsupported target: {raw}")


def target_profile(target: str) -> Dict[str, Any]:
    key = normalize_target_name(target)
    return TARGET_PROFILES[key]


def target_slug(target: str) -> str:
    return target_profile(target)["slug"]


def target_dir_name(base: str, target: str) -> str:
    slug = target_slug(target)
    return base if not slug else f"{base}-{slug}"


def target_file_name(base: str, target: str) -> str:
    slug = target_slug(target)
    return base if not slug else f"{Path(base).stem}-{slug}{Path(base).suffix}"


def normalize_repo_relpath(path: Any) -> str:
    text = str(path or "").strip().replace("\\", "/")
    while text.startswith("./"):
        text = text[2:]
    return text


def path_matches_roots(path: str, roots: Sequence[str]) -> bool:
    rel = normalize_repo_relpath(path)
    normalized_roots = [normalize_repo_relpath(root).rstrip("/") for root in roots if normalize_repo_relpath(root)]
    if not normalized_roots:
        return True
    for root in normalized_roots:
        if rel == root or rel.startswith(root + "/"):
            return True
    return False


def target_scan_roots(target: str) -> Tuple[str, ...]:
    profile = target_profile(target)
    raw_roots = profile.get("scan_roots", ())
    roots = [normalize_repo_relpath(item) for item in raw_roots if normalize_repo_relpath(item)]
    if roots:
        return tuple(roots)
    fallback = normalize_repo_relpath(target)
    return (fallback,) if fallback else ()


def target_config_seed(target: str) -> Dict[str, Any]:
    profile = target_profile(target)
    seed = profile.get("config_seed", {})
    return dict(seed) if isinstance(seed, dict) else {"kind": "allmodconfig"}


def target_bzimage_relpath(target: str) -> Path:
    profile = target_profile(target)
    rel = str(profile.get("bzimage_relpath", "arch/x86/boot/bzImage") or "arch/x86/boot/bzImage")
    return Path(rel)


def source_tree_version(repo_root: Path) -> str:
    makefile = repo_root / "Makefile"
    text = makefile.read_text(encoding="utf-8", errors="replace")

    def _extract(name: str, default: str = "0") -> str:
        match = re.search(rf"^{name}\s*=\s*(.+)$", text, re.M)
        return match.group(1).strip() if match else default

    version = _extract("VERSION")
    patchlevel = _extract("PATCHLEVEL")
    sublevel = _extract("SUBLEVEL")
    extraversion = _extract("EXTRAVERSION", "")
    return f"{version}.{patchlevel}.{sublevel}{extraversion}"


def source_tree_series(repo_root: Path) -> str:
    version = source_tree_version(repo_root)
    parts = version.split(".")
    return ".".join(parts[:2]) if len(parts) >= 2 else version


def ensure_target_source_compat(ctx: "KernelAuditContext") -> None:
    seed = ctx.config_seed()
    if not seed.get("enforce_lts_match"):
        return
    expected_series = str(seed.get("lts_series", "") or "").strip()
    if not expected_series:
        return
    current_series = source_tree_series(ctx.repo_root)
    if current_series == expected_series:
        return
    label = str(seed.get("label", seed.get("file_name", "target config")) or "target config")
    expected_release = str(seed.get("lts_release", expected_series) or expected_series)
    current_version = source_tree_version(ctx.repo_root)
    raise RuntimeError(
        f"target `{ctx.target}` requires a Linux {expected_series}.x source tree because {label} is pinned to "
        f"{expected_release}; current source tree is {current_version}"
    )


def omx_install_root() -> Optional[Path]:
    omx_bin = shutil.which("omx")
    if not omx_bin:
        return None
    real = Path(omx_bin).resolve()
    for cand in [real.parent, real.parent.parent, real.parent.parent.parent]:
        pkg = cand / "package.json"
        if not pkg.exists():
            continue
        data = read_json(pkg, {})
        if isinstance(data, dict) and data.get("name") == "oh-my-codex":
            return cand
    return None


def omx_notifications_configured(repo_root: Path) -> bool:
    candidates = [repo_root / ".codex" / "config.toml", Path.home() / ".codex" / "config.toml"]
    for path in candidates:
        if not path.exists():
            continue
        text = path.read_text(encoding="utf-8", errors="replace")
        if "[notifications]" in text or "\nnotify =" in text or text.lstrip().startswith("notify ="):
            return True
    return False


def omx_local_info(repo_root: Path) -> Dict[str, Any]:
    info: Dict[str, Any] = {
        "omx_bin": shutil.which("omx"),
        "install_root": None,
        "package_json": None,
        "installed_version": None,
        "node_version": None,
        "platform": None,
        "reasoning_effort": None,
        "team_api_available": False,
        "team_api_event_query_available": False,
        "team_api_monitor_snapshot_available": False,
        "session_command_available": False,
        "resume_command_available": False,
        "tmux_hook_available": False,
        "hooks_command_available": False,
        "reasoning_command_available": False,
        "agents_init_available": False,
        "notifications_configured": False,
    }

    root = omx_install_root()
    if root:
        pkg = root / "package.json"
        info["install_root"] = str(root)
        info["package_json"] = str(pkg)
        data = read_json(pkg, {})
        if isinstance(data, dict):
            info["installed_version"] = normalize_version(str(data.get("version", "") or ""))

    version_out = run_cmd(["omx", "version"], cwd=Path.cwd(), check=False).stdout
    m_ver = re.search(r"oh-my-codex v([0-9][A-Za-z0-9._-]*)", version_out)
    if m_ver and not info.get("installed_version"):
        info["installed_version"] = normalize_version(m_ver.group(1))
    m_node = re.search(r"Node\.js v([0-9][A-Za-z0-9._-]*)", version_out)
    if m_node:
        info["node_version"] = m_node.group(1)
    m_platform = re.search(r"Platform:\s*([^\n]+)", version_out)
    if m_platform:
        info["platform"] = m_platform.group(1).strip()

    help_out = run_cmd(["omx", "--help"], cwd=Path.cwd(), check=False).stdout
    info["session_command_available"] = re.search(r"^\s*omx session\b", help_out, re.M) is not None
    info["resume_command_available"] = re.search(r"^\s*omx resume\b", help_out, re.M) is not None
    info["tmux_hook_available"] = re.search(r"^\s*omx tmux-hook\b", help_out, re.M) is not None
    info["hooks_command_available"] = re.search(r"^\s*omx hooks\b", help_out, re.M) is not None
    info["reasoning_command_available"] = re.search(r"^\s*omx reasoning\b", help_out, re.M) is not None
    info["agents_init_available"] = re.search(r"^\s*omx agents-init\b", help_out, re.M) is not None

    reasoning_out = run_cmd(["omx", "reasoning"], cwd=Path.cwd(), check=False).stdout
    m_reasoning = re.search(r"Current model_reasoning_effort:\s*([A-Za-z0-9_-]+)", reasoning_out)
    if m_reasoning:
        info["reasoning_effort"] = m_reasoning.group(1).strip()
    team_api_out = run_cmd(["omx", "team", "api", "--help"], cwd=Path.cwd(), check=False).stdout
    info["team_api_available"] = "get-summary" in team_api_out
    info["team_api_event_query_available"] = "await-event" in team_api_out and "read-events" in team_api_out
    info["team_api_monitor_snapshot_available"] = (
        "read-monitor-snapshot" in team_api_out and "write-monitor-snapshot" in team_api_out
    )
    info["notifications_configured"] = omx_notifications_configured(repo_root)
    return info


def fetch_omx_github_latest() -> Dict[str, Any]:
    data = fetch_json(OMX_GITHUB_RELEASE_API, timeout=45)
    return {
        "version": normalize_version(str(data.get("tag_name", "") or data.get("name", "") or "")),
        "tag_name": str(data.get("tag_name", "") or ""),
        "published_at": data.get("published_at"),
        "url": data.get("html_url"),
        "body": str(data.get("body", "") or ""),
    }


def fetch_omx_npm_latest() -> Dict[str, Any]:
    data = fetch_json(OMX_NPM_LATEST_API, timeout=45)
    dist = data.get("dist", {}) if isinstance(data, dict) else {}
    return {
        "version": normalize_version(str(data.get("version", "") or "")),
        "url": dist.get("tarball"),
    }


def strip_html_to_text(raw_html: str) -> str:
    text = re.sub(r"(?is)<(script|style)[^>]*>.*?</\1>", " ", raw_html)
    text = re.sub(r"(?i)<li[^>]*>", "\n* ", text)
    text = re.sub(r"(?i)<br\s*/?>", "\n", text)
    text = re.sub(r"(?i)</(p|div|section|article|h1|h2|h3|h4|h5|h6|ul|ol|pre|table|tr)>", "\n", text)
    text = re.sub(r"(?s)<[^>]+>", " ", text)
    text = html_lib.unescape(text)
    text = text.replace("\r", "\n")
    text = re.sub(r"[ \t]+", " ", text)
    text = re.sub(r"\n{3,}", "\n\n", text)
    return text


def parse_omx_docs_releases(raw_html: str) -> Dict[str, Any]:
    text = strip_html_to_text(raw_html)
    lines = [line.strip() for line in text.splitlines() if line.strip()]

    docs_version = None
    releases: List[Dict[str, Any]] = []
    current: Optional[Dict[str, Any]] = None
    in_summary = False

    for line in lines:
        if docs_version is None:
            m_docs = re.search(r"Oh My Codex v(\d+\.\d+\.\d+)", line)
            if m_docs:
                docs_version = normalize_version(m_docs.group(1))

        low = line.lower()
        if low == "quick summary":
            in_summary = True
            continue
        if in_summary and low in {"installation", "quick start", "concepts", "feature guides"}:
            break
        if not in_summary:
            continue

        m_rel = re.match(r"^(v\d+\.\d+\.\d+)\b", line)
        if m_rel:
            if current:
                releases.append(current)
            current = {"version": normalize_version(m_rel.group(1)), "heading": line, "bullets": []}
            continue

        if current and line.startswith("* "):
            bullet = line[2:].strip()
            if bullet and not bullet.lower().startswith("view changes in "):
                current["bullets"].append(bullet)

    if current:
        releases.append(current)

    return {
        "docs_version": docs_version,
        "releases": releases,
    }


def fetch_omx_docs_summary() -> Dict[str, Any]:
    raw = fetch_text(OMX_DOCS_URL, timeout=45)
    parsed = parse_omx_docs_releases(raw)
    if not parsed.get("docs_version"):
        parsed["docs_version"] = max_version([str(x.get("version", "") or "") for x in parsed.get("releases", [])])
    parsed["url"] = OMX_DOCS_URL
    return parsed


def feature_reflection(version: str, bullet: str) -> Optional[Dict[str, Any]]:
    low = bullet.lower()
    if "gemini" in low:
        return {
            "version": version,
            "feature": bullet,
            "status": "optional",
            "why_useful": "Useful only for sidecar research lanes when Codex remains the root-cause and reporting authority.",
            "reflection": "Keep fs root-cause analysis, uniqueness, repro, and reports Codex-only; Gemini-capable worker fixes only matter if you intentionally add external sidecar workers.",
        }
    if "team cli interop api" in low or "cli interop api" in low:
        return {
            "version": version,
            "feature": bullet,
            "status": "recommended",
            "why_useful": "Scripts can control worker/task/mailbox state more precisely than plain status polling.",
            "reflection": "Extend kaudit team orchestration beyond start/status/shutdown into task-level case routing and result collection via `omx team api`.",
        }
    if "gemini cli workers" in low or "mixed worker" in low:
        return {
            "version": version,
            "feature": bullet,
            "status": "optional",
            "why_useful": "Can help with wide source-map or docs-ingestion side work when kernel context is large.",
            "reflection": "Keep root-cause, uniqueness, repro, and final reporting Codex-only; use mixed workers only for sidecar exploration if desired.",
        }
    if "dynamic team worker scaling" in low or "scaling" in low:
        return {
            "version": version,
            "feature": bullet,
            "status": "recommended",
            "why_useful": "Long-running fs campaigns naturally oscillate between idle discovery and heavy build/repro bursts.",
            "reflection": "Add scale-up rules for build/repro backlog and scale-down when only static triage remains.",
        }
    if "notification" in low:
        return {
            "version": version,
            "feature": bullet,
            "status": "recommended",
            "why_useful": "Long campaign loops should surface new cases, stalled teams, and successful KASAN hits without manual tmux polling.",
            "reflection": "After updating OMX, use `--team-omx-global-args '--notify-temp --slack|--discord|--telegram'` for long-running cycles and configure persistent notifications through `.codex/config.toml` or the `configure-notifications` skill as needed.",
        }
    if "worktree" in low:
        return {
            "version": version,
            "feature": bullet,
            "status": "recommended",
            "why_useful": "Parallel kernel auditing can conflict with one shared tree when workers build or patch simultaneously.",
            "reflection": "Adopt worktree-backed team execution when moving from preflight-only team usage to concurrent subsystem-specific audit branches.",
        }
    if "setup" in low and "scope" in low:
        return {
            "version": version,
            "feature": bullet,
            "status": "already-useful",
            "why_useful": "Project-local prompts, skills, and MCP state drift after OMX upgrades if setup is not rerun.",
            "reflection": "Keep `omx setup --scope project --force` in the post-update path so the workspace matches the installed OMX version.",
        }
    if "pipeline" in low:
        return {
            "version": version,
            "feature": bullet,
            "status": "candidate",
            "why_useful": "The kernel workflow is already stage-shaped: sync, intake, build, cycle, repro, report.",
            "reflection": "Consider promoting kaudit orchestration to OMX pipeline stages once the case-routing model stabilizes.",
        }
    if "spark" in low:
        return {
            "version": version,
            "feature": bullet,
            "status": "recommended",
            "why_useful": "Refresh/status-heavy worker lanes do not always need the full default worker model.",
            "reflection": f"Use `--team-omx-global-args '--spark'` or `--team-model {OMX_SPARK_MODEL}` for team preflight when you want faster, cheaper worker turns.",
        }
    return None


def omx_reflections(releases: List[Dict[str, Any]]) -> List[Dict[str, Any]]:
    out: List[Dict[str, Any]] = []
    seen = set()
    for rel in releases:
        version = str(rel.get("version", "") or "")
        for bullet in rel.get("bullets", []):
            item = feature_reflection(version, str(bullet))
            if not item:
                continue
            key = (item["status"], item["reflection"])
            if key in seen:
                continue
            seen.add(key)
            out.append(item)
    return out


def omx_operator_tips(local: Dict[str, Any], snapshot: Dict[str, Any]) -> List[str]:
    tips: List[str] = []
    if bool(local.get("session_command_available")):
        tips.append("Use `omx session` to search prior long-running audit sessions and earlier terminal transcripts.")
    if bool(local.get("tmux_hook_available")):
        tips.append("Use `omx tmux-hook validate` if tmux pane injection or HUD behavior looks wrong after team/backlog runs.")
    if bool(local.get("hooks_command_available")):
        tips.append("Use `omx hooks validate` to sanity-check installed hook plugins when lifecycle events look inconsistent.")
    if bool(local.get("reasoning_command_available")):
        tips.append("Use `omx reasoning xhigh` to keep the default local reasoning level aligned with the kernel-audit workflow.")
    if snapshot.get("github_ahead_of_installable"):
        tips.append(
            "GitHub tag is ahead of npm. Treat `installable_latest` as the real upgrade target for `kaudit omx update` until the npm package catches up."
        )
    return tips


def omx_snapshot(ctx: KernelAuditContext) -> Dict[str, Any]:
    local = omx_local_info(ctx.repo_root)
    cached = read_json(ctx.omx_upstream_path, {})
    github_latest: Dict[str, Any] = {}
    npm_latest: Dict[str, Any] = {}
    docs_summary: Dict[str, Any] = {}
    errors: List[str] = []
    cache_fallback_used: List[str] = []

    try:
        github_latest = fetch_omx_github_latest()
    except Exception as exc:
        errors.append(f"github_latest: {exc}")
        if isinstance(cached.get("github_latest"), dict) and cached.get("github_latest"):
            github_latest = dict(cached.get("github_latest", {}))
            cache_fallback_used.append("github_latest")
    try:
        npm_latest = fetch_omx_npm_latest()
    except Exception as exc:
        errors.append(f"npm_latest: {exc}")
        if isinstance(cached.get("npm_latest"), dict) and cached.get("npm_latest"):
            npm_latest = dict(cached.get("npm_latest", {}))
            cache_fallback_used.append("npm_latest")
    try:
        docs_summary = fetch_omx_docs_summary()
    except Exception as exc:
        errors.append(f"docs_summary: {exc}")
        if isinstance(cached.get("docs_summary"), dict) and cached.get("docs_summary"):
            docs_summary = dict(cached.get("docs_summary", {}))
            cache_fallback_used.append("docs_summary")

    upstream_latest = max_version(
        [
            str(github_latest.get("version", "") or ""),
            str(npm_latest.get("version", "") or ""),
            str(docs_summary.get("docs_version", "") or ""),
        ]
    )
    installable_latest = normalize_version(str(npm_latest.get("version", "") or "")) or None
    installed = normalize_version(str(local.get("installed_version", "") or ""))
    if installed and (not upstream_latest or compare_versions(installed, upstream_latest) > 0):
        upstream_latest = installed
    if installed and (not installable_latest or compare_versions(installed, installable_latest) > 0):
        installable_latest = installed
    update_available = bool(installed and installable_latest and compare_versions(installed, installable_latest) < 0)
    github_ahead_of_installable = bool(
        github_latest.get("version")
        and installable_latest
        and compare_versions(str(github_latest.get("version", "") or ""), installable_latest) > 0
    )

    snapshot = {
        "generated_at": utc_now_iso(),
        "installed": local,
        "github_latest": github_latest,
        "npm_latest": npm_latest,
        "docs_summary": docs_summary,
        "upstream_latest": upstream_latest,
        "installable_latest": installable_latest,
        "github_ahead_of_installable": github_ahead_of_installable,
        "docs_lagging": bool(
            docs_summary.get("docs_version")
            and upstream_latest
            and compare_versions(str(docs_summary.get("docs_version", "")), str(upstream_latest)) < 0
        ),
        "update_available": update_available,
        "reflections": omx_reflections(docs_summary.get("releases", [])),
        "operator_tips": [],
        "recommended_team_worker_launch_args": '-c model_reasoning_effort="xhigh"',
        "post_update_steps": [
            "omx setup --scope project --force",
            "omx doctor",
            "omx doctor --team",
        ],
        "cache_fallback_used": cache_fallback_used,
        "errors": errors,
    }
    snapshot["operator_tips"] = omx_operator_tips(local, snapshot)
    return snapshot


def omx_live_release_versions(snapshot: Dict[str, Any]) -> List[str]:
    cache_fallback_used = {str(item) for item in snapshot.get("cache_fallback_used", []) if item}
    versions: List[str] = []
    if "npm_latest" not in cache_fallback_used:
        versions.append(normalize_version(str(snapshot.get("npm_latest", {}).get("version", "") or "")))
    return [item for item in versions if item]


def omx_resolve_update_target(ctx: KernelAuditContext, requested_version: str) -> Tuple[str, Dict[str, Any]]:
    target_version = normalize_version(str(requested_version or ""))
    snapshot = omx_snapshot(ctx)
    write_json(ctx.omx_upstream_path, snapshot)

    if target_version and target_version != "latest":
        return target_version, snapshot

    live_versions = omx_live_release_versions(snapshot)
    if live_versions:
        return max_version(live_versions) or "latest", snapshot

    cached = read_json(ctx.omx_upstream_path, {})
    cached_target = normalize_version(
        str(
            cached.get("installable_latest", "")
            or cached.get("npm_latest", {}).get("version", "")
            or cached.get("upstream_latest", "")
            or ""
        )
    )
    installed = normalize_version(str(snapshot.get("installed", {}).get("installed_version", "") or ""))
    if cached_target and installed and compare_versions(cached_target, installed) > 0:
        return cached_target, snapshot
    return "latest", snapshot


def find_repo_root(start: Path) -> Path:
    cur = start.resolve()
    for cand in [cur] + list(cur.parents):
        if (cand / ".git").exists() and (cand / "Makefile").exists() and (cand / "fs").is_dir():
            return cand
    raise RuntimeError("could not find linux-up repo root from current directory")


class KernelAuditContext:
    def __init__(self, repo_root: Path, target: str = "fs") -> None:
        self.repo_root = repo_root
        self.target = normalize_target_name(target)
        self.profile = target_profile(self.target)
        self.root = repo_root / ".omx" / "kernel-audit"
        self.state_dir = self.root / "state"
        self.knowledge_dir = self.root / "knowledge"
        self.build_dir = self.root / "build" / str(self.profile.get("build_dir_name", "x86_64") or "x86_64")
        self.config_dir = self.root / "config"
        self.fragments_dir = self.config_dir / "fragments"
        self.defconfigs_dir = self.config_dir / "defconfigs"
        self.artifacts_dir = self.root / "artifacts" / target_dir_name("cases", self.target)
        self.reports_dir = self.root / target_dir_name("reports", self.target)
        self.public_reports_dir = self.reports_dir / "public"
        self.logs_dir = self.root / target_dir_name("logs", self.target)
        self.rootfs_dir = self.root / target_dir_name("rootfs", self.target)
        self.templates_dir = self.root / "templates"

    @property
    def campaign_path(self) -> Path:
        return self.state_dir / target_file_name("campaign.json", self.target)

    @property
    def build_state_path(self) -> Path:
        return self.state_dir / str(self.profile.get("build_state_name", "build.json") or "build.json")

    @property
    def pipeline_path(self) -> Path:
        return self.state_dir / target_file_name("pipeline.json", self.target)

    @property
    def shards_path(self) -> Path:
        return self.state_dir / target_file_name("shards.json", self.target)

    @property
    def syzbot_path(self) -> Path:
        return self.knowledge_dir / f"syzbot-{self.profile['syzbot_suffix']}.json"

    @property
    def cve_path(self) -> Path:
        return self.knowledge_dir / f"cve-{self.profile['cve_suffix']}.json"

    @property
    def knowledge_snapshot_path(self) -> Path:
        return self.knowledge_dir / target_file_name("knowledge-snapshot.json", self.target)

    @property
    def omx_upstream_path(self) -> Path:
        return self.knowledge_dir / "omx-upstream.json"

    @property
    def omx_update_log_path(self) -> Path:
        return self.logs_dir / f"omx-update-{utc_stamp()}.log"

    def prompt_path(self, name: str) -> Path:
        return self.repo_root / ".codex" / "prompts" / name

    def template_path(self, name: str) -> Path:
        return self.templates_dir / name

    def case_dir(self, case_id: str) -> Path:
        return self.artifacts_dir / case_id

    def case_json_path(self, case_id: str) -> Path:
        return self.case_dir(case_id) / "case.json"

    def prompt_name(self, stage: str) -> str:
        prompts = self.profile.get("prompts", {})
        return str(prompts.get(stage, "") or "")

    def default_fragments(self) -> Tuple[str, ...]:
        vals = self.profile.get("default_fragments", ())
        return tuple(str(v) for v in vals)

    def scan_roots(self) -> Tuple[str, ...]:
        return target_scan_roots(self.target)

    def config_seed(self) -> Dict[str, Any]:
        return target_config_seed(self.target)

    def bzimage_path(self) -> Path:
        return self.build_dir / target_bzimage_relpath(self.target)

    def seed_config_path(self) -> Optional[Path]:
        seed = self.config_seed()
        file_name = str(seed.get("file_name", "") or "").strip()
        if not file_name:
            return None
        return self.defconfigs_dir / file_name

    def ensure_layout(self) -> None:
        for p in [
            self.state_dir,
            self.knowledge_dir,
            self.build_dir,
            self.config_dir,
            self.fragments_dir,
            self.defconfigs_dir,
            self.artifacts_dir,
            self.reports_dir,
            self.public_reports_dir,
            self.logs_dir,
            self.rootfs_dir,
            self.templates_dir,
        ]:
            p.mkdir(parents=True, exist_ok=True)

    def load_campaign(self) -> Dict[str, Any]:
        default = {
            "campaign_id": f"campaign-{utc_stamp()}",
            "kernel_head": None,
            "knowledge_snapshot": None,
            "queue_depth": 0,
            "completed_cases": 0,
            "rejected_as_known": 0,
            "next_targets": [self.target],
            "seen_locations": [],
            "last_cycle_at": None,
            "last_case_id": None,
        }
        c = read_json(self.campaign_path, default)
        for k, v in default.items():
            c.setdefault(k, v)
        return c

    def save_campaign(self, campaign: Dict[str, Any]) -> None:
        write_json(self.campaign_path, campaign)


def deep_copy_json(obj: Any) -> Any:
    return json.loads(json.dumps(obj))


def safe_slug(text: str, fallback: str = "item") -> str:
    slug = re.sub(r"[^A-Za-z0-9._-]+", "-", str(text or "").strip()).strip("-")
    return slug or fallback


def load_pipeline_state(ctx: KernelAuditContext) -> Dict[str, Any]:
    default = {
        "version": PIPELINE_VERSION,
        "runtime_policy": "bounded_queue",
        "iteration": 0,
        "last_iteration_at": None,
        "last_successful_kasan_at": None,
        "audit_queue": [],
        "verify_queue": [],
        "repro_queue": [],
        "report_queue": [],
        "active_jobs": [],
        "completed_jobs": [],
    }
    state = read_json(ctx.pipeline_path, default)
    if not isinstance(state, dict):
        state = deep_copy_json(default)
    for key, value in default.items():
        state.setdefault(key, deep_copy_json(value))
    state["version"] = PIPELINE_VERSION
    return state


def save_pipeline_state(ctx: KernelAuditContext, state: Dict[str, Any]) -> None:
    state["version"] = PIPELINE_VERSION
    write_json(ctx.pipeline_path, state)


def pipeline_job_record(
    stage: str,
    label: str,
    status: str,
    *,
    details: Optional[Dict[str, Any]] = None,
) -> Dict[str, Any]:
    return {
        "stage": stage,
        "label": label,
        "status": status,
        "timestamp": utc_now_iso(),
        "details": details or {},
    }


def set_pipeline_active_jobs(ctx: KernelAuditContext, jobs: List[Dict[str, Any]]) -> None:
    state = load_pipeline_state(ctx)
    state["active_jobs"] = jobs
    save_pipeline_state(ctx, state)


def append_pipeline_completed_jobs(ctx: KernelAuditContext, jobs: List[Dict[str, Any]]) -> None:
    if not jobs:
        return
    state = load_pipeline_state(ctx)
    completed = state.get("completed_jobs", [])
    if not isinstance(completed, list):
        completed = []
    completed.extend(jobs)
    state["completed_jobs"] = completed[-50:]
    save_pipeline_state(ctx, state)


def load_shards_state(ctx: KernelAuditContext) -> Dict[str, Any]:
    default = {"version": PIPELINE_VERSION, "items": {}}
    state = read_json(ctx.shards_path, default)
    if not isinstance(state, dict):
        state = deep_copy_json(default)
    state.setdefault("items", {})
    if not isinstance(state["items"], dict):
        state["items"] = {}
    state["version"] = PIPELINE_VERSION
    return state


def save_shards_state(ctx: KernelAuditContext, state: Dict[str, Any]) -> None:
    state["version"] = PIPELINE_VERSION
    write_json(ctx.shards_path, state)


def case_stage(case: Dict[str, Any]) -> str:
    stage = str(case.get("stage", "") or "").strip()
    if stage:
        return stage
    status = str(case.get("status", "candidate") or "candidate").strip()
    mapping = {
        "candidate": "discovered",
        "verified": "verified",
        "manual_only": "manual_only",
        "duplicate_review": "duplicate_review",
        "repro_failed": "repro_failed",
        "confirmed": "confirmed",
        "reported": "reported",
        "rejected": "rejected",
    }
    return mapping.get(status, "discovered")


def sync_case_status(case: Dict[str, Any]) -> None:
    stage = case_stage(case)
    case["stage"] = stage
    case["status"] = CASE_STAGE_TO_STATUS.get(stage, case.get("status", "candidate"))


def normalize_case(case: Dict[str, Any]) -> Dict[str, Any]:
    if not isinstance(case, dict):
        case = {}
    base = deep_copy_json(CASE_TEMPLATE)
    for key, value in base.items():
        if key not in case:
            case[key] = value
            continue
        if isinstance(value, dict) and isinstance(case.get(key), dict):
            for sub_key, sub_value in value.items():
                case[key].setdefault(sub_key, deep_copy_json(sub_value))
    if not isinstance(case.get("required_config"), list):
        case["required_config"] = []
    if not isinstance(case.get("config_fragments"), list):
        case["config_fragments"] = list(DEFAULT_FRAGMENT_NAMES)
    if not isinstance(case.get("poc_artifacts"), list):
        case["poc_artifacts"] = []
    if not isinstance(case.get("repro_attempts"), list):
        case["repro_attempts"] = []
    if not isinstance(case.get("operator_notes"), list):
        case["operator_notes"] = []
    if not isinstance(case.get("operator_actions"), list):
        case["operator_actions"] = []
    if not isinstance(case.get("pre_disclosure_check"), dict):
        case["pre_disclosure_check"] = deep_copy_json(CASE_TEMPLATE["pre_disclosure_check"])
    else:
        for sub_key, sub_value in CASE_TEMPLATE["pre_disclosure_check"].items():
            if sub_key not in case["pre_disclosure_check"]:
                case["pre_disclosure_check"][sub_key] = deep_copy_json(sub_value)
            elif isinstance(sub_value, dict) and isinstance(case["pre_disclosure_check"].get(sub_key), dict):
                for nested_key, nested_value in sub_value.items():
                    case["pre_disclosure_check"][sub_key].setdefault(nested_key, deep_copy_json(nested_value))
    sync_case_status(case)
    return case


def collect_case_paths(ctx: KernelAuditContext) -> List[Path]:
    if not ctx.artifacts_dir.exists():
        return []
    return sorted(ctx.artifacts_dir.glob("*/case.json"))


def count_case_statuses(ctx: KernelAuditContext) -> Dict[str, int]:
    counts: Dict[str, int] = {}
    for case_path in collect_case_paths(ctx):
        obj = normalize_case(read_json(case_path, {}))
        status = obj.get("stage", obj.get("status", "unknown"))
        counts[status] = counts.get(status, 0) + 1
    return counts


def refresh_campaign_metrics(ctx: KernelAuditContext, campaign: Dict[str, Any]) -> None:
    counts = count_case_statuses(ctx)
    campaign["queue_depth"] = sum(v for k, v in counts.items() if k in QUEUE_ACTIVE_STAGES)
    campaign["completed_cases"] = sum(v for k, v in counts.items() if k in CONFIRMED_STAGES)


def ensure_default_files(ctx: KernelAuditContext) -> None:
    base_frag = ctx.fragments_dir / "base-kasan.config"
    fs_frag = ctx.fragments_dir / "fs-broad.config"
    net_frag = ctx.fragments_dir / "net-broad.config"
    kctf_frag = ctx.fragments_dir / "kctf-broad.config"
    repro_stable_frag = ctx.fragments_dir / REPRO_STABLE_FRAGMENT_NAME
    if not base_frag.exists():
        base_frag.write_text(BASE_KASAN_FRAGMENT, encoding="utf-8")
    if not fs_frag.exists():
        fs_frag.write_text(FS_BROAD_FRAGMENT, encoding="utf-8")
    if not net_frag.exists():
        net_frag.write_text(NET_BROAD_FRAGMENT, encoding="utf-8")
    if not kctf_frag.exists():
        kctf_frag.write_text(
            "# kCTF campaigns use the Lakitu base config as the dead-code filter authority.\n",
            encoding="utf-8",
        )
    if not repro_stable_frag.exists():
        repro_stable_frag.write_text(REPRO_STABLE_FRAGMENT, encoding="utf-8")

    tpl = ctx.templates_dir / "case-template.json"
    tpl_obj = read_json(tpl, {})
    if not tpl.exists() or "stage" not in tpl_obj:
        write_json(tpl, CASE_TEMPLATE)

    if not ctx.campaign_path.exists():
        ctx.save_campaign(ctx.load_campaign())
    if not ctx.pipeline_path.exists():
        save_pipeline_state(ctx, load_pipeline_state(ctx))
    if not ctx.shards_path.exists():
        save_shards_state(ctx, load_shards_state(ctx))


def cmd_bootstrap(ctx: KernelAuditContext, _args: argparse.Namespace) -> int:
    ctx.ensure_layout()
    ensure_default_files(ctx)
    campaign = ctx.load_campaign()
    refresh_campaign_metrics(ctx, campaign)
    ctx.save_campaign(campaign)

    print("[kaudit] bootstrap complete")
    print(f"[kaudit] root: {ctx.root}")
    print(f"[kaudit] campaign: {ctx.campaign_path}")
    print(f"[kaudit] default fragments: {ctx.fragments_dir}")
    return 0


def cmd_sync_mainline(ctx: KernelAuditContext, _args: argparse.Namespace) -> int:
    ctx.ensure_layout()
    ensure_default_files(ctx)
    campaign = ctx.load_campaign()

    dirty = run_cmd(["git", "status", "--porcelain", "--untracked-files=no"], cwd=ctx.repo_root, check=True)
    if dirty.stdout.strip():
        return fail("working tree has tracked changes; refusing sync-mainline")

    stamp = utc_stamp()
    log_path = ctx.logs_dir / f"sync-{stamp}.log"

    fetch = run_logged(["git", "fetch", "--prune", "origin"], cwd=ctx.repo_root, log_path=log_path)
    if fetch.returncode != 0:
        return fail(f"git fetch failed (see {log_path})")

    merge = run_logged(["git", "merge", "--ff-only", "origin/master"], cwd=ctx.repo_root, log_path=log_path)
    if merge.returncode != 0:
        return fail(f"git merge --ff-only failed (see {log_path})")

    head = run_cmd(["git", "rev-parse", "HEAD"], cwd=ctx.repo_root, check=True).stdout.strip()
    head_short = run_cmd(["git", "rev-parse", "--short", "HEAD"], cwd=ctx.repo_root, check=True).stdout.strip()

    campaign["kernel_head"] = head
    campaign["last_sync_at"] = utc_now_iso()
    refresh_campaign_metrics(ctx, campaign)
    ctx.save_campaign(campaign)

    print(f"[kaudit] sync-mainline complete: {head_short}")
    print(f"[kaudit] log: {log_path}")
    return 0


def fetch_syzbot_subsystem(subsystem: str, limit: int = 180) -> Dict[str, Any]:
    base_url = "https://syzkaller.appspot.com"
    html = fetch_text(f"{base_url}/upstream/s/{subsystem}", timeout=60)
    extids = re.findall(r"/bug\?extid=([a-f0-9]+)", html)
    uniq: List[str] = []
    seen = set()
    for e in extids:
        if e in seen:
            continue
        seen.add(e)
        uniq.append(e)
    uniq = uniq[:limit]

    bugs = []
    for extid in uniq:
        url = f"{base_url}/bug?extid={extid}&json=1"
        try:
            payload = json.loads(fetch_text(url, timeout=45))
        except (HTTPError, URLError, TimeoutError, json.JSONDecodeError):
            continue

        title = payload.get("title", "")
        status = payload.get("status", "")
        crashes = payload.get("crashes", [])
        crash_titles = [c.get("title", "") for c in crashes[:4] if c.get("title")]
        text = " ".join([title, status] + crash_titles)
        bugs.append(
            {
                "extid": extid,
                "title": title,
                "status": status,
                "first_crash": payload.get("first-crash"),
                "last_crash": payload.get("last-crash"),
                "discussions": payload.get("discussions", []),
                "sample_crash_titles": crash_titles,
                "signature_tokens": signature_tokens(text),
            }
        )

    return {
        "source": f"https://syzkaller.appspot.com/upstream/s/{subsystem}",
        "fetched_at": utc_now_iso(),
        "bug_count": len(bugs),
        "bugs": bugs,
    }


def fetch_syzbot_fs(limit: int = 180) -> Dict[str, Any]:
    return fetch_syzbot_subsystem("fs", limit=limit)


def fetch_syzbot_net(limit: int = 240) -> Dict[str, Any]:
    return fetch_syzbot_subsystem("net", limit=limit)


def merge_syzbot_datasets(label: str, datasets: Sequence[Dict[str, Any]]) -> Dict[str, Any]:
    bugs: List[Dict[str, Any]] = []
    seen: Set[str] = set()
    sources: List[str] = []
    for dataset in datasets:
        if not isinstance(dataset, dict):
            continue
        source = str(dataset.get("source", "") or "").strip()
        if source:
            sources.append(source)
        for bug in dataset.get("bugs", []) if isinstance(dataset.get("bugs"), list) else []:
            if not isinstance(bug, dict):
                continue
            extid = str(bug.get("extid", "") or "").strip()
            if not extid or extid in seen:
                continue
            seen.add(extid)
            bugs.append(bug)
    bugs.sort(key=lambda item: str(item.get("last_crash") or item.get("first_crash") or ""), reverse=True)
    return {
        "source": f"merged:{label}",
        "fetched_at": utc_now_iso(),
        "sources": sources,
        "bug_count": len(bugs),
        "bugs": bugs,
    }


def fetch_syzbot_kctf(limit_per_subsystem: int = 120) -> Dict[str, Any]:
    datasets: List[Dict[str, Any]] = []
    for subsystem in ("fs", "net", "mm", "kernel", "security", "drivers"):
        try:
            datasets.append(fetch_syzbot_subsystem(subsystem, limit=limit_per_subsystem))
        except Exception:
            continue
    if not datasets:
        return merge_syzbot_datasets("kctf-empty", [])
    return merge_syzbot_datasets("kctf", datasets)


def extract_cwe(cna: Dict[str, Any]) -> List[str]:
    out: List[str] = []
    for pt in cna.get("problemTypes", []):
        for d in pt.get("descriptions", []):
            cwe = d.get("cweId")
            if cwe:
                out.append(cwe)
    return sorted(set(out))


def fetch_cve_kernel_target(limit: int, keywords: Set[str], source_label: str) -> Dict[str, Any]:
    url = "https://cve.circl.lu/api/search/linux/kernel"
    raw = fetch_text(url, timeout=120)
    blob = json.loads(raw)
    rows = blob.get("results", {}).get("cvelistv5", [])

    picked: List[Dict[str, Any]] = []
    fallback_pool: List[Dict[str, Any]] = []
    for row in rows[:limit]:
        if not isinstance(row, list) or len(row) != 2:
            continue
        cve_id = str(row[0])
        obj = row[1] if isinstance(row[1], dict) else {}
        cna = obj.get("containers", {}).get("cna", {})
        title = cna.get("title", "") or ""
        descs = cna.get("descriptions", [])
        desc_text = " ".join(d.get("value", "") for d in descs if isinstance(d, dict) and d.get("lang") == "en")
        haystack = f"{title} {desc_text}".lower()

        is_target_related = any(k in haystack for k in keywords)

        refs = []
        for ref in cna.get("references", []):
            if isinstance(ref, dict) and ref.get("url"):
                refs.append(ref["url"])

        meta = obj.get("cveMetadata", {})
        sig = signature_tokens(f"{title} {desc_text}")

        entry = {
            "cve_id": cve_id.upper(),
            "title": title,
            "description": desc_text[:4000],
            "published": meta.get("datePublished"),
            "updated": meta.get("dateUpdated"),
            "cwe": extract_cwe(cna),
            "references": refs[:8],
            "signature_tokens": sig,
        }
        if is_target_related:
            picked.append(entry)
        else:
            fallback_pool.append(entry)

    if not picked and fallback_pool:
        # Defensive fallback for feed format/keyword drift: keep a bounded
        # kernel CVE baseline instead of returning an empty dataset.
        picked = fallback_pool[:200]

    return {
        "source": source_label,
        "fetched_at": utc_now_iso(),
        "entry_count": len(picked),
        "entries": picked,
    }


def fetch_cve_kernel_fs(limit: int = 2000) -> Dict[str, Any]:
    return fetch_cve_kernel_target(limit=limit, keywords=FS_KEYWORDS, source_label="cve/linux-kernel/fs")


def fetch_cve_kernel_net(limit: int = 2500) -> Dict[str, Any]:
    return fetch_cve_kernel_target(limit=limit, keywords=NET_KEYWORDS, source_label="cve/linux-kernel/net")


def fetch_cve_kernel_kctf(limit: int = 3500) -> Dict[str, Any]:
    return fetch_cve_kernel_target(limit=limit, keywords=KCTF_KEYWORDS, source_label="cve/linux-kernel/kctf")


def cmd_knowledge_refresh(ctx: KernelAuditContext, _args: argparse.Namespace) -> int:
    ctx.ensure_layout()
    ensure_default_files(ctx)
    campaign = ctx.load_campaign()

    if ctx.target == "net":
        syz = fetch_syzbot_net()
        cve = fetch_cve_kernel_net()
        label = "net"
    elif ctx.target == "kctf":
        syz = fetch_syzbot_kctf()
        cve = fetch_cve_kernel_kctf()
        label = "kctf"
    else:
        syz = fetch_syzbot_fs()
        cve = fetch_cve_kernel_fs()
        label = "fs"
    write_json(ctx.syzbot_path, syz)
    write_json(ctx.cve_path, cve)

    snapshot = {
        "generated_at": utc_now_iso(),
        "syzbot": {
            "path": str(ctx.syzbot_path),
            "count": syz.get("bug_count", 0),
            "sha256": sha256_file(ctx.syzbot_path),
        },
        "cve": {
            "path": str(ctx.cve_path),
            "count": cve.get("entry_count", 0),
            "sha256": sha256_file(ctx.cve_path),
        },
    }
    write_json(ctx.knowledge_snapshot_path, snapshot)

    campaign["knowledge_snapshot"] = str(ctx.knowledge_snapshot_path)
    campaign["knowledge_snapshot_at"] = snapshot["generated_at"]
    refresh_campaign_metrics(ctx, campaign)
    ctx.save_campaign(campaign)

    print("[kaudit] knowledge refresh complete")
    print(f"[kaudit] target: {ctx.target}")
    print(f"[kaudit] syzbot {label} bugs: {syz.get('bug_count', 0)}")
    print(f"[kaudit] {label}-related cve entries: {cve.get('entry_count', 0)}")
    print(f"[kaudit] snapshot: {ctx.knowledge_snapshot_path}")
    return 0


def fragment_paths(ctx: KernelAuditContext) -> List[Path]:
    names = set(ctx.default_fragments())
    return sorted(p for p in ctx.fragments_dir.glob("*.config") if p.is_file() and p.name in names)


def apply_fragments(ctx: KernelAuditContext, extra_fragments: Optional[List[Path]] = None) -> None:
    build_config = ctx.build_dir / ".config"
    if not build_config.exists():
        raise RuntimeError(f"missing {build_config}; run build init first")

    merge_script = ctx.repo_root / "scripts" / "kconfig" / "merge_config.sh"
    if not merge_script.exists():
        raise RuntimeError(f"missing merge_config.sh: {merge_script}")

    frags = fragment_paths(ctx)
    if extra_fragments:
        frags.extend(extra_fragments)
    frags = [f for f in frags if f.exists()]
    if not frags:
        return

    cmd = [str(merge_script), "-m", "-O", str(ctx.build_dir), str(build_config)] + [str(f) for f in frags]
    result = run_cmd(cmd, cwd=ctx.repo_root, check=True)
    if result.stdout.strip():
        (ctx.logs_dir / "build-fragments.log").write_text(result.stdout, encoding="utf-8")

    run_cmd(["make", f"O={ctx.build_dir}", "ARCH=x86_64", "olddefconfig"], cwd=ctx.repo_root, check=True)


def kernel_release(ctx: KernelAuditContext) -> str:
    rel_file = ctx.build_dir / "include" / "config" / "kernel.release"
    if rel_file.exists():
        return rel_file.read_text(encoding="utf-8").strip()
    out = run_cmd(["make", f"O={ctx.build_dir}", "ARCH=x86_64", "kernelrelease"], cwd=ctx.repo_root, check=True)
    return out.stdout.strip()


def ensure_build_config_exists(ctx: KernelAuditContext) -> None:
    build_config = ctx.build_dir / ".config"
    if build_config.exists():
        return
    seed = ctx.config_seed()
    kind = str(seed.get("kind", "allmodconfig") or "allmodconfig")
    if kind == "allmodconfig":
        print(f"[kaudit] generating initial allmodconfig for target `{ctx.target}` (x86_64)")
        run_cmd(["make", f"O={ctx.build_dir}", "ARCH=x86_64", "allmodconfig"], cwd=ctx.repo_root, check=True)
        return
    if kind == "full_config":
        ensure_target_source_compat(ctx)
        seed_path = ctx.seed_config_path()
        if not seed_path or not seed_path.exists():
            raise RuntimeError(f"missing target seed config: {seed_path}")
        print(
            f"[kaudit] seeding build config for target `{ctx.target}` from "
            f"{seed.get('label', seed_path.name)} ({seed_path})"
        )
        shutil.copy2(seed_path, build_config)
        run_cmd(["make", f"O={ctx.build_dir}", "ARCH=x86_64", "olddefconfig"], cwd=ctx.repo_root, check=True)
        return
    raise RuntimeError(f"unsupported config seed kind for target `{ctx.target}`: {kind}")


def write_generated_fragment(ctx: KernelAuditContext, name: str, lines: Sequence[str]) -> Path:
    frag = ctx.fragments_dir / name
    if not lines:
        if frag.exists():
            frag.unlink()
        return frag
    frag.write_text("\n".join(lines) + "\n", encoding="utf-8")
    return frag


def cmd_build_init(ctx: KernelAuditContext, args: argparse.Namespace) -> int:
    ctx.ensure_layout()
    ensure_default_files(ctx)
    ensure_target_source_compat(ctx)

    jobs = args.jobs if args.jobs and args.jobs > 0 else os.cpu_count() or 1
    clear_compiled_source_cache(ctx)
    ensure_build_config_exists(ctx)

    apply_fragments(ctx)

    print(f"[kaudit] building bzImage with -j{jobs}")
    run_cmd(
        [
            "make",
            f"O={ctx.build_dir}",
            "ARCH=x86_64",
            f"-j{jobs}",
            "bzImage",
        ],
        cwd=ctx.repo_root,
        check=True,
    )

    release = kernel_release(ctx)
    bzimage = ctx.bzimage_path()
    seed = ctx.config_seed()

    build_state = {
        "updated_at": utc_now_iso(),
        "target": ctx.target,
        "build_dir": str(ctx.build_dir),
        "kernel_release": release,
        "bzImage": str(bzimage),
        "fragments": [str(p.name) for p in fragment_paths(ctx)],
        "jobs": jobs,
        "config_seed": seed,
        "source_tree_version": source_tree_version(ctx.repo_root),
    }
    write_json(ctx.build_state_path, build_state)

    print("[kaudit] build init complete")
    print(f"[kaudit] kernel release: {release}")
    print(f"[kaudit] bzImage: {bzimage}")
    return 0


def case_effective_required_config(case: Dict[str, Any]) -> List[str]:
    repro_plan = case.get("repro_plan", {}) if isinstance(case.get("repro_plan"), dict) else {}
    return merge_required_config(case.get("required_config", []), as_str_list(repro_plan.get("required_config", [])))


NONBLOCKING_REPRO_CONFIG = {
    "CONFIG_KASAN_MULTI_SHOT=y",
    "CONFIG_FRAME_POINTER=y",
}


def case_blocking_repro_config(case: Dict[str, Any]) -> List[str]:
    return [item for item in case_effective_required_config(case) if item not in NONBLOCKING_REPRO_CONFIG]


def cmd_build_repro_backlog(ctx: KernelAuditContext, args: argparse.Namespace) -> int:
    ctx.ensure_layout()
    ensure_default_files(ctx)
    ensure_target_source_compat(ctx)
    clear_compiled_source_cache(ctx)

    stages = {
        s.strip()
        for s in str(getattr(args, "stages", "repro_queued") or "repro_queued").split(",")
        if s.strip()
    }
    if not stages:
        return fail("--stages must include at least one stage")

    cases = collect_cases_by_stage(ctx, stages)
    cases.sort(
        key=lambda item: str(item.get("last_verified_at", item.get("created_at", ""))),
        reverse=not bool(getattr(args, "oldest_first", False)),
    )
    limit = max(0, as_int(getattr(args, "limit", 0), 0))
    if limit:
        cases = cases[:limit]
    if not cases:
        print("[kaudit] build repro-backlog: no matching cases")
        return 0

    merged_required = merge_required_config(*(case_blocking_repro_config(case) for case in cases))
    if bool(getattr(args, "missing_only", True)):
        current_config = load_build_config_map(ctx)
        missing_only = [item for item in merged_required if not config_requirement_satisfied(item, current_config)]
    else:
        missing_only = list(merged_required)

    print("[kaudit] build repro-backlog plan")
    print(f"- stages: {', '.join(sorted(stages))}")
    print(f"- cases: {len(cases)}")
    print(f"- missing_only: {bool(getattr(args, 'missing_only', True))}")
    print(f"- merged_required_count: {len(merged_required)}")
    print(f"- to_apply_count: {len(missing_only)}")
    for item in missing_only[:50]:
        print(f"  - {item}")
    if len(missing_only) > 50:
        print(f"  - ... ({len(missing_only) - 50} more)")

    if not missing_only:
        print("[kaudit] build repro-backlog: current bzImage already satisfies all selected case configs")
        return 0

    ensure_build_config_exists(ctx)
    generated_fragment = write_generated_fragment(ctx, "repro-backlog.config", missing_only)
    apply_fragments(ctx, extra_fragments=[generated_fragment])

    jobs = args.jobs if args.jobs and args.jobs > 0 else os.cpu_count() or 1
    print(f"[kaudit] building bzImage with -j{jobs}")
    run_cmd(
        [
            "make",
            f"O={ctx.build_dir}",
            "ARCH=x86_64",
            f"-j{jobs}",
            "bzImage",
        ],
        cwd=ctx.repo_root,
        check=True,
    )

    release = kernel_release(ctx)
    bzimage = ctx.bzimage_path()
    build_state = {
        "updated_at": utc_now_iso(),
        "target": ctx.target,
        "build_dir": str(ctx.build_dir),
        "kernel_release": release,
        "bzImage": str(bzimage),
        "fragments": [str(p.name) for p in fragment_paths(ctx)] + [generated_fragment.name],
        "jobs": jobs,
        "repro_backlog_fragment": str(generated_fragment),
        "repro_backlog_stages": sorted(stages),
        "repro_backlog_case_count": len(cases),
        "repro_backlog_config_count": len(missing_only),
        "config_seed": ctx.config_seed(),
        "source_tree_version": source_tree_version(ctx.repo_root),
    }
    write_json(ctx.build_state_path, build_state)

    print("[kaudit] build repro-backlog complete")
    print(f"[kaudit] kernel release: {release}")
    print(f"[kaudit] bzImage: {bzimage}")
    print(f"[kaudit] generated_fragment: {generated_fragment}")
    return 0


_FILE_CACHE: Dict[str, List[str]] = {}
_FUNCTION_RANGE_CACHE: Dict[str, List[Tuple[int, int, str]]] = {}
_COMPILED_SOURCE_CACHE: Dict[str, Tuple[str, ...]] = {}


def target_requires_dead_code_pruning(target: str) -> bool:
    profile = target_profile(target)
    return str(profile.get("dead_code_filter", "") or "") == "compiled_sources"


def clear_compiled_source_cache(ctx: KernelAuditContext) -> None:
    prefix = f"{ctx.build_dir.resolve()}::"
    for key in [item for item in _COMPILED_SOURCE_CACHE if item.startswith(prefix)]:
        _COMPILED_SOURCE_CACHE.pop(key, None)


def compiled_source_inventory(ctx: KernelAuditContext, *, roots: Optional[Sequence[str]] = None) -> Tuple[str, ...]:
    effective_roots = tuple(roots or ctx.scan_roots())
    cache_key = f"{ctx.build_dir.resolve()}::{'||'.join(effective_roots)}"
    cached = _COMPILED_SOURCE_CACHE.get(cache_key)
    if cached is not None:
        return cached
    if not ctx.build_dir.exists():
        _COMPILED_SOURCE_CACHE[cache_key] = ()
        return ()

    repo_root_real = ctx.repo_root.resolve()
    allowed_roots = effective_roots or KERNEL_SOURCE_SCAN_PREFIXES
    compiled: Set[str] = set()
    for cmd_file in ctx.build_dir.rglob("*.cmd"):
        if not cmd_file.is_file():
            continue
        text = cmd_file.read_text(encoding="utf-8", errors="replace")
        for match in re.finditer(r"^source_[^:]+ := (.+)$", text, re.M):
            raw_source = match.group(1).strip()
            if not raw_source:
                continue
            source_path = Path(raw_source)
            if source_path.is_absolute():
                try:
                    rel_path = source_path.resolve().relative_to(repo_root_real)
                except ValueError:
                    continue
                rel = normalize_repo_relpath(rel_path)
            else:
                rel = normalize_repo_relpath(raw_source)
            if not rel.endswith(".c"):
                continue
            if not path_matches_roots(rel, allowed_roots):
                continue
            compiled.add(rel)

    result = tuple(sorted(compiled))
    _COMPILED_SOURCE_CACHE[cache_key] = result
    return result


def compiled_source_to_shard(path: str) -> str:
    rel = normalize_repo_relpath(path)
    parts = [part for part in rel.split("/") if part]
    if len(parts) >= 2 and not parts[1].endswith(".c"):
        return "/".join(parts[:2])
    return rel


def ensure_discovery_target_ready(ctx: KernelAuditContext, *, target: str, jobs: int = 0) -> None:
    if not target_requires_dead_code_pruning(target):
        return
    bzimage = ctx.bzimage_path()
    build_config = ctx.build_dir / ".config"
    needs_build = not build_config.exists() or not bzimage.exists()
    if needs_build:
        print(
            f"[kaudit] target `{target}` requires a target-local bzImage before discovery so config-dead code "
            "can be culled; building first"
        )
        cmd_build_init(ctx, argparse.Namespace(jobs=jobs))

    compiled = compiled_source_inventory(ctx)
    if not compiled:
        raise RuntimeError(
            f"target `{target}` has no compiled source inventory under {ctx.build_dir}; "
            f"run `kaudit build init --target {target}` first"
        )


def read_lines(path: Path) -> List[str]:
    key = str(path)
    if key in _FILE_CACHE:
        return _FILE_CACHE[key]
    lines = path.read_text(encoding="utf-8", errors="replace").splitlines()
    _FILE_CACHE[key] = lines
    return lines


def strip_strings_and_comments(line: str, in_block_comment: bool) -> Tuple[str, bool]:
    out: List[str] = []
    i = 0
    n = len(line)
    in_str = False
    str_char = ""

    while i < n:
        ch = line[i]
        nxt = line[i + 1] if i + 1 < n else ""

        if in_block_comment:
            if ch == "*" and nxt == "/":
                in_block_comment = False
                i += 2
                continue
            i += 1
            continue

        if in_str:
            if ch == "\\":
                i += 2
                continue
            if ch == str_char:
                in_str = False
            i += 1
            continue

        if ch == "/" and nxt == "*":
            in_block_comment = True
            i += 2
            continue

        if ch == "/" and nxt == "/":
            break

        if ch == '"' or ch == "'":
            in_str = True
            str_char = ch
            i += 1
            continue

        out.append(ch)
        i += 1

    return "".join(out), in_block_comment


def function_ranges(path: Path) -> List[Tuple[int, int, str]]:
    key = str(path)
    if key in _FUNCTION_RANGE_CACHE:
        return _FUNCTION_RANGE_CACHE[key]

    lines = read_lines(path)
    sanitized: List[str] = []
    in_block = False
    for line in lines:
        clean, in_block = strip_strings_and_comments(line, in_block)
        sanitized.append(clean)

    ranges: List[Tuple[int, int, str]] = []
    n = len(sanitized)
    i = 0
    name_re = re.compile(r"\b([A-Za-z_][A-Za-z0-9_]*)\s*\([^;{}]*\)\s*\{")

    while i < n:
        s = sanitized[i].strip()
        if not s or s.startswith("#") or "(" not in s:
            i += 1
            continue

        header_lines = [s]
        j = i
        saw_brace = "{" in s
        while not saw_brace and j + 1 < n:
            nxt = sanitized[j + 1].strip()
            if not nxt:
                j += 1
                continue
            if nxt.startswith("#"):
                break
            header_lines.append(nxt)
            j += 1
            if "{" in nxt:
                saw_brace = True
            if ";" in nxt and "{" not in nxt:
                break
            if len(" ".join(header_lines)) > 2000:
                break

        header_join = " ".join(header_lines)
        before_brace = header_join.split("{", 1)[0]
        if ";" in before_brace:
            i += 1
            continue

        m = name_re.search(header_join)
        if not m:
            i += 1
            continue

        name = m.group(1)
        name_l = name.lower()
        if name_l in CONTROL_KEYWORDS or name_l in STOPWORDS:
            i += 1
            continue

        open_idx = None
        for k in range(i, min(j + 1, n)):
            if "{" in sanitized[k]:
                open_idx = k
                break
        if open_idx is None:
            i += 1
            continue

        depth = 0
        end_idx = None
        k = open_idx
        while k < n:
            depth += sanitized[k].count("{")
            depth -= sanitized[k].count("}")
            if depth == 0:
                end_idx = k
                break
            k += 1

        if end_idx is None:
            end_idx = n - 1

        ranges.append((i + 1, end_idx + 1, name))
        i = end_idx + 1

    _FUNCTION_RANGE_CACHE[key] = ranges
    return ranges


def enclosing_function(path: Path, line_no: int) -> str:
    for start, end, name in function_ranges(path):
        if start <= line_no <= end:
            return name
    return "unknown_function"


def scan_pattern_hits(ctx: KernelAuditContext, target_dir: str = "fs") -> List[Dict[str, Any]]:
    target = normalize_target_name(target_dir)
    roots = target_scan_roots(target)
    pattern_key = str(target_profile(target).get("seed_pattern", "fs") or "fs")
    scan_pattern = SCAN_PATTERNS.get(pattern_key, SCAN_PATTERNS["fs"])
    rg_cmd = [
        "rg",
        "-n",
        "--no-heading",
        scan_pattern,
        *[root.rstrip("/") for root in roots],
    ]
    rg_result = run_cmd(rg_cmd, cwd=ctx.repo_root, check=False)
    if rg_result.returncode not in (0, 1):
        raise RuntimeError(
            f"failed to scan patterns in {target_dir}: {rg_result.stdout.strip()}"
        )
    out = rg_result.stdout
    candidates: List[Dict[str, Any]] = []
    compiled_sources = set(compiled_source_inventory(ctx, roots=roots)) if target_requires_dead_code_pruning(target) else set()

    for raw in out.splitlines():
        m = re.match(r"([^:]+):(\d+):(.*)", raw)
        if not m:
            continue
        rel = normalize_repo_relpath(m.group(1))
        line_no = int(m.group(2))
        snippet = m.group(3).strip()
        if not path_matches_roots(rel, roots):
            continue
        if compiled_sources and rel not in compiled_sources:
            continue
        path = ctx.repo_root / rel
        if not path.exists() or path.suffix != ".c":
            continue

        kind = "generic"
        score = 1
        if "copy_from_user" in snippet or "copy_to_user" in snippet or "memdup_user" in snippet:
            kind = "usercopy-boundary"
            score = 4
        elif "nla_parse" in snippet or "nla_memcpy" in snippet or "sockptr" in snippet:
            kind = "input-validation"
            score = 4
        elif "skb_put" in snippet or "skb_pull" in snippet or "skb_copy_bits" in snippet:
            kind = "packet-boundary"
            score = 4
        elif "kfree(" in snippet:
            kind = "lifetime"
            score = 3
        elif "kmalloc(" in snippet or "kzalloc(" in snippet or "krealloc(" in snippet:
            kind = "allocation-size"
            score = 2

        candidates.append(
            {
                "path": rel,
                "line": line_no,
                "snippet": snippet,
                "kind": kind,
                "score": score,
                "function": enclosing_function(path, line_no),
            }
        )

    # Extra heuristic: kfree(var) followed by var dereference in nearby lines.
    heuristic_paths = sorted(compiled_sources) if compiled_sources else []
    if not heuristic_paths:
        for root_text in roots:
            scan_root = ctx.repo_root / root_text
            if scan_root.is_file() and scan_root.suffix == ".c":
                heuristic_paths.append(str(scan_root.relative_to(ctx.repo_root)))
                continue
            if not scan_root.exists():
                continue
            heuristic_paths.extend(str(path.relative_to(ctx.repo_root)) for path in scan_root.rglob("*.c"))
    for rel in sorted(set(heuristic_paths)):
        if not path_matches_roots(rel, roots):
            continue
        path = ctx.repo_root / rel
        if not path.exists() or path.suffix != ".c":
            continue
        lines = read_lines(path)
        for idx, line in enumerate(lines):
            m = re.search(r"\bkfree\s*\(\s*([A-Za-z_][A-Za-z0-9_]*)\s*\)", line)
            if not m:
                continue
            var = m.group(1)
            tail = "\n".join(lines[idx + 1 : idx + 12])
            if re.search(rf"\b{re.escape(var)}\s*->", tail):
                candidates.append(
                    {
                        "path": rel,
                        "line": idx + 1,
                        "snippet": line.strip(),
                        "kind": "possible-uaf",
                        "score": 6,
                        "function": enclosing_function(path, idx + 1),
                    }
                )

    candidates.sort(key=lambda c: (-int(c["score"]), c["path"], int(c["line"])))
    return candidates


def candidate_signature(candidate: Dict[str, Any]) -> Dict[str, Any]:
    basis = f"{candidate.get('kind', '')} {candidate.get('function', '')} {candidate.get('snippet', '')} {candidate.get('path', '')}"
    paths = [str(candidate.get("path", ""))]
    functions = [str(candidate.get("function", ""))]
    return {
        "tokens": signature_tokens(basis),
        "paths": sorted({p for p in paths if p}),
        "functions": sorted({f for f in functions if f and f != "unknown_function"}),
        "weakness": classify_weakness(basis),
    }


def load_known_signatures(ctx: KernelAuditContext) -> List[Dict[str, Any]]:
    records: List[Dict[str, Any]] = []

    syz = read_json(ctx.syzbot_path, {})
    for bug in syz.get("bugs", []):
        text_parts: List[str] = []
        title = str(bug.get("title", "") or "")
        text_parts.append(title)
        for c in bug.get("sample_crash_titles", [])[:8]:
            text_parts.append(str(c))
        for d in bug.get("discussions", [])[:6]:
            text_parts.append(str(d))
        raw_text = " ".join(text_parts).strip()
        tokens = sorted(set(list(bug.get("signature_tokens", [])) + signature_tokens(raw_text)))
        if tokens:
            records.append(
                {
                    "id": bug.get("extid"),
                    "source": "syzbot",
                    "title": title,
                    "tokens": tokens,
                    "paths": extract_paths_from_text(raw_text),
                    "functions": extract_functions_from_text(raw_text),
                    "weakness": classify_weakness(raw_text),
                    "first_crash": bug.get("first_crash"),
                    "last_crash": bug.get("last_crash"),
                }
            )

    cve = read_json(ctx.cve_path, {})
    for entry in cve.get("entries", []):
        title = str(entry.get("title", "") or "")
        desc = str(entry.get("description", "") or "")
        raw_text = f"{title} {desc}"
        tokens = sorted(set(list(entry.get("signature_tokens", [])) + signature_tokens(raw_text)))
        if tokens:
            records.append(
                {
                    "id": entry.get("cve_id"),
                    "source": "cve",
                    "title": title,
                    "tokens": tokens,
                    "paths": extract_paths_from_text(raw_text),
                    "functions": extract_functions_from_text(raw_text),
                    "weakness": classify_weakness(raw_text),
                }
            )

    return records


def best_known_similarity(
    candidate_sig: Dict[str, Any], known: List[Dict[str, Any]]
) -> Tuple[float, Optional[Dict[str, Any]], Dict[str, float]]:
    best_score = 0.0
    best: Optional[Dict[str, Any]] = None
    best_details = {"score": 0.0, "token": 0.0, "function": 0.0, "path": 0.0, "weakness": 0.0}
    for item in known:
        details = similarity_breakdown(candidate_sig, item)
        score = details["score"]
        if score > best_score:
            best_score = score
            best = item
            best_details = details
    return best_score, best, best_details


def case_signature(case: Dict[str, Any]) -> Dict[str, Any]:
    case = normalize_case(case)
    analysis = case.get("analysis", {}) if isinstance(case.get("analysis"), dict) else {}
    existing = analysis.get("signature", {}) if isinstance(analysis.get("signature"), dict) else {}
    basis = " ".join(
        [
            str(case.get("root_cause", "") or ""),
            str(case.get("impact", "") or ""),
            str(case.get("attack_scenario", "") or ""),
            str(case.get("verification", {}).get("proof", "") or ""),
            str(case.get("verification", {}).get("trigger_contract", "") or ""),
            str(case.get("analysis", {}).get("candidate", {}).get("snippet", "") or ""),
            " ".join(as_str_list(case.get("target_paths", []))),
            " ".join(as_str_list(case.get("suspect_functions", []))),
        ]
    ).strip()
    paths = sorted(
        {
            *as_str_list(case.get("target_paths", [])),
            *as_str_list(existing.get("paths", [])),
            *extract_paths_from_text(basis),
        }
    )
    functions = sorted(
        {
            *[f for f in as_str_list(case.get("suspect_functions", [])) if f != "unknown_function"],
            *[f for f in as_str_list(existing.get("functions", [])) if f != "unknown_function"],
            *extract_functions_from_text(basis),
        }
    )
    tokens = sorted(set(as_str_list(existing.get("tokens", [])) + signature_tokens(basis)))
    weakness = str(existing.get("weakness", "") or classify_weakness(basis) or "unknown")
    return {
        "tokens": tokens,
        "paths": paths,
        "functions": functions,
        "weakness": weakness,
    }


def case_search_terms(case: Dict[str, Any]) -> List[str]:
    case = normalize_case(case)
    terms: List[str] = []
    for fn in as_str_list(case.get("suspect_functions", []))[:3]:
        if fn and fn != "unknown_function":
            terms.append(fn)
    for path in as_str_list(case.get("target_paths", []))[:2]:
        p = Path(path)
        if p.name:
            terms.append(p.name)
        if len(p.parts) >= 2:
            terms.append("/".join(p.parts[:2]))
    weakness = str(case_signature(case).get("weakness", "") or "")
    if weakness and weakness != "unknown":
        terms.append(weakness)
    deduped: List[str] = []
    seen = set()
    for term in terms:
        text = str(term or "").strip()
        if len(text) < 3:
            continue
        if text in seen:
            continue
        seen.add(text)
        deduped.append(text)
    return deduped[:3]


def similarity_match_record(
    candidate_sig: Dict[str, Any],
    record: Dict[str, Any],
    *,
    source: str,
    title: str,
    identifier: str,
    url: str = "",
    extra: Optional[Dict[str, Any]] = None,
) -> Dict[str, Any]:
    details = similarity_breakdown(candidate_sig, record)
    out = {
        "source": source,
        "id": identifier,
        "title": title,
        "score": round(details["score"], 4),
        "components": {k: round(float(v), 4) for k, v in details.items()},
        "weakness": str(record.get("weakness", "") or ""),
        "paths": as_str_list(record.get("paths", []))[:6],
        "functions": as_str_list(record.get("functions", []))[:6],
    }
    if url:
        out["url"] = url
    if extra:
        out.update(extra)
    return out


def syzbot_record_from_bug_json(payload: Dict[str, Any], *, source: str, search_query: str = "") -> Dict[str, Any]:
    title = str(payload.get("title", "") or "")
    status = str(payload.get("status", "") or "")
    crashes = payload.get("crashes", []) if isinstance(payload.get("crashes"), list) else []
    crash_titles = [str(c.get("title", "") or "") for c in crashes[:6] if isinstance(c, dict) and c.get("title")]
    discussions = as_str_list(payload.get("discussions", []))[:8]
    raw_text = " ".join([title, status, *crash_titles, *discussions]).strip()
    extid = str(payload.get("id", "") or payload.get("extid", "") or "")
    if not extid:
        extid = ""
    return {
        "id": extid,
        "source": source,
        "title": title,
        "status": status,
        "first_crash": payload.get("first_crash") or payload.get("first-crash"),
        "last_crash": payload.get("last_crash") or payload.get("last-crash"),
        "tokens": sorted(set(signature_tokens(raw_text))),
        "paths": extract_paths_from_text(raw_text),
        "functions": extract_functions_from_text(raw_text),
        "weakness": classify_weakness(raw_text),
        "search_query": search_query,
        "url": f"https://syzkaller.appspot.com/bug?extid={extid}" if extid else "",
    }


def fetch_syzbot_search_matches(query: str, *, fixed: bool = False, limit: int = 5) -> List[Dict[str, Any]]:
    query = str(query or "").strip()
    if len(query) < 3:
        return []
    page = "upstream/fixed" if fixed else "upstream"
    url = f"https://syzkaller.appspot.com/{page}?search={quote_plus(query)}"
    html = fetch_text(url, timeout=LIVE_SYZBOT_TIMEOUT_SECONDS)
    extids = re.findall(r"/bug\\?extid=([a-f0-9]+)", html)
    uniq: List[str] = []
    seen = set()
    for extid in extids:
        if extid in seen:
            continue
        seen.add(extid)
        uniq.append(extid)
    matches: List[Dict[str, Any]] = []
    for extid in uniq[: max(1, limit)]:
        bug = fetch_json(
            f"https://syzkaller.appspot.com/bug?extid={extid}&json=1",
            timeout=LIVE_SYZBOT_TIMEOUT_SECONDS,
        )
        if not isinstance(bug, dict):
            continue
        bug["extid"] = extid
        record = syzbot_record_from_bug_json(
            bug,
            source="syzbot-live-fixed" if fixed else "syzbot-live",
            search_query=query,
        )
        if record["id"] == "":
            record["id"] = extid
            record["url"] = f"https://syzkaller.appspot.com/bug?extid={extid}"
        matches.append(record)
    return matches


def current_head_datetime(ctx: KernelAuditContext) -> Optional[datetime]:
    result = run_cmd(["git", "show", "-s", "--format=%cI", "HEAD"], cwd=ctx.repo_root, check=False)
    if result.returncode != 0:
        return None
    return parse_datetime_iso(result.stdout.strip())


def is_near_mainline_datetime(value: Optional[datetime], *, reference: Optional[datetime], days: int) -> bool:
    if value is None or reference is None:
        return False
    delta = reference - value
    return timedelta(days=0) <= delta <= timedelta(days=max(1, days))


def git_commit_has_bug_signal(subject: str, body: str) -> bool:
    text = f"{subject} {body}".lower()
    return any(word in text for word in ("fix", "syzbot", "kasan", "oops", "warning", "overflow", "uaf", "use-after-free", "out-of-bounds", "oob"))


def git_commit_records_for_case(
    ctx: KernelAuditContext,
    case: Dict[str, Any],
    *,
    limit: int = 200,
    recent_days: int = PRE_DISCLOSE_NEAR_MAINLINE_DAYS,
) -> List[Dict[str, Any]]:
    paths = as_str_list(case.get("target_paths", []))
    if not paths:
        return []
    head_dt = current_head_datetime(ctx)
    scopes: List[str] = []
    seen = set()
    for raw in paths[:2]:
        p = Path(raw)
        for scope in [raw, str(p.parent)]:
            if scope and scope not in seen:
                seen.add(scope)
                scopes.append(scope)
    records: List[Dict[str, Any]] = []
    commit_seen = set()
    for scope in scopes:
        cmd = [
            "git",
            "log",
            "--no-merges",
            f"-n{max(20, limit)}",
            "--date=short",
            "--format=%H%x1f%ad%x1f%s%x1f%b%x1e",
            "--",
            scope,
        ]
        result = run_cmd(cmd, cwd=ctx.repo_root, check=False)
        if result.returncode not in (0, 128):
            continue
        for chunk in result.stdout.split("\x1e"):
            chunk = chunk.strip()
            if not chunk:
                continue
            parts = chunk.split("\x1f", 3)
            if len(parts) != 4:
                continue
            commit, authored, subject, body = parts
            if commit in commit_seen:
                continue
            authored_dt = parse_datetime_ymd(authored)
            if head_dt is not None and authored_dt is not None and not is_near_mainline_datetime(authored_dt, reference=head_dt, days=recent_days):
                continue
            commit_seen.add(commit)
            raw_text = f"{subject} {body}".strip()
            records.append(
                {
                    "id": commit,
                    "source": "git-commit",
                    "title": subject.strip(),
                    "authored": authored.strip(),
                    "tokens": signature_tokens(raw_text),
                    "paths": [scope],
                    "functions": extract_functions_from_text(raw_text),
                    "weakness": classify_weakness(raw_text),
                    "subject": subject.strip(),
                    "body": body.strip(),
                    "near_mainline": True if authored_dt is None or head_dt is None else is_near_mainline_datetime(authored_dt, reference=head_dt, days=recent_days),
                    "bug_signal": git_commit_has_bug_signal(subject, body),
                    "url": f"https://git.kernel.org/pub/scm/linux/kernel/git/torvalds/linux.git/commit/?id={commit}",
                }
            )
    return records


def local_case_match_records(ctx: KernelAuditContext, case: Dict[str, Any], *, max_results: int = 5) -> List[Dict[str, Any]]:
    candidate_sig = case_signature(case)
    current_id = str(case.get("case_id", "") or "")
    matches: List[Dict[str, Any]] = []
    for other in collect_cases_by_stage(ctx, CONFIRMED_STAGES):
        if str(other.get("case_id", "") or "") == current_id:
            continue
        other_sig = case_signature(other)
        match = similarity_match_record(
            candidate_sig,
            other_sig,
            source="local-case",
            title=str(other.get("root_cause", "") or other.get("case_id", ""))[:180],
            identifier=str(other.get("case_id", "") or ""),
            extra={"stage": other.get("stage")},
        )
        matches.append(match)
    matches.sort(key=lambda item: (-float(item.get("score", 0.0)), str(item.get("id", ""))))
    return matches[: max_results]


def maybe_refresh_knowledge_for_disclosure(
    ctx: KernelAuditContext,
    *,
    refresh_requested: bool = False,
    max_age_seconds: int = PRE_DISCLOSE_MAX_AGE_SECONDS,
) -> Tuple[bool, Optional[str]]:
    snapshot = read_json(ctx.knowledge_snapshot_path, {})
    generated = str(snapshot.get("generated_at", "") or "")
    stale = True
    if generated:
        try:
            generated_dt = datetime.fromisoformat(generated.replace("Z", "+00:00"))
            stale = (datetime.now(timezone.utc) - generated_dt).total_seconds() > max_age_seconds
        except ValueError:
            stale = True
    if not refresh_requested:
        if ctx.syzbot_path.exists() and ctx.cve_path.exists():
            return False, None
        return False, "knowledge snapshot missing; rerun with --refresh"
    if not stale and ctx.syzbot_path.exists() and ctx.cve_path.exists():
        return False, None
    try:
        rc = cmd_knowledge_refresh(ctx, argparse.Namespace())
    except Exception as exc:
        return False, f"knowledge refresh failed: {exc}"
    if rc != 0:
        return False, "knowledge refresh failed"
    return True, None


def match_is_recent_syzbot(match: Dict[str, Any], *, reference: Optional[datetime], days: int = PRE_DISCLOSE_NEAR_MAINLINE_DAYS) -> bool:
    first_dt = parse_datetime_iso(str(match.get("first_crash", "") or ""))
    last_dt = parse_datetime_iso(str(match.get("last_crash", "") or ""))
    for candidate in (last_dt, first_dt):
        if is_near_mainline_datetime(candidate, reference=reference, days=days):
            return True
    return False


def knowledge_match_eligible_for_verdict(match: Dict[str, Any], *, reference: Optional[datetime]) -> bool:
    source = str(match.get("source", "") or "")
    if source == "syzbot":
        return match_is_recent_syzbot(match, reference=reference)
    return False


def evaluate_pre_disclosure_verdict(
    *,
    best_score: float,
    best_source: str,
    best_title: str,
    hard_threshold: float,
    soft_threshold: float,
    live_matches: List[Dict[str, Any]],
    git_matches: List[Dict[str, Any]],
) -> Tuple[str, str]:
    if best_score >= hard_threshold:
        return (
            "possible_duplicate",
            f"High-similarity match found from {best_source}: {best_title} (score={best_score:.4f}).",
        )
    if best_score >= soft_threshold:
        return (
            "needs_manual_review",
            f"Moderate-similarity match found from {best_source}: {best_title} (score={best_score:.4f}).",
        )
    for match in live_matches:
        text = f"{match.get('title', '')} {' '.join(match.get('functions', []))}".lower()
        if "syzbot" in text or "kasan" in text:
            if float(match.get("score", 0.0)) >= max(0.15, soft_threshold * 0.6):
                return (
                    "needs_manual_review",
                    f"Live syzbot search surfaced a relevant public report candidate: {match.get('title')} (score={float(match.get('score', 0.0)):.4f}).",
                )
    for match in git_matches:
        subj = str(match.get("title", "") or "").lower()
        if any(word in subj for word in ("fix", "syzbot", "kasan", "oops", "overflow", "uaf")):
            if float(match.get("score", 0.0)) >= max(0.15, soft_threshold * 0.6):
                return (
                    "needs_manual_review",
                    f"Recent git history contains a potentially related fix/report commit: {match.get('title')} (score={float(match.get('score', 0.0)):.4f}).",
                )
    return ("clear", "No strong duplicate or prior-fix signal was found across refreshed knowledge, live syzbot search, and local git history.")


def run_pre_disclosure_check(
    ctx: KernelAuditContext,
    case: Dict[str, Any],
    *,
    refresh: bool,
    hard_threshold: float,
    soft_threshold: float,
    max_results: int,
    live_syzbot: bool = True,
) -> Dict[str, Any]:
    case = normalize_case(case)
    candidate_sig = case_signature(case)
    errors: List[str] = []
    refreshed_at = None
    head_dt = current_head_datetime(ctx)

    refreshed, refresh_error = maybe_refresh_knowledge_for_disclosure(ctx, refresh_requested=refresh)
    if refreshed:
        refreshed_at = utc_now_iso()
    if refresh_error:
        errors.append(refresh_error)

    knowledge_records = load_known_signatures(ctx)
    best_score, best_ref, best_details = best_known_similarity(candidate_sig, knowledge_records)
    knowledge_matches: List[Dict[str, Any]] = []
    for item in knowledge_records:
        match = similarity_match_record(
            candidate_sig,
            item,
            source=str(item.get("source", "") or "knowledge"),
            title=str(item.get("title", "") or ""),
            identifier=str(item.get("id", "") or ""),
            extra={
                "first_crash": item.get("first_crash"),
                "last_crash": item.get("last_crash"),
            },
        )
        if float(match["score"]) > 0.0:
            knowledge_matches.append(match)
    knowledge_matches.sort(key=lambda item: (-float(item.get("score", 0.0)), str(item.get("id", ""))))
    knowledge_matches = knowledge_matches[: max_results]

    live_syzbot_records: List[Dict[str, Any]] = []
    if live_syzbot:
        for query in case_search_terms(case):
            for fixed in (False, True):
                try:
                    live_syzbot_records.extend(fetch_syzbot_search_matches(query, fixed=fixed, limit=max_results))
                except Exception as exc:
                    errors.append(f"syzbot search '{query}' ({'fixed' if fixed else 'open'}): {exc}")
    live_seen = set()
    live_syzbot_records = [r for r in live_syzbot_records if not (r["id"] in live_seen or live_seen.add(r["id"]))]
    live_matches = [
        similarity_match_record(
            candidate_sig,
            record,
            source=str(record.get("source", "") or "syzbot-live"),
            title=str(record.get("title", "") or ""),
            identifier=str(record.get("id", "") or ""),
            url=str(record.get("url", "") or ""),
            extra={
                "search_query": record.get("search_query", ""),
                "first_crash": record.get("first_crash"),
                "last_crash": record.get("last_crash"),
            },
        )
        for record in live_syzbot_records
    ]
    live_matches = [item for item in live_matches if float(item.get("score", 0.0)) > 0.0]
    live_matches.sort(key=lambda item: (-float(item.get("score", 0.0)), str(item.get("id", ""))))
    live_matches = live_matches[: max_results]

    git_records = git_commit_records_for_case(ctx, case, limit=200)
    git_matches = []
    for record in git_records:
        match = similarity_match_record(
            candidate_sig,
            record,
            source="git-commit",
            title=str(record.get("title", "") or ""),
            identifier=str(record.get("id", "") or ""),
            url=str(record.get("url", "") or ""),
            extra={
                "authored": record.get("authored", ""),
                "near_mainline": bool(record.get("near_mainline", False)),
                "bug_signal": bool(record.get("bug_signal", False)),
            },
        )
        if bool(record.get("bug_signal", False)):
            match["score"] = round(min(1.0, float(match["score"]) + 0.08), 4)
        if float(match.get("score", 0.0)) > 0.0:
            git_matches.append(match)
    git_matches.sort(key=lambda item: (-float(item.get("score", 0.0)), str(item.get("id", ""))))
    git_matches = git_matches[: max_results]
    eligible_git = [item for item in git_matches if bool(item.get("near_mainline", False)) and bool(item.get("bug_signal", False))]

    local_matches = local_case_match_records(ctx, case, max_results=max_results)

    display_best_match = None
    display_best_source = "none"
    display_best_title = "no match"
    if best_ref is not None:
        display_best_match = similarity_match_record(
            candidate_sig,
            best_ref,
            source=str(best_ref.get("source", "") or "knowledge"),
            title=str(best_ref.get("title", "") or ""),
            identifier=str(best_ref.get("id", "") or ""),
            extra={
                "first_crash": best_ref.get("first_crash"),
                "last_crash": best_ref.get("last_crash"),
            },
        )
        display_best_match["components"] = {k: round(float(v), 4) for k, v in best_details.items()}
        display_best_source = str(display_best_match.get("source", "") or "knowledge")
        display_best_title = str(display_best_match.get("title", "") or display_best_match.get("id", "") or "unknown")
    for pool in (live_matches, git_matches, local_matches):
        if pool and float(pool[0].get("score", 0.0)) > float(display_best_match.get("score", 0.0) if isinstance(display_best_match, dict) else best_score):
            display_best_match = pool[0]
            best_score = float(pool[0].get("score", 0.0))
            display_best_source = str(pool[0].get("source", "") or "unknown")
            display_best_title = str(pool[0].get("title", "") or pool[0].get("id", "") or "unknown")

    eligible_knowledge = [item for item in knowledge_matches if knowledge_match_eligible_for_verdict(item, reference=head_dt)]
    eligible_live = [item for item in live_matches if match_is_recent_syzbot(item, reference=head_dt)]
    eligible_local = list(local_matches)

    verdict_best_match = None
    verdict_best_score = 0.0
    verdict_best_source = "none"
    verdict_best_title = "no match"
    for pool in (eligible_knowledge, eligible_live, eligible_git, eligible_local):
        if pool and float(pool[0].get("score", 0.0)) > verdict_best_score:
            verdict_best_match = pool[0]
            verdict_best_score = float(pool[0].get("score", 0.0))
            verdict_best_source = str(pool[0].get("source", "") or "unknown")
            verdict_best_title = str(pool[0].get("title", "") or pool[0].get("id", "") or "unknown")

    verdict, summary = evaluate_pre_disclosure_verdict(
        best_score=verdict_best_score,
        best_source=verdict_best_source,
        best_title=verdict_best_title,
        hard_threshold=hard_threshold,
        soft_threshold=soft_threshold,
        live_matches=eligible_live,
        git_matches=eligible_git,
    )
    if errors and verdict == "clear":
        verdict = "needs_manual_review"
        summary = f"Fresh duplicate check had partial errors and should be reviewed manually. Best considered signal: {verdict_best_source} ({verdict_best_score:.4f})."

    return {
        "checked_at": utc_now_iso(),
        "knowledge_refreshed_at": refreshed_at,
        "verdict": verdict,
        "summary": summary,
        "best_match": verdict_best_match,
        "display_best_match": display_best_match,
        "thresholds": {"hard": hard_threshold, "soft": soft_threshold},
        "results": {
            "knowledge": knowledge_matches,
            "live_syzbot": live_matches,
            "git_commits": eligible_git,
            "git_context": git_matches,
            "local_cases": local_matches,
            "eligible_knowledge": eligible_knowledge,
            "eligible_live_syzbot": eligible_live,
            "eligible_git_commits": eligible_git,
            "eligible_local_cases": eligible_local,
        },
        "errors": errors,
    }


def write_pre_disclose_case_snapshot(ctx: KernelAuditContext, case: Dict[str, Any], result: Dict[str, Any]) -> Path:
    snapshot_path = ctx.case_dir(case["case_id"]) / f"pre-disclose-{utc_stamp()}.json"
    payload = {
        "generated_at": utc_now_iso(),
        "case_id": case["case_id"],
        "stage": case_stage(case),
        "result": result,
    }
    write_json(snapshot_path, payload)
    return snapshot_path


def render_pre_disclose_batch_markdown(payload: Dict[str, Any]) -> str:
    lines: List[str] = []
    lines.append("# Pre-Disclosure Duplicate Check")
    lines.append("")
    lines.append(f"- generated_at: {payload.get('generated_at')}")
    lines.append(f"- stages: {', '.join(payload.get('stages', []))}")
    lines.append(f"- refresh: {payload.get('refresh')}")
    lines.append(f"- live_syzbot: {payload.get('live_syzbot')}")
    lines.append("")
    lines.append("## Verdict Counts")
    counts = payload.get("counts", {}) if isinstance(payload.get("counts"), dict) else {}
    for verdict in sorted(counts):
        lines.append(f"- {verdict}: {counts[verdict]}")
    lines.append("")
    lines.append("## Results")
    for row in payload.get("results", []):
        best = row.get("best_match") if isinstance(row.get("best_match"), dict) else None
        best_text = ""
        if best:
            best_text = f" | best={best.get('source')}:{best.get('id')} score={best.get('score')}"
        lines.append(f"- {row.get('case_id')} | stage={row.get('stage')} | verdict={row.get('verdict')}{best_text}")
        summary = str(row.get("summary", "") or "").strip()
        if summary:
            lines.append(f"  {summary}")
    lines.append("")
    return "\n".join(lines)


def write_pre_disclose_batch_snapshot(ctx: KernelAuditContext, payload: Dict[str, Any]) -> Tuple[Path, Path]:
    stamp = utc_stamp()
    json_path = ctx.logs_dir / f"pre-disclose-batch-{stamp}.json"
    md_path = ctx.logs_dir / f"pre-disclose-batch-{stamp}.md"
    write_json(json_path, payload)
    write_text(md_path, render_pre_disclose_batch_markdown(payload))
    return json_path, md_path


def make_case_id() -> str:
    return f"case-{utc_stamp()}-{random.randint(0, 0xFFFF):04x}"


def merge_required_config(*groups: Iterable[str]) -> List[str]:
    seen: Set[str] = set()
    out: List[str] = []
    for group in groups:
        for item in group:
            text = normalize_config_entry(item)
            if not text or text in seen:
                continue
            seen.add(text)
            out.append(text)
    return out


def normalize_config_entry(item: Any) -> Optional[str]:
    text = str(item or "").strip()
    if not text:
        return None
    if re.fullmatch(r"CONFIG_[A-Za-z0-9_]+", text):
        return text + "=y"
    if re.fullmatch(r"CONFIG_[A-Za-z0-9_]+=(y|m|n|\\d+|0x[0-9A-Fa-f]+|\".*\")", text):
        return text
    if re.fullmatch(r"# CONFIG_[A-Za-z0-9_]+ is not set", text):
        return text
    return None


def load_build_config_map(ctx: KernelAuditContext) -> Dict[str, str]:
    cfg = ctx.build_dir / ".config"
    if not cfg.exists():
        return {}
    out: Dict[str, str] = {}
    for line in cfg.read_text(encoding="utf-8", errors="replace").splitlines():
        line = line.strip()
        if not line:
            continue
        m = re.fullmatch(r"CONFIG_([A-Za-z0-9_]+)=(.*)", line)
        if m:
            out[m.group(1)] = m.group(2)
            continue
        m = re.fullmatch(r"# CONFIG_([A-Za-z0-9_]+) is not set", line)
        if m:
            out[m.group(1)] = "n"
    return out


def config_requirement_satisfied(requirement: str, config_map: Dict[str, str]) -> bool:
    req = normalize_config_entry(requirement)
    if not req:
        return True
    m = re.fullmatch(r"CONFIG_([A-Za-z0-9_]+)=(.*)", req)
    if m:
        key = m.group(1)
        want = m.group(2)
        have = config_map.get(key, "n")
        if want == "m":
            return have in {"m", "y"}
        if want == "n":
            return have == "n"
        return have == want
    m = re.fullmatch(r"# CONFIG_([A-Za-z0-9_]+) is not set", req)
    if m:
        return config_map.get(m.group(1), "n") == "n"
    return True


def missing_required_config(ctx: KernelAuditContext, case: Dict[str, Any]) -> List[str]:
    config_map = load_build_config_map(ctx)
    if not config_map:
        return case_blocking_repro_config(case)
    missing: List[str] = []
    for item in case_blocking_repro_config(case):
        if not config_requirement_satisfied(item, config_map):
            missing.append(item)
    return missing


def select_repro_batch_cases(
    ctx: KernelAuditContext,
    args: argparse.Namespace,
    limit: int,
) -> Tuple[List[Dict[str, Any]], List[Tuple[str, List[str]]]]:
    pending_all = sorted(
        collect_cases_by_stage(ctx, {"repro_queued"}),
        key=lambda item: str(item.get("last_verified_at", item.get("created_at", ""))),
        reverse=not bool(getattr(args, "oldest_first", False)),
    )
    selected: List[Dict[str, Any]] = []
    skipped_missing_config: List[Tuple[str, List[str]]] = []
    skip_build = bool(getattr(args, "repro_skip_build", False))

    for case in pending_all:
        if len(selected) >= limit:
            break
        if skip_build:
            missing = missing_required_config(ctx, case)
            if missing:
                skipped_missing_config.append((case["case_id"], missing))
                continue
        selected.append(case)
    return selected, skipped_missing_config


def case_location_key(candidate: Dict[str, Any]) -> str:
    return f"{candidate.get('path', '')}:{candidate.get('line', 0)}:{candidate.get('kind', '')}"


def case_fingerprint(path: str, function: str, kind: str) -> str:
    return f"{path}|{function}|{kind}"


def collect_case_fingerprints(ctx: KernelAuditContext) -> Set[str]:
    fps: Set[str] = set()
    for case_path in collect_case_paths(ctx):
        case = normalize_case(read_json(case_path, {}))
        path = str((case.get("target_paths") or [""])[0] if isinstance(case.get("target_paths"), list) else "")
        function = str((case.get("suspect_functions") or [""])[0] if isinstance(case.get("suspect_functions"), list) else "")
        kind = str(case.get("analysis", {}).get("candidate", {}).get("kind", "") or "")
        if path and function and kind:
            fps.add(case_fingerprint(path, function, kind))
    return fps


def enumerate_target_shards(ctx: KernelAuditContext, target: str) -> List[str]:
    profile = target_profile(target)
    roots = target_scan_roots(target)
    if str(profile.get("shard_source", "") or "") == "compiled":
        compiled = compiled_source_inventory(ctx, roots=roots)
        return sorted({compiled_source_to_shard(path) for path in compiled})

    shards: List[str] = []
    for root_text in roots:
        root = ctx.repo_root / root_text
        if root.is_file():
            shards.append(str(root.relative_to(ctx.repo_root)))
            continue
        if not root.exists():
            continue

        for entry in sorted(root.iterdir()):
            if entry.name.startswith("."):
                continue
            if entry.is_dir():
                shards.append(str(entry.relative_to(ctx.repo_root)))
            elif entry.suffix == ".c":
                shards.append(str(entry.relative_to(ctx.repo_root)))
    return sorted(set(shards))


def select_next_shards(ctx: KernelAuditContext, target: str, limit: int) -> List[str]:
    shards = enumerate_target_shards(ctx, target)
    shard_state = load_shards_state(ctx)
    items = shard_state.setdefault("items", {})

    def sort_key(shard: str) -> Tuple[int, str, int, str]:
        info = items.get(shard, {}) if isinstance(items.get(shard), dict) else {}
        last = str(info.get("last_audited_at", "") or "")
        attempts = as_int(info.get("attempts", 0), 0)
        return (1 if last else 0, last, attempts, shard)

    selected = sorted(shards, key=sort_key)[: max(limit, 1)]
    return selected


def shard_matches_path(shard: str, path: str) -> bool:
    shard = shard.rstrip("/")
    if shard.endswith(".c"):
        return path == shard
    return path == shard or path.startswith(shard + "/")


def filter_seed_hits_for_shard(seed_hits: Sequence[Dict[str, Any]], shard: str) -> List[Dict[str, Any]]:
    return [hit for hit in seed_hits if shard_matches_path(shard, str(hit.get("path", "")))]


def run_codex_worker_json(
    ctx: KernelAuditContext,
    prompt_name: str,
    schema_name: str,
    payload: Dict[str, Any],
    *,
    label: str,
    stage: str,
    model: str,
    reasoning_effort: str,
    timeout: int,
    sandbox: str = "read-only",
    case_id: Optional[str] = None,
) -> Dict[str, Any]:
    prompt_path = ctx.prompt_path(prompt_name)
    schema_path = ctx.template_path(schema_name)
    if not prompt_path.exists():
        raise RuntimeError(f"missing worker prompt: {prompt_path}")
    if not schema_path.exists():
        raise RuntimeError(f"missing worker schema: {schema_path}")

    prompt_body = prompt_path.read_text(encoding="utf-8").strip()
    full_prompt = (
        prompt_body
        + "\n\n## Task Context\n```json\n"
        + json.dumps(payload, indent=2, sort_keys=True)
        + "\n```\n"
    )

    output_root = ctx.logs_dir if not case_id else (ctx.case_dir(case_id) / "workers")
    output_root.mkdir(parents=True, exist_ok=True)
    stamp = utc_stamp()
    stem = f"{stage}-{safe_slug(label)}-{stamp}"
    output_path = output_root / f"{stem}.json"
    prompt_dump = output_root / f"{stem}.prompt.txt"
    prompt_dump.write_text(full_prompt, encoding="utf-8")

    cmd = [
        "codex",
        "exec",
        "-C",
        str(ctx.repo_root),
        "--sandbox",
        sandbox,
        "--color",
        "never",
        "--output-schema",
        str(schema_path),
        "-o",
        str(output_path),
        "-c",
        f'model_reasoning_effort="{reasoning_effort}"',
    ]
    if model:
        cmd.extend(["--model", model])
    cmd.append("-")

    last_error = ""
    for attempt in range(1, CODEX_WORKER_RETRIES_DEFAULT + 1):
        if output_path.exists():
            output_path.unlink()
        try:
            result = run_cmd(cmd, cwd=ctx.repo_root, check=False, input_text=full_prompt, timeout=timeout)
        except subprocess.TimeoutExpired:
            partial = output_path.read_text(encoding="utf-8", errors="replace") if output_path.exists() else ""
            last_error = (partial.strip() or f"timed out after {timeout} seconds")[-1200:]
            if attempt < CODEX_WORKER_RETRIES_DEFAULT:
                print(f"[kaudit] worker retry {attempt}/{CODEX_WORKER_RETRIES_DEFAULT - 1} for {stage}:{label}")
                time.sleep(min(5 * attempt, 15))
                continue
            raise RuntimeError(f"codex worker timed out ({stage}/{label}) after {timeout} seconds")
        raw = output_path.read_text(encoding="utf-8", errors="replace") if output_path.exists() else result.stdout
        parsed = parse_json_output_loose(raw)
        if result.returncode == 0 and parsed is not None:
            return parsed

        last_error = result.stdout.strip()[-1200:]
        if parsed is None and raw.strip():
            last_error = raw.strip()[-1200:]
        if attempt < CODEX_WORKER_RETRIES_DEFAULT:
            print(f"[kaudit] worker retry {attempt}/{CODEX_WORKER_RETRIES_DEFAULT - 1} for {stage}:{label}")
            time.sleep(min(5 * attempt, 15))

    raise RuntimeError(f"codex worker failed ({stage}/{label}): {last_error}")


def normalize_worker_candidate(
    ctx: KernelAuditContext,
    raw: Dict[str, Any],
    shard: str,
) -> Optional[Dict[str, Any]]:
    path = str(raw.get("path", "") or "").strip().lstrip("./")
    if not path:
        return None
    abs_path = ctx.repo_root / path
    if not abs_path.exists() or abs_path.suffix != ".c":
        return None

    line = max(1, as_int(raw.get("line", 1), 1))
    function = str(raw.get("function", "") or "").strip() or enclosing_function(abs_path, line)
    kind = str(raw.get("vuln_class", raw.get("kind", "generic")) or "generic").strip()
    confidence = max(0.0, min(1.0, as_float(raw.get("confidence", 0.0), 0.0)))
    root_cause_summary = str(raw.get("root_cause_summary", "") or "").strip()
    proof_outline = str(raw.get("proof_outline", "") or "").strip()
    novelty = str(raw.get("novelty_analysis", "") or "").strip()
    entry_surface = str(raw.get("entry_surface", "") or "").strip()
    attacker_control = str(raw.get("attacker_control", "") or "").strip()
    repro_feasibility = str(raw.get("repro_feasibility", "") or "").strip()
    required_config = merge_required_config(as_str_list(raw.get("required_config", [])))
    if not root_cause_summary or not proof_outline or confidence < 0.60:
        return None

    return {
        "path": path,
        "line": line,
        "snippet": root_cause_summary,
        "kind": kind,
        "score": max(1, int(round(confidence * 10))),
        "function": function,
        "confidence": confidence,
        "entry_surface": entry_surface,
        "attacker_control": attacker_control,
        "proof_outline": proof_outline,
        "novelty_analysis": novelty,
        "repro_feasibility": repro_feasibility,
        "required_config": required_config,
        "shard": shard,
        "worker_summary": str(raw.get("worker_summary", "") or "").strip(),
    }


def create_case_from_candidate(
    ctx: KernelAuditContext,
    candidate: Dict[str, Any],
    sim_score: float,
    sim_ref: Optional[Dict[str, Any]],
    sim_details: Dict[str, float],
) -> Dict[str, Any]:
    case_id = make_case_id()
    case = deep_copy_json(CASE_TEMPLATE)
    case["case_id"] = case_id
    case["created_at"] = utc_now_iso()
    case["stage"] = "discovered"
    case["target_paths"] = [candidate["path"]]
    case["suspect_functions"] = [candidate["function"]]
    case["parameter_assumptions"] = [
        "Audit caller-controlled parameters and exact syscall/mount/ioctl entry surfaces.",
        "Re-check object lifetime transitions around free/error/RCU/refcount paths.",
    ]
    case["known_vuln_similarity"] = {
        "max_score": round(sim_score, 4),
        "best_match": sim_ref.get("id") if sim_ref else None,
        "source": sim_ref.get("source") if sim_ref else None,
        "components": {k: round(float(v), 4) for k, v in sim_details.items()},
        "weights": SIMILARITY_WEIGHTS,
        "method": "weighted(token_jaccard + function_overlap + path_overlap + weakness_match)",
    }
    case["config_fragments"] = list(ctx.default_fragments())
    case["required_config"] = merge_required_config(
        [
            "CONFIG_KASAN=y",
            "CONFIG_KASAN_GENERIC=y",
            "CONFIG_KASAN_MULTI_SHOT=y",
            "CONFIG_DEBUG_KERNEL=y",
            "CONFIG_FRAME_POINTER=y",
        ],
        candidate.get("required_config", []),
    )
    case["root_cause"] = (
        str(candidate.get("snippet", "")).strip()
        or f"Hypothesis: {candidate['kind']} weakness near {candidate['path']}:{candidate['line']} inside {candidate['function']}()."
    )
    case["impact"] = "Pending verifier confirmation."
    case["attack_scenario"] = "Pending verifier confirmation."
    case["analysis"] = {
        "candidate": candidate,
        "signature": candidate_signature(candidate),
    }
    case["discovery"] = {
        "prompt_version": "v2",
        "worker_summary": str(candidate.get("worker_summary", "") or ""),
        "confidence": round(as_float(candidate.get("confidence", 0.0), 0.0), 4),
        "entry_surface": str(candidate.get("entry_surface", "") or ""),
        "attacker_control": str(candidate.get("attacker_control", "") or ""),
        "proof_outline": str(candidate.get("proof_outline", "") or ""),
        "novelty_analysis": str(candidate.get("novelty_analysis", "") or ""),
        "repro_feasibility": str(candidate.get("repro_feasibility", "") or ""),
        "shard": str(candidate.get("shard", "") or ""),
    }
    case["trigger"] = {
        "description": "Auto-generated during repro stage unless manually overridden.",
        "command": "",
        "source_c": "",
        "run_script": "",
    }
    sync_case_status(case)
    return case


def save_case(ctx: KernelAuditContext, case: Dict[str, Any]) -> None:
    case = normalize_case(case)
    case_id = case["case_id"]
    case_dir = ctx.case_dir(case_id)
    case_dir.mkdir(parents=True, exist_ok=True)
    write_json(ctx.case_json_path(case_id), case)

    note = textwrap.dedent(
        f"""
        # {case_id}

        - created_at: {case.get('created_at')}
        - stage: {case.get('stage')}
        - status: {case.get('status')}
        - target: {', '.join(case.get('target_paths', []))}
        - suspect_functions: {', '.join(case.get('suspect_functions', []))}
        - root_cause_hypothesis: {case.get('root_cause', '').strip()}
        - verifier_verdict: {case.get('verification', {}).get('verdict', 'pending')}
        - kasan_detected: {case.get('kasan_detected')}
        """
    ).strip()
    operator_notes = case.get("operator_notes", []) if isinstance(case.get("operator_notes"), list) else []
    operator_actions = case.get("operator_actions", []) if isinstance(case.get("operator_actions"), list) else []
    if operator_notes:
        note += "\n\n## Operator Notes\n"
        for item in operator_notes[-10:]:
            if not isinstance(item, dict):
                continue
            ts = str(item.get("timestamp", "") or "")
            author = str(item.get("author", "") or "operator")
            message = str(item.get("message", "") or "").strip()
            if message:
                note += f"- [{ts}] {author}: {message}\n"
    if operator_actions:
        note += "\n## Operator Actions\n"
        for item in operator_actions[-10:]:
            if not isinstance(item, dict):
                continue
            ts = str(item.get("timestamp", "") or "")
            action = str(item.get("action", "") or "unknown")
            details = str(item.get("details", "") or "").strip()
            if details:
                note += f"- [{ts}] {action}: {details}\n"
            else:
                note += f"- [{ts}] {action}\n"
    note += "\n"
    (case_dir / "notes.md").write_text(note, encoding="utf-8")


def discover_cases_once(
    ctx: KernelAuditContext,
    *,
    target: str,
    similarity_threshold: float,
    audit_workers: int,
    worker_model: str,
    worker_reasoning_effort: str,
    worker_timeout: int,
) -> List[str]:
    ensure_default_files(ctx)
    campaign = ctx.load_campaign()
    if not ctx.syzbot_path.exists() or not ctx.cve_path.exists():
        print("[kaudit] knowledge cache missing; refreshing first")
        rc = cmd_knowledge_refresh(ctx, argparse.Namespace())
        if rc != 0:
            raise RuntimeError("knowledge refresh failed")

    seed_hits = scan_pattern_hits(ctx, target_dir=target)
    known = load_known_signatures(ctx)
    seen = set(campaign.get("seen_locations", []))
    fingerprints = collect_case_fingerprints(ctx)
    rejected = 0
    created_case_ids: List[str] = []
    shard_state = load_shards_state(ctx)
    shard_items = shard_state.setdefault("items", {})

    selected_shards = select_next_shards(ctx, target, audit_workers)
    if not selected_shards:
        campaign["last_cycle_at"] = utc_now_iso()
        refresh_campaign_metrics(ctx, campaign)
        ctx.save_campaign(campaign)
        print(f"[kaudit] cycle complete: no shards found under {target}")
        return []

    payloads: List[Tuple[str, Dict[str, Any]]] = []
    knowledge_snapshot = read_json(ctx.knowledge_snapshot_path, {})
    for shard in selected_shards:
        payloads.append(
            (
                shard,
                {
                    "pipeline_version": PIPELINE_VERSION,
                    "repo_root": str(ctx.repo_root),
                    "kernel_head": campaign.get("kernel_head"),
                    "target": target,
                    "shard": shard,
                    "knowledge_paths": {
                        "snapshot": str(ctx.knowledge_snapshot_path),
                        "syzbot": str(ctx.syzbot_path),
                        "cve": str(ctx.cve_path),
                    },
                    "knowledge_summary": knowledge_snapshot,
                    "seed_hits": filter_seed_hits_for_shard(seed_hits, shard)[:12],
                },
            )
        )

    def worker_job(item: Tuple[str, Dict[str, Any]]) -> Tuple[str, Dict[str, Any]]:
        shard, payload = item
        result = run_codex_worker_json(
            ctx,
            ctx.prompt_name("discovery"),
            DISCOVERY_SCHEMA_NAME,
            payload,
            label=shard,
            stage="discovery",
            model=worker_model,
            reasoning_effort=worker_reasoning_effort,
            timeout=worker_timeout,
        )
        return shard, result

    with concurrent.futures.ThreadPoolExecutor(max_workers=max(1, audit_workers)) as pool:
        futures = {pool.submit(worker_job, item): item[0] for item in payloads}
        for future in concurrent.futures.as_completed(futures):
            shard = futures[future]
            now = utc_now_iso()
            info = shard_items.setdefault(shard, {})
            info["last_audited_at"] = now
            info["attempts"] = as_int(info.get("attempts", 0), 0) + 1
            try:
                _shard, result = future.result()
            except Exception as exc:
                info["last_error"] = str(exc)
                print(f"[kaudit] discovery worker failed for {shard}: {exc}")
                continue

            info["last_error"] = ""
            info["last_worker_status"] = str(result.get("summary", "") or "")
            raw_candidates = result.get("candidates", [])
            if not isinstance(raw_candidates, list):
                raw_candidates = []

            for raw_candidate in raw_candidates[:3]:
                if not isinstance(raw_candidate, dict):
                    continue
                duplicate = bool(raw_candidate.get("is_duplicate", False))
                normalized = normalize_worker_candidate(ctx, raw_candidate, shard)
                if duplicate or normalized is None:
                    continue

                loc = case_location_key(normalized)
                fp = case_fingerprint(normalized["path"], normalized["function"], normalized["kind"])
                if loc in seen or fp in fingerprints:
                    continue

                cand_sig = candidate_signature(normalized)
                score, ref, details = best_known_similarity(cand_sig, known)
                seen.add(loc)
                if score >= similarity_threshold:
                    rejected += 1
                    continue

                case = create_case_from_candidate(ctx, normalized, score, ref, details)
                save_case(ctx, case)
                info["last_case_id"] = case["case_id"]
                fingerprints.add(fp)
                created_case_ids.append(case["case_id"])
                campaign["last_case_id"] = case["case_id"]
                campaign["next_targets"] = [normalized["path"]]

                print(f"[kaudit] new candidate case: {case['case_id']}")
                print(f"[kaudit] candidate: {normalized['path']}:{normalized['line']} ({normalized['kind']})")
                if ref:
                    print(
                        f"[kaudit] uniqueness gate: best known={ref.get('source')}:{ref.get('id')} score={score:.4f} (< {similarity_threshold})"
                    )
                else:
                    print(f"[kaudit] uniqueness gate: no known match (score={score:.4f})")
                print(f"[kaudit] case path: {ctx.case_json_path(case['case_id'])}")

    campaign["seen_locations"] = sorted(seen)
    campaign["rejected_as_known"] = int(campaign.get("rejected_as_known", 0)) + rejected
    campaign["last_cycle_at"] = utc_now_iso()
    refresh_campaign_metrics(ctx, campaign)
    ctx.save_campaign(campaign)
    save_shards_state(ctx, shard_state)
    return created_case_ids


def run_single_cycle(
    ctx: KernelAuditContext,
    similarity_threshold: float,
    target: str,
    args: Optional[argparse.Namespace] = None,
) -> Optional[str]:
    ensure_default_files(ctx)
    if args is None:
        args = argparse.Namespace(
            audit_workers=DEFAULT_AUDIT_WORKERS,
            verify_workers=DEFAULT_VERIFY_WORKERS,
            repro_workers=DEFAULT_REPRO_WORKERS,
            report_workers=DEFAULT_REPORT_WORKERS,
            worker_model="",
            worker_reasoning_effort=CODEX_WORKER_REASONING_DEFAULT,
            worker_timeout=CODEX_WORKER_TIMEOUT_DEFAULT,
            auto_verify=True,
            auto_repro=True,
            auto_report=True,
            repro_timeout=240,
            repro_attempts=3,
            rootfs_mode="auto",
            debian_suite="bookworm",
            debian_mirror="http://deb.debian.org/debian",
            debian_include="busybox,ca-certificates",
            debian_force_cache=False,
            jobs=0,
            backlog_only=False,
            oldest_first=False,
        )

    backlog_only = bool(getattr(args, "backlog_only", False))
    oldest_first = bool(getattr(args, "oldest_first", False))
    audit_workers = max(1, as_int(getattr(args, "audit_workers", DEFAULT_AUDIT_WORKERS), DEFAULT_AUDIT_WORKERS))
    if not backlog_only:
        ensure_discovery_target_ready(
            ctx,
            target=target,
            jobs=max(0, as_int(getattr(args, "jobs", 0), 0)),
        )
    selected_audit_queue = [] if backlog_only else select_next_shards(ctx, target, audit_workers)
    completed_jobs: List[Dict[str, Any]] = []

    created_case_ids: List[str] = []
    if backlog_only:
        completed_jobs.append(
            pipeline_job_record(
                "discovery",
                target,
                "skipped",
                details={"target": target, "reason": "backlog_only"},
            )
        )
    else:
        set_pipeline_active_jobs(
            ctx,
            [
                pipeline_job_record(
                    "discovery",
                    target,
                    "running",
                    details={"target": target, "shards": selected_audit_queue, "workers": audit_workers},
                )
            ],
        )
        try:
            created_case_ids = discover_cases_once(
                ctx,
                target=target,
                similarity_threshold=similarity_threshold,
                audit_workers=audit_workers,
                worker_model=str(getattr(args, "worker_model", "") or ""),
                worker_reasoning_effort=str(
                    getattr(args, "worker_reasoning_effort", CODEX_WORKER_REASONING_DEFAULT)
                    or CODEX_WORKER_REASONING_DEFAULT
                ),
                worker_timeout=max(
                    120,
                    as_int(getattr(args, "worker_timeout", CODEX_WORKER_TIMEOUT_DEFAULT), CODEX_WORKER_TIMEOUT_DEFAULT),
                ),
            )
            completed_jobs.append(
                pipeline_job_record(
                    "discovery",
                    target,
                    "completed",
                    details={
                        "target": target,
                        "shards": selected_audit_queue,
                        "created_cases": created_case_ids,
                        "count": len(created_case_ids),
                    },
                )
            )
        except Exception as exc:
            completed_jobs.append(
                pipeline_job_record(
                    "discovery",
                    target,
                    "failed",
                    details={"target": target, "shards": selected_audit_queue, "error": str(exc)},
                )
            )
            append_pipeline_completed_jobs(ctx, completed_jobs)
            set_pipeline_active_jobs(ctx, [])
            raise
        set_pipeline_active_jobs(ctx, [])

    verified_case_ids: List[str] = []
    confirmed_case_ids: List[str] = []
    reported_case_ids: List[str] = []

    if bool(getattr(args, "auto_verify", True)):
        verify_limit = max(1, as_int(getattr(args, "verify_workers", DEFAULT_VERIFY_WORKERS), DEFAULT_VERIFY_WORKERS))
        verify_candidates = sorted(
            collect_cases_by_stage(ctx, {"discovered"}),
            key=lambda item: str(item.get("created_at", "")),
            reverse=not oldest_first,
        )[:verify_limit]
        set_pipeline_active_jobs(
            ctx,
            [
                pipeline_job_record(
                    "verify",
                    "verify-batch",
                    "running",
                    details={"case_ids": [case["case_id"] for case in verify_candidates], "workers": verify_limit},
                )
            ],
        )
        try:
            verified_case_ids = run_verify_batch(ctx, args)
            completed_jobs.append(
                pipeline_job_record(
                    "verify",
                    "verify-batch",
                    "completed",
                    details={"case_ids": verified_case_ids, "count": len(verified_case_ids)},
                )
            )
        except Exception as exc:
            completed_jobs.append(
                pipeline_job_record(
                    "verify",
                    "verify-batch",
                    "failed",
                    details={"error": str(exc), "case_ids": [case["case_id"] for case in verify_candidates]},
                )
            )
            append_pipeline_completed_jobs(ctx, completed_jobs)
            set_pipeline_active_jobs(ctx, [])
            raise
        set_pipeline_active_jobs(ctx, [])
    if bool(getattr(args, "auto_repro", True)):
        repro_limit = max(1, as_int(getattr(args, "repro_workers", DEFAULT_REPRO_WORKERS), DEFAULT_REPRO_WORKERS))
        repro_candidates, skipped_repro_config = select_repro_batch_cases(ctx, args, repro_limit)
        set_pipeline_active_jobs(
            ctx,
            [
                pipeline_job_record(
                    "repro",
                    "repro-batch",
                    "running",
                    details={
                        "case_ids": [case["case_id"] for case in repro_candidates],
                        "workers": repro_limit,
                        "skipped_missing_config": [
                            {"case_id": case_id, "missing": missing} for case_id, missing in skipped_repro_config
                        ],
                    },
                )
            ],
        )
        try:
            confirmed_case_ids = run_repro_batch(ctx, args)
            completed_jobs.append(
                pipeline_job_record(
                    "repro",
                    "repro-batch",
                    "completed",
                    details={"confirmed_case_ids": confirmed_case_ids, "count": len(confirmed_case_ids)},
                )
            )
        except Exception as exc:
            completed_jobs.append(
                pipeline_job_record(
                    "repro",
                    "repro-batch",
                    "failed",
                    details={"error": str(exc), "case_ids": [case["case_id"] for case in repro_candidates]},
                )
            )
            append_pipeline_completed_jobs(ctx, completed_jobs)
            set_pipeline_active_jobs(ctx, [])
            raise
        set_pipeline_active_jobs(ctx, [])
    if bool(getattr(args, "auto_report", True)):
        report_limit = max(1, as_int(getattr(args, "report_workers", DEFAULT_REPORT_WORKERS), DEFAULT_REPORT_WORKERS))
        report_candidates = sorted(
            collect_cases_by_stage(ctx, {"confirmed"}),
            key=lambda item: str(item.get("last_repro_at", item.get("created_at", ""))),
            reverse=not oldest_first,
        )[:report_limit]
        set_pipeline_active_jobs(
            ctx,
            [
                pipeline_job_record(
                    "report",
                    "report-batch",
                    "running",
                    details={"case_ids": [case["case_id"] for case in report_candidates], "workers": report_limit},
                )
            ],
        )
        try:
            reported_case_ids = run_report_batch(ctx, args)
            completed_jobs.append(
                pipeline_job_record(
                    "report",
                    "report-batch",
                    "completed",
                    details={"reported_case_ids": reported_case_ids, "count": len(reported_case_ids)},
                )
            )
        except Exception as exc:
            completed_jobs.append(
                pipeline_job_record(
                    "report",
                    "report-batch",
                    "failed",
                    details={"error": str(exc), "case_ids": [case["case_id"] for case in report_candidates]},
                )
            )
            append_pipeline_completed_jobs(ctx, completed_jobs)
            set_pipeline_active_jobs(ctx, [])
            raise
        set_pipeline_active_jobs(ctx, [])

    update_pipeline_snapshot(
        ctx,
        target=target,
        audit_queue=[] if backlog_only else select_next_shards(ctx, target, audit_workers),
        active_jobs=[],
        completed_jobs=completed_jobs,
    )

    first_case_id = (
        (created_case_ids or verified_case_ids or confirmed_case_ids or reported_case_ids or [None])[0]
    )
    if not first_case_id:
        print("[kaudit] cycle complete: no novel candidate found")
    return first_case_id
def team_ready(ctx: KernelAuditContext) -> Tuple[bool, str]:
    if not shutil.which("omx"):
        return False, "omx binary not found"
    if not shutil.which("tmux"):
        return False, "tmux binary not found"
    if not os.environ.get("TMUX"):
        return False, "not inside tmux session"
    doctor = run_cmd(["omx", "doctor", "--team"], cwd=ctx.repo_root, check=False)
    if doctor.returncode != 0:
        recovered, note = try_recover_stale_team(ctx)
        if recovered:
            print(f"[kaudit] recovered stale team state: {note}")
            doctor = run_cmd(["omx", "doctor", "--team"], cwd=ctx.repo_root, check=False)
    if doctor.returncode != 0:
        msg = doctor.stdout.strip().splitlines()[-1] if doctor.stdout.strip() else "omx doctor --team failed"
        return False, msg
    return True, "ok"


def read_active_team_name(ctx: KernelAuditContext) -> Optional[str]:
    state_path = ctx.repo_root / ".omx" / "state" / "team-state.json"
    obj = read_json(state_path, {})
    if not isinstance(obj, dict):
        return None
    if obj.get("active") is not True:
        return None
    team_name = str(obj.get("team_name", "")).strip()
    return team_name or None


def deactivate_team_state(ctx: KernelAuditContext, expected_team_name: Optional[str], phase: str) -> bool:
    state_path = ctx.repo_root / ".omx" / "state" / "team-state.json"
    obj = read_json(state_path, {})
    if not isinstance(obj, dict):
        return False
    current_team = str(obj.get("team_name", "")).strip()
    if expected_team_name and current_team and current_team != expected_team_name:
        return False

    changed = False
    if obj.get("active") is not False:
        obj["active"] = False
        changed = True
    if phase and str(obj.get("current_phase", "")).strip() != phase:
        obj["current_phase"] = phase
        changed = True
    obj["completed_at"] = utc_now_iso()
    changed = True
    if changed:
        write_json(state_path, obj)
    return changed


def scrub_team_nudge_state(ctx: KernelAuditContext, expected_team_name: Optional[str]) -> bool:
    if not expected_team_name:
        return False
    nudge_path = ctx.repo_root / ".omx" / "state" / "team-leader-nudge.json"
    obj = read_json(nudge_path, {})
    if not isinstance(obj, dict):
        return False
    changed = False
    for key in ("last_nudged_by_team", "last_idle_nudged_by_team"):
        bucket = obj.get(key)
        if isinstance(bucket, dict) and expected_team_name in bucket:
            del bucket[expected_team_name]
            changed = True
    if changed:
        write_json(nudge_path, obj)
    return changed


def cleanup_team_runtime(
    ctx: KernelAuditContext,
    expected_team_name: Optional[str],
    *,
    phase: str,
    aggressive: bool,
) -> str:
    notes: List[str] = []
    team_names: List[str] = []
    if expected_team_name:
        team_names.append(expected_team_name)
    elif aggressive:
        team_names.extend(list_lingering_team_names(ctx))

    for team_name in team_names:
        try:
            shutdown = run_cmd(["omx", "team", "shutdown", team_name, "--force"], cwd=ctx.repo_root, check=False)
            notes.append(f"{team_name}:shutdown={shutdown.returncode}")
        except Exception as exc:
            notes.append(f"{team_name}:shutdown_error={exc}")
        try:
            cleanup = team_api_call(ctx, "cleanup", {"team_name": team_name})
            notes.append(f"{team_name}:api_cleanup={bool(cleanup and cleanup.get('ok') is True)}")
        except Exception as exc:
            notes.append(f"{team_name}:api_cleanup_error={exc}")
    if aggressive:
        try:
            cancel = run_cmd(["omx", "cancel"], cwd=ctx.repo_root, check=False)
            notes.append(f"cancel={cancel.returncode}")
        except Exception as exc:
            notes.append(f"cancel_error={exc}")
    try:
        if deactivate_team_state(ctx, expected_team_name, phase):
            notes.append("team_state=deactivated")
    except Exception as exc:
        notes.append(f"team_state_error={exc}")
    for team_name in team_names or [expected_team_name]:
        try:
            if scrub_team_nudge_state(ctx, team_name):
                notes.append(f"{team_name}:nudge_state=scrubbed")
        except Exception as exc:
            notes.append(f"{team_name}:nudge_state_error={exc}")
    return " ".join(notes)


def list_lingering_team_names(ctx: KernelAuditContext) -> List[str]:
    names: List[str] = []
    active = read_active_team_name(ctx)
    if active:
        names.append(active)

    team_root = ctx.repo_root / ".omx" / "state" / "team"
    if team_root.exists():
        for entry in sorted(team_root.iterdir()):
            if not entry.is_dir():
                continue
            name = entry.name.strip()
            if not name or name in names:
                continue
            names.append(name)
    return names


def parse_team_workers(status_output: str) -> Tuple[Optional[int], Optional[int]]:
    m = re.search(r"workers:\s+total=(\d+)\s+dead=(\d+)\s+non_reporting=(\d+)", status_output)
    if not m:
        return None, None
    return int(m.group(1)), int(m.group(2))


def try_recover_stale_team(ctx: KernelAuditContext) -> Tuple[bool, str]:
    candidates = list_lingering_team_names(ctx)
    if not candidates:
        return False, "no active or lingering team-state"

    recovered: List[str] = []
    still_alive: List[str] = []
    for team_name in candidates:
        st = run_cmd(["omx", "team", "status", team_name], cwd=ctx.repo_root, check=False)
        should_cleanup = st.returncode != 0
        if st.returncode == 0:
            total, dead = parse_team_workers(st.stdout)
            pending = 0
            in_progress = 0
            blocked = 0
            parsed = parse_team_status(st.stdout)
            if parsed:
                pending = int(parsed.get("pending", 0))
                in_progress = int(parsed.get("in_progress", 0))
                blocked = int(parsed.get("blocked", 0))
            if total is not None and dead is not None and total > 0 and dead >= total:
                should_cleanup = True
            elif pending > 0 and in_progress == 0 and blocked == 0:
                should_cleanup = True

        if should_cleanup:
            note = cleanup_team_runtime(ctx, team_name, phase="cancelled", aggressive=True)
            recovered.append(f"{team_name}: {note or 'cleanup attempted'}")
        else:
            still_alive.append(team_name)

    if recovered:
        return True, "; ".join(recovered)
    if still_alive:
        return False, f"team(s) still appear alive: {', '.join(still_alive)}"
    return False, "no stale team to recover"


def parse_team_name(start_output: str) -> Optional[str]:
    m = re.search(r"Team started:\s*([A-Za-z0-9._-]+)", start_output)
    if not m:
        return None
    return m.group(1).strip()


def parse_team_status(status_output: str) -> Dict[str, Any]:
    out: Dict[str, Any] = {}
    phase_match = re.search(r"phase=([A-Za-z0-9_-]+)", status_output)
    if phase_match:
        out["phase"] = phase_match.group(1)

    task_match = re.search(
        r"tasks:\s+total=(\d+)\s+pending=(\d+)\s+blocked=(\d+)\s+in_progress=(\d+)\s+completed=(\d+)\s+failed=(\d+)",
        status_output,
    )
    if task_match:
        out["total"] = int(task_match.group(1))
        out["pending"] = int(task_match.group(2))
        out["blocked"] = int(task_match.group(3))
        out["in_progress"] = int(task_match.group(4))
        out["completed"] = int(task_match.group(5))
        out["failed"] = int(task_match.group(6))
    return out


def team_api_call(
    ctx: KernelAuditContext,
    operation: str,
    payload: Dict[str, Any],
    *,
    env: Optional[Dict[str, str]] = None,
) -> Optional[Dict[str, Any]]:
    cmd = ["omx", "team", "api", operation, "--input", json.dumps(payload), "--json"]
    res = run_cmd(cmd, cwd=ctx.repo_root, check=False, env=env)
    if res.returncode != 0:
        return None
    return parse_json_output(res.stdout)


def team_event_query_available(ctx: KernelAuditContext) -> bool:
    return bool(omx_local_info(ctx.repo_root).get("team_api_event_query_available"))


def team_await_event_via_api(
    ctx: KernelAuditContext,
    team_name: str,
    after_event_id: Optional[str],
    timeout_ms: int,
    *,
    poll_ms: int = 1000,
) -> Optional[Dict[str, Any]]:
    payload: Dict[str, Any] = {
        "team_name": team_name,
        "timeout_ms": max(0, int(timeout_ms)),
        "poll_ms": max(50, int(poll_ms)),
    }
    if after_event_id:
        payload["after_event_id"] = after_event_id
    data = team_api_call(ctx, "await-event", payload)
    if not data or data.get("ok") is not True:
        return None
    body = data.get("data", {})
    if not isinstance(body, dict):
        return None
    return {
        "status": str(body.get("status", "") or ""),
        "cursor": str(body.get("cursor", "") or ""),
        "event": body.get("event"),
    }


def team_summary_via_api(ctx: KernelAuditContext, team_name: str) -> Optional[Dict[str, Any]]:
    payload = {"team_name": team_name}
    data = team_api_call(ctx, "get-summary", payload)
    if not data or data.get("ok") is not True:
        return None
    summary = data.get("data", {}).get("summary")
    if not isinstance(summary, dict):
        return None
    tasks = summary.get("tasks", {}) if isinstance(summary.get("tasks"), dict) else {}
    workers = summary.get("workers", []) if isinstance(summary.get("workers"), list) else []
    dead_workers = 0
    for worker in workers:
        if isinstance(worker, dict) and worker.get("alive") is False:
            dead_workers += 1
    return {
        "source": "team-api",
        "team_name": summary.get("teamName", team_name),
        "worker_count": int(summary.get("workerCount", len(workers)) or len(workers)),
        "dead_workers": dead_workers,
        "non_reporting": len(summary.get("nonReportingWorkers", []) or []),
        "pending": int(tasks.get("pending", 0) or 0),
        "blocked": int(tasks.get("blocked", 0) or 0),
        "in_progress": int(tasks.get("in_progress", 0) or 0),
        "completed": int(tasks.get("completed", 0) or 0),
        "failed": int(tasks.get("failed", 0) or 0),
        "total": int(tasks.get("total", 0) or 0),
    }


def build_team_worker_launch_args(
    existing_raw: str,
    team_model: str,
    reasoning_effort: str,
) -> str:
    tokens = split_shell_args(existing_raw)

    if team_model.strip() and not has_cli_flag(tokens, "--model"):
        tokens.extend(["--model", team_model.strip()])
    if reasoning_effort.strip() and not has_reasoning_override(tokens):
        tokens.extend(["-c", f'model_reasoning_effort="{reasoning_effort.strip()}"'])
    # OMX upstream parses OMX_TEAM_WORKER_LAUNCH_ARGS with a whitespace split,
    # not a shell lexer. Return a plain token stream so config overrides like
    # model_reasoning_effort="xhigh" survive without extra quote characters.
    return " ".join(tokens)


def normalize_custom_notify_selector(raw: str) -> Optional[str]:
    text = str(raw or "").strip().lower()
    if not text:
        return None
    if text.startswith("openclaw:"):
        gateway = text.split(":", 1)[1].strip()
        return f"openclaw:{gateway}" if gateway else None
    return f"custom:{text}"


def parse_team_omx_global_args(raw: str) -> Dict[str, Any]:
    tokens = split_shell_args(raw)
    team_subcommand_args: List[str] = []
    selectors: List[str] = []
    warnings: List[str] = []
    cli_notify = False
    spark = False
    reasoning_effort = ""

    idx = 0
    while idx < len(tokens):
        token = tokens[idx]
        if token == "--notify-temp":
            cli_notify = True
            idx += 1
            continue
        if token in {"--discord", "--slack", "--telegram"}:
            selectors.append(token[2:])
            idx += 1
            continue
        if token == "--custom":
            nxt = tokens[idx + 1] if idx + 1 < len(tokens) else ""
            normalized = normalize_custom_notify_selector(nxt)
            if normalized:
                selectors.append(normalized)
                idx += 2
                continue
            warnings.append("notify temp: ignoring --custom without a valid selector")
            idx += 1
            continue
        if token.startswith("--custom="):
            normalized = normalize_custom_notify_selector(token.split("=", 1)[1])
            if normalized:
                selectors.append(normalized)
            else:
                warnings.append(f"notify temp: ignoring invalid --custom selector {token.split('=', 1)[1]!r}")
            idx += 1
            continue
        if token == "--spark":
            spark = True
            idx += 1
            continue
        if token == "--high":
            reasoning_effort = "high"
            idx += 1
            continue
        if token == "--xhigh":
            reasoning_effort = "xhigh"
            idx += 1
            continue
        if token in {"-w", "--worktree"}:
            team_subcommand_args.append(token)
            if idx + 1 < len(tokens) and not tokens[idx + 1].startswith("-"):
                team_subcommand_args.append(tokens[idx + 1])
                idx += 2
                continue
            idx += 1
            continue
        if token.startswith("--worktree="):
            team_subcommand_args.append(token)
            idx += 1
            continue
        raise RuntimeError(
            "unsupported token in --team-omx-global-args: "
            f"{token!r} (supported: --notify-temp, --discord/--slack/--telegram, "
            "--custom, --spark, --high/--xhigh, -w/--worktree)"
        )

    canonical_selectors = list(dict.fromkeys(selectors))
    notify_contract = None
    if cli_notify or canonical_selectors:
        if canonical_selectors and not cli_notify:
            warnings.append("notify temp: provider selectors imply temp mode (auto-activated)")
        notify_contract = {
            "active": True,
            "selectors": selectors,
            "canonicalSelectors": canonical_selectors,
            "warnings": warnings,
            "source": "cli" if cli_notify else "providers",
        }

    return {
        "team_subcommand_args": team_subcommand_args,
        "notify_contract": notify_contract,
        "spark": spark,
        "reasoning_effort": reasoning_effort,
    }


def build_omx_team_start_command(args: argparse.Namespace, task: str, global_opts: Dict[str, Any]) -> List[str]:
    cmd = ["omx", "team"]
    cmd.extend(global_opts.get("team_subcommand_args", []))
    cmd.extend([f"{max(int(args.team_workers), 1)}:{str(args.team_agent_type)}", task])
    return cmd


def build_team_env(args: argparse.Namespace, global_opts: Dict[str, Any]) -> Dict[str, str]:
    env = os.environ.copy()
    team_model = str(getattr(args, "team_model", "") or "")
    if not team_model and bool(global_opts.get("spark")):
        team_model = OMX_SPARK_MODEL

    reasoning_effort = str(
        getattr(args, "team_reasoning_effort", "")
        or getattr(args, "worker_reasoning_effort", "")
        or global_opts.get("reasoning_effort", "")
        or CODEX_WORKER_REASONING_DEFAULT
    )
    worker_launch = build_team_worker_launch_args(
        str(getattr(args, "team_worker_launch_args", "") or os.environ.get("OMX_TEAM_WORKER_LAUNCH_ARGS", "")),
        team_model,
        reasoning_effort,
    )
    if worker_launch.strip():
        env["OMX_TEAM_WORKER_LAUNCH_ARGS"] = worker_launch
    if bool(getattr(args, "team_scaling", False)):
        env["OMX_TEAM_SCALING_ENABLED"] = "1"
    # kaudit preflight is shell-driven. Disable worker-idle prompt injection so
    # OMX status strings do not get pasted back into the shell leader pane.
    env.setdefault("OMX_TEAM_WORKER_IDLE_NOTIFY", "0")
    env.setdefault("OMX_TEAM_WORKER_IDLE_COOLDOWN_MS", str(TEAM_NUDGE_MAX_MS))
    env.setdefault("OMX_TEAM_ALL_IDLE_COOLDOWN_MS", str(TEAM_NUDGE_MAX_MS))
    env.setdefault("OMX_TEAM_LEADER_NUDGE_MS", str(TEAM_NUDGE_MAX_MS))
    env.setdefault("OMX_TEAM_LEADER_ALL_IDLE_COOLDOWN_MS", str(TEAM_NUDGE_MAX_MS))
    env.setdefault("OMX_TEAM_LEADER_STALE_MS", str(TEAM_NUDGE_MAX_MS))
    notify_contract = global_opts.get("notify_contract")
    if isinstance(notify_contract, dict) and notify_contract.get("active") is True:
        env["OMX_NOTIFY_TEMP"] = "1"
        env["OMX_NOTIFY_TEMP_CONTRACT"] = json.dumps(notify_contract)
    return env


def team_preflight_task(ctx: KernelAuditContext, jobs: int, target: str) -> str:
    # Numbered task format makes omx team decomposition deterministic.
    return textwrap.dedent(
        f"""\
        1. In {ctx.repo_root}, run `./.omx/kernel-audit/bin/kernel-audit refresh --syzbot --cve`.
        2. In {ctx.repo_root}, run `./.omx/kernel-audit/bin/kernel-audit build init --jobs {jobs}`.
        3. In {ctx.repo_root}, run `./.omx/kernel-audit/bin/kernel-audit status` and verify knowledge snapshot + bzImage are present for target `{target}` campaign.
        """
    ).strip()


def parse_iso_timestamp(raw: str) -> Optional[float]:
    text = str(raw or "").strip()
    if not text:
        return None
    try:
        return datetime.fromisoformat(text.replace("Z", "+00:00")).timestamp()
    except ValueError:
        return None


def team_preflight_artifacts_ready(ctx: KernelAuditContext, started_at_epoch: float) -> bool:
    margin = 5.0
    snapshot_ok = ctx.knowledge_snapshot_path.exists() and (
        ctx.knowledge_snapshot_path.stat().st_mtime >= (started_at_epoch - margin)
    )

    bzimage = ctx.bzimage_path()
    build_ok = False
    if bzimage.exists() and bzimage.stat().st_mtime >= (started_at_epoch - margin):
        build_ok = True
    else:
        build_state = read_json(ctx.build_state_path, {})
        updated_at = parse_iso_timestamp(str(build_state.get("updated_at", "") or ""))
        build_ok = bool(
            bzimage.exists()
            and updated_at is not None
            and updated_at >= (started_at_epoch - margin)
        )

    return snapshot_ok and build_ok


def run_team_preflight(
    ctx: KernelAuditContext,
    args: argparse.Namespace,
    jobs: int,
    target: str,
) -> Dict[str, Any]:
    task = team_preflight_task(ctx, jobs=jobs, target=target)
    global_opts = parse_team_omx_global_args(str(getattr(args, "team_omx_global_args", "") or ""))
    start_cmd = build_omx_team_start_command(args, task, global_opts)
    env = build_team_env(args, global_opts)
    started_at_epoch = time.time()

    started = run_cmd(start_cmd, cwd=ctx.repo_root, check=False, env=env)
    if started.returncode != 0:
        raise RuntimeError(f"omx team start failed: {started.stdout.strip()}")

    team_name = parse_team_name(started.stdout)
    if not team_name:
        raise RuntimeError(f"could not parse team name from omx output:\n{started.stdout.strip()}")

    timeout = int(args.team_timeout)
    poll_interval = int(args.team_poll_interval)
    deadline = time.time() + max(timeout, 30)
    last_status: Dict[str, Any] = {}
    phase = "cancelled"
    aggressive_cleanup = False
    dead_worker_grace_deadline = started_at_epoch + 30
    event_query_ok = team_event_query_available(ctx)
    event_cursor: Optional[str] = None
    try:
        while True:
            st = team_summary_via_api(ctx, team_name)
            if not st:
                status_res = run_cmd(["omx", "team", "status", team_name], cwd=ctx.repo_root, check=False)
                if status_res.returncode == 0:
                    st = parse_team_status(status_res.stdout)
                    if st:
                        st["source"] = "status-scrape"
            if st:
                last_status = st
                current_phase = str(st.get("phase", ""))
                pending = int(st.get("pending", 0))
                blocked = int(st.get("blocked", 0))
                in_progress = int(st.get("in_progress", 0))
                completed = int(st.get("completed", 0))
                worker_count = int(st.get("worker_count", 0))
                dead_workers = int(st.get("dead_workers", 0))
                if current_phase in TEAM_PHASE_DONE or (pending == 0 and blocked == 0 and in_progress == 0):
                    phase = "complete"
                    break
                if (
                    time.time() >= dead_worker_grace_deadline
                    and worker_count > 0
                    and dead_workers >= worker_count
                    and (pending > 0 or in_progress > 0)
                    and completed == 0
                ):
                    phase = "failed"
                    aggressive_cleanup = True
                    raise RuntimeError(
                        "omx team preflight workers died before completing tasks "
                        f"(team={team_name}, workers={worker_count}, dead={dead_workers}, "
                        f"pending={pending}, in_progress={in_progress})"
                    )

            if team_preflight_artifacts_ready(ctx, started_at_epoch):
                phase = "complete"
                last_status["artifact_gate"] = True
                last_status.setdefault("source", "artifact-gate")
                break

            if time.time() >= deadline:
                phase = "timeout"
                aggressive_cleanup = True
                raise RuntimeError(f"omx team preflight timed out after {timeout}s (team={team_name})")
            remaining_ms = int(max(0, (deadline - time.time()) * 1000))
            wait_ms = min(remaining_ms, max(poll_interval, 2) * 1000)
            if event_query_ok and wait_ms > 0:
                awaited = team_await_event_via_api(ctx, team_name, event_cursor, wait_ms, poll_ms=min(wait_ms, 1000))
                if awaited:
                    cursor = str(awaited.get("cursor", "") or "")
                    if cursor:
                        event_cursor = cursor
                    continue
            time.sleep(max(poll_interval, 2))

        if int(last_status.get("failed", 0)) > 0:
            phase = "failed"
            raise RuntimeError(f"omx team preflight completed with failed tasks (team={team_name})")

        return {"team_name": team_name, "status": last_status}
    except KeyboardInterrupt:
        phase = "cancelled"
        aggressive_cleanup = True
        raise
    finally:
        note = cleanup_team_runtime(ctx, team_name, phase=phase, aggressive=aggressive_cleanup)
        if note:
            print(f"[kaudit] team cleanup: {note}")


def run_local_preflight(ctx: KernelAuditContext, jobs: int, force_refresh: bool, force_build: bool) -> None:
    bz = ctx.bzimage_path()
    if force_refresh or not (ctx.syzbot_path.exists() and ctx.cve_path.exists()):
        cmd_knowledge_refresh(ctx, argparse.Namespace())
    if force_build or not bz.exists():
        cmd_build_init(ctx, argparse.Namespace(jobs=jobs))


def run_cycle_preflight(ctx: KernelAuditContext, args: argparse.Namespace) -> None:
    jobs = args.jobs if args.jobs and args.jobs > 0 else os.cpu_count() or 1
    dispatch = str(args.dispatch).strip().lower()

    if dispatch not in {"auto", "team", "local"}:
        raise RuntimeError(f"invalid --dispatch mode: {dispatch}")

    if dispatch == "local":
        run_local_preflight(ctx, jobs, force_refresh=args.force_refresh, force_build=args.force_build)
        return

    ready, reason = team_ready(ctx)
    if not ready:
        if dispatch == "team":
            raise RuntimeError(f"team dispatch requested but unavailable: {reason}")
        print(f"[kaudit] auto dispatch fallback to local preflight: {reason}")
        run_local_preflight(ctx, jobs, force_refresh=args.force_refresh, force_build=args.force_build)
        return

    try:
        result = run_team_preflight(
            ctx,
            args=args,
            jobs=jobs,
            target=args.target,
        )
        print(f"[kaudit] team preflight complete: {result['team_name']} status={result['status']}")
    except Exception as exc:
        if dispatch == "team":
            raise
        print(f"[kaudit] auto dispatch team preflight failed; fallback to local: {exc}")
        run_local_preflight(ctx, jobs, force_refresh=args.force_refresh, force_build=args.force_build)


def cmd_cycle(ctx: KernelAuditContext, args: argparse.Namespace) -> int:
    ctx.ensure_layout()
    ensure_default_files(ctx)

    once = args.once or not args.loop
    if once:
        try:
            if args.preflight:
                run_cycle_preflight(ctx, args)
            run_single_cycle(ctx, similarity_threshold=args.similarity_threshold, target=args.target, args=args)
            return 0
        except KeyboardInterrupt:
            set_pipeline_active_jobs(ctx, [])
            note = cleanup_team_runtime(ctx, read_active_team_name(ctx), phase="cancelled", aggressive=True)
            if note:
                print(f"[kaudit] interrupt cleanup: {note}")
            print("\n[kaudit] cycle interrupted by user")
            return 130
        except Exception as exc:
            set_pipeline_active_jobs(ctx, [])
            note = cleanup_team_runtime(ctx, read_active_team_name(ctx), phase="failed", aggressive=True)
            if note:
                print(f"[kaudit] error cleanup: {note}")
            return fail(str(exc))

    iteration = 0
    try:
        if args.preflight:
            run_cycle_preflight(ctx, args)
        while True:
            iteration += 1
            print(f"[kaudit] loop iteration {iteration} start")
            run_single_cycle(ctx, similarity_threshold=args.similarity_threshold, target=args.target, args=args)
            if args.max_iterations and iteration >= args.max_iterations:
                print("[kaudit] loop complete: reached max iterations")
                break
            print(f"[kaudit] sleeping {args.interval}s before next iteration")
            time.sleep(args.interval)
    except KeyboardInterrupt:
        set_pipeline_active_jobs(ctx, [])
        note = cleanup_team_runtime(ctx, read_active_team_name(ctx), phase="cancelled", aggressive=True)
        if note:
            print(f"[kaudit] interrupt cleanup: {note}")
        print("\n[kaudit] loop interrupted by user")
    except Exception as exc:
        set_pipeline_active_jobs(ctx, [])
        note = cleanup_team_runtime(ctx, read_active_team_name(ctx), phase="failed", aggressive=True)
        if note:
            print(f"[kaudit] error cleanup: {note}")
        return fail(str(exc))

    return 0


def cmd_orchestrate(ctx: KernelAuditContext, args: argparse.Namespace) -> int:
    ctx.ensure_layout()
    ensure_default_files(ctx)
    try:
        if args.sync_mainline:
            rc = cmd_sync_mainline(ctx, argparse.Namespace())
            if rc != 0:
                return rc

        preflight_ns = argparse.Namespace(
            jobs=args.jobs,
            dispatch=args.dispatch,
            force_refresh=args.force_refresh,
            force_build=args.force_build,
            target=args.target,
            team_workers=args.team_workers,
            team_agent_type=args.team_agent_type,
            team_timeout=args.team_timeout,
            team_poll_interval=args.team_poll_interval,
            team_model=args.team_model,
            team_worker_launch_args=args.team_worker_launch_args,
            team_reasoning_effort=args.team_reasoning_effort,
            team_omx_global_args=args.team_omx_global_args,
            team_scaling=args.team_scaling,
        )
        run_cycle_preflight(ctx, preflight_ns)

        case_id = run_single_cycle(ctx, similarity_threshold=args.similarity_threshold, target=args.target, args=args)
        if not case_id:
            print("[kaudit] orchestrate complete: no novel case in this run")
            return 0

        print(f"[kaudit] orchestrate selected case: {case_id}")
        if not args.auto_repro:
            return 0
        return 0
    except KeyboardInterrupt:
        set_pipeline_active_jobs(ctx, [])
        note = cleanup_team_runtime(ctx, read_active_team_name(ctx), phase="cancelled", aggressive=True)
        if note:
            print(f"[kaudit] interrupt cleanup: {note}")
        print("\n[kaudit] orchestrate interrupted by user")
        return 130
    except Exception as exc:
        set_pipeline_active_jobs(ctx, [])
        note = cleanup_team_runtime(ctx, read_active_team_name(ctx), phase="failed", aggressive=True)
        if note:
            print(f"[kaudit] error cleanup: {note}")
        return fail(str(exc))


def ensure_case_exists(ctx: KernelAuditContext, case_id: str) -> Dict[str, Any]:
    candidates: List[Path] = [ctx.case_json_path(case_id)]
    for target in SUPPORTED_TARGETS:
        alt = KernelAuditContext(ctx.repo_root, target).case_json_path(case_id)
        if alt not in candidates:
            candidates.append(alt)
    for path in candidates:
        if not path.exists():
            continue
        case = normalize_case(read_json(path, {}))
        if case:
            return case
        raise RuntimeError(f"failed to read case json: {path}")
    raise RuntimeError(f"case not found: {case_id}")


def pipeline_target(ctx: KernelAuditContext) -> str:
    state = load_pipeline_state(ctx)
    return normalize_target_name(str(state.get("target", "") or "fs").strip() or "fs")


def refresh_case_queues(ctx: KernelAuditContext, *, target: Optional[str] = None) -> Dict[str, Any]:
    state = load_pipeline_state(ctx)
    resolved_target = normalize_target_name(str(target or state.get("target") or "fs").strip() or "fs")
    audit_width = max(1, len(state.get("audit_queue", [])) or DEFAULT_AUDIT_WORKERS)
    state["target"] = resolved_target
    state["audit_queue"] = select_next_shards(ctx, resolved_target, audit_width)
    state["verify_queue"] = [case["case_id"] for case in collect_cases_by_stage(ctx, {"discovered"})]
    state["repro_queue"] = [case["case_id"] for case in collect_cases_by_stage(ctx, {"repro_queued", "repro_failed"})]
    state["report_queue"] = [case["case_id"] for case in collect_cases_by_stage(ctx, {"confirmed"})]
    save_pipeline_state(ctx, state)

    campaign = ctx.load_campaign()
    refresh_campaign_metrics(ctx, campaign)
    ctx.save_campaign(campaign)
    return state


def append_operator_note(
    case: Dict[str, Any],
    message: str,
    *,
    author: str = "operator",
    category: str = "note",
) -> None:
    text = str(message or "").strip()
    if not text:
        return
    case.setdefault("operator_notes", [])
    case["operator_notes"].append(
        {
            "timestamp": utc_now_iso(),
            "author": author,
            "category": category,
            "message": text,
        }
    )
    case["operator_notes"] = case["operator_notes"][-50:]


def append_operator_action(
    case: Dict[str, Any],
    action: str,
    *,
    from_stage: Optional[str] = None,
    to_stage: Optional[str] = None,
    details: str = "",
    author: str = "operator",
) -> None:
    case.setdefault("operator_actions", [])
    entry = {
        "timestamp": utc_now_iso(),
        "author": author,
        "action": str(action or "").strip() or "operator-action",
    }
    if from_stage:
        entry["from_stage"] = from_stage
    if to_stage:
        entry["to_stage"] = to_stage
    if details.strip():
        entry["details"] = details.strip()
    case["operator_actions"].append(entry)
    case["operator_actions"] = case["operator_actions"][-50:]


def format_case_summary(case: Dict[str, Any], *, recent_limit: int = 5) -> str:
    case = normalize_case(case)
    lines = [
        "[kaudit] case",
        f"- case_id: {case.get('case_id')}",
        f"- stage: {case.get('stage')}",
        f"- status: {case.get('status')}",
        f"- created_at: {case.get('created_at')}",
        f"- target_paths: {', '.join(case.get('target_paths', []))}",
        f"- suspect_functions: {', '.join(case.get('suspect_functions', []))}",
        f"- verifier_verdict: {case.get('verification', {}).get('verdict', 'pending')}",
        f"- verifier_confidence: {case.get('verification', {}).get('confidence')}",
        f"- auto_repro_supported: {case.get('verification', {}).get('auto_repro_supported')}",
        f"- kasan_detected: {case.get('kasan_detected')}",
        f"- qemu_log: {case.get('qemu_log')}",
        f"- report_path: {case.get('report_path')}",
        f"- email_report_path: {case.get('email_report_path')}",
    ]
    manual_constraints = str(case.get("verification", {}).get("manual_constraints", "") or "").strip()
    if manual_constraints:
        lines.append(f"- manual_constraints: {manual_constraints}")
    duplicate_analysis = str(case.get("verification", {}).get("duplicate_analysis", "") or "").strip()
    if duplicate_analysis:
        lines.append(f"- duplicate_analysis: {duplicate_analysis}")
    trigger_contract = str(case.get("verification", {}).get("trigger_contract", "") or "").strip()
    if trigger_contract:
        lines.append(f"- trigger_contract: {trigger_contract}")
    operator_notes = case.get("operator_notes", []) if isinstance(case.get("operator_notes"), list) else []
    if operator_notes:
        lines.append("- operator_notes:")
        for item in operator_notes[-recent_limit:]:
            if not isinstance(item, dict):
                continue
            lines.append(
                f"  - [{item.get('timestamp')}] {item.get('author', 'operator')}: {str(item.get('message', '')).strip()}"
            )
    operator_actions = case.get("operator_actions", []) if isinstance(case.get("operator_actions"), list) else []
    if operator_actions:
        lines.append("- operator_actions:")
        for item in operator_actions[-recent_limit:]:
            if not isinstance(item, dict):
                continue
            details = str(item.get("details", "") or "").strip()
            suffix = f" ({details})" if details else ""
            lines.append(
                f"  - [{item.get('timestamp')}] {item.get('action')} {item.get('from_stage', '')}->{item.get('to_stage', '')}{suffix}".rstrip()
            )
    return "\n".join(lines)


def case_promotion_allowed(from_stage: str, to_stage: str) -> bool:
    if from_stage == to_stage:
        return True
    allowed = {
        "manual_only": {"repro_queued", "discovered", "rejected"},
        "repro_failed": {"repro_queued", "manual_only", "rejected"},
        "discovered": {"manual_only", "rejected", "repro_queued"},
        "rejected": {"discovered", "manual_only"},
        "duplicate_review": {"confirmed", "reported", "rejected", "manual_only"},
        "confirmed": {"reported"},
    }
    return to_stage in allowed.get(from_stage, set())


def cmd_case_show(ctx: KernelAuditContext, args: argparse.Namespace) -> int:
    ctx.ensure_layout()
    ensure_default_files(ctx)
    case = ensure_case_exists(ctx, args.case_id)
    if bool(getattr(args, "json", False)):
        print(json.dumps(case, indent=2, sort_keys=True))
        return 0
    print(format_case_summary(case, recent_limit=max(1, as_int(getattr(args, "recent", 5), 5))))
    return 0


def cmd_case_note(ctx: KernelAuditContext, args: argparse.Namespace) -> int:
    ctx.ensure_layout()
    ensure_default_files(ctx)
    case = ensure_case_exists(ctx, args.case_id)
    message = str(getattr(args, "message", "") or "").strip()
    if not message:
        return fail("--message is required")
    append_operator_note(case, message, category=str(getattr(args, "category", "note") or "note"))
    append_operator_action(
        case,
        "case-note",
        from_stage=case_stage(case),
        to_stage=case_stage(case),
        details=message,
    )
    save_case(ctx, case)
    refresh_case_queues(ctx, target=pipeline_target(ctx))
    print(f"[kaudit] case note added: {case['case_id']}")
    return 0


def cmd_case_promote(ctx: KernelAuditContext, args: argparse.Namespace) -> int:
    ctx.ensure_layout()
    ensure_default_files(ctx)
    case = ensure_case_exists(ctx, args.case_id)
    from_stage = case_stage(case)
    to_stage = str(getattr(args, "to_stage", "") or "").strip()
    if not to_stage:
        return fail("--to is required")
    reason = str(getattr(args, "reason", "") or "").strip()
    if not reason:
        return fail("--reason is required for operator promotion")
    if to_stage not in CASE_STAGE_TO_STATUS:
        return fail(f"unsupported target stage: {to_stage}")
    if not bool(getattr(args, "force", False)) and not case_promotion_allowed(from_stage, to_stage):
        return fail(f"refusing promotion {from_stage} -> {to_stage} without --force")

    case["stage"] = to_stage
    sync_case_status(case)
    append_operator_note(case, reason, category="promotion")
    append_operator_action(
        case,
        "case-promote",
        from_stage=from_stage,
        to_stage=to_stage,
        details=reason,
    )
    if to_stage == "repro_queued":
        case["last_verified_at"] = utc_now_iso()
    save_case(ctx, case)
    refresh_case_queues(ctx, target=pipeline_target(ctx))
    print(f"[kaudit] case promoted: {case['case_id']} {from_stage} -> {to_stage}")
    return 0


def cmd_case_backfill(ctx: KernelAuditContext, args: argparse.Namespace) -> int:
    ctx.ensure_layout()
    ensure_default_files(ctx)
    case_paths = collect_case_paths(ctx)
    rewritten = 0
    changed = 0
    for case_path in case_paths:
        before = read_json(case_path, {})
        after = normalize_case(deep_copy_json(before))
        if before != after or bool(getattr(args, "rewrite_notes", False)):
            save_case(ctx, after)
            rewritten += 1
        if case_stage(before if isinstance(before, dict) else {}) != case_stage(after):
            changed += 1
    refresh_case_queues(ctx, target=pipeline_target(ctx))
    print("[kaudit] case backfill complete")
    print(f"- scanned: {len(case_paths)}")
    print(f"- rewritten: {rewritten}")
    print(f"- stage_changes: {changed}")
    return 0


def write_text(path: Path, content: str, mode: int = 0o644) -> None:
    path.parent.mkdir(parents=True, exist_ok=True)
    path.write_text(content, encoding="utf-8")
    os.chmod(path, mode)


def ensure_gen_init_cpio(ctx: KernelAuditContext) -> Path:
    gen_init_cpio = ctx.build_dir / "usr" / "gen_init_cpio"
    if gen_init_cpio.exists():
        return gen_init_cpio
    run_cmd(
        ["make", f"O={ctx.build_dir}", "ARCH=x86_64", "usr/gen_init_cpio"],
        cwd=ctx.repo_root,
        check=True,
    )
    if not gen_init_cpio.exists():
        raise RuntimeError(f"gen_init_cpio not found after build: {gen_init_cpio}")
    return gen_init_cpio


def prepare_case_poc_assets(ctx: KernelAuditContext, case: Dict[str, Any]) -> Dict[str, Path]:
    case_id = case["case_id"]
    case_dir = ctx.case_dir(case_id)
    poc_dir = case_dir / "poc"
    poc_dir.mkdir(parents=True, exist_ok=True)

    assets: Dict[str, Path] = {}
    trigger = case.get("trigger", {}) if isinstance(case.get("trigger"), dict) else {}
    source_c = str(trigger.get("source_c", "") or "")
    command = str(trigger.get("command", "") or "")
    run_script = str(trigger.get("run_script", "") or "")

    if source_c.strip():
        src_path = poc_dir / "poc.c"
        bin_path = poc_dir / "poc-bin"
        write_text(src_path, source_c)
        run_cmd(["gcc", "-static", "-O2", "-s", str(src_path), "-o", str(bin_path)], cwd=ctx.repo_root, check=True)
        assets["/poc/poc.c"] = src_path
        assets["/poc/poc-bin"] = bin_path
        if not command.strip():
            command = "/poc/poc-bin"

    marker_src = textwrap.dedent(
        """\
        #define _GNU_SOURCE
        #include <errno.h>
        #include <stdio.h>
        #include <string.h>
        #include <sys/io.h>
        #include <unistd.h>

        #define COM1_BASE 0x3f8
        #define DEBUGCON_BASE 0xe9

        int main(int argc, char **argv)
        {
            const char *msg = (argc > 1) ? argv[1] : "[kaudit] marker\\n";
            size_t i;

            if (ioperm(COM1_BASE, 8, 1) != 0) {
                fprintf(stderr, "ioperm: %s\\n", strerror(errno));
                return 1;
            }
            (void)ioperm(DEBUGCON_BASE, 1, 1);
            for (i = 0; msg[i]; i++)
                outb((unsigned char)msg[i], COM1_BASE);
            for (i = 0; msg[i]; i++)
                outb((unsigned char)msg[i], DEBUGCON_BASE);
            return 0;
        }
        """
    )
    marker_src_path = poc_dir / "serial-mark.c"
    marker_bin_path = poc_dir / "serial-mark"
    write_text(marker_src_path, marker_src)
    run_cmd(["gcc", "-static", "-O2", "-s", str(marker_src_path), "-o", str(marker_bin_path)], cwd=ctx.repo_root, check=True)
    assets["/poc/serial-mark.c"] = marker_src_path
    assets["/poc/serial-mark"] = marker_bin_path

    if run_script.strip():
        run_content = run_script
    elif command.strip():
        run_content = textwrap.dedent(
            f"""\
            #!/bin/sh
            set -eux
            if [ -x /poc/serial-mark ]; then /poc/serial-mark "[kaudit] run.sh start\\n" || true; fi
            echo "[kaudit] trigger command: {command}"
            {command} || true
            dmesg || true
            if [ -x /poc/serial-mark ]; then /poc/serial-mark "[kaudit] run.sh done\\n" || true; fi
            sync || true
            """
        )
    else:
        run_content = textwrap.dedent(
            """\
            #!/bin/sh
            set -eux
            if [ -x /poc/serial-mark ]; then /poc/serial-mark "[kaudit] no trigger configured\\n" || true; fi
            echo "[kaudit] no trigger configured for this case"
            dmesg || true
            sync || true
            """
        )

    run_path = poc_dir / "run.sh"
    write_text(run_path, run_content, mode=0o755)
    assets["/poc/run.sh"] = run_path

    return assets


def build_guest_init_launcher(root_dir: Path, banner: str) -> Path:
    source = textwrap.dedent(
        f"""\
#define _GNU_SOURCE
#include <errno.h>
#include <fcntl.h>
#include <linux/reboot.h>
#include <stdio.h>
#include <stdlib.h>
#include <string.h>
#include <sys/mount.h>
#include <sys/reboot.h>
#include <sys/types.h>
#include <sys/wait.h>
#include <unistd.h>

static void emit_marker(const char *msg)
{{
    int fd = open("/dev/ttyS0", O_WRONLY | O_NOCTTY);
    if (fd >= 0) {{
        (void)write(fd, msg, strlen(msg));
        close(fd);
    }}
}}

static void redirect_serial(void)
{{
    int fd = open("/dev/ttyS0", O_WRONLY | O_NOCTTY);
    if (fd < 0)
        return;
    (void)dup2(fd, STDOUT_FILENO);
    (void)dup2(fd, STDERR_FILENO);
    if (fd > STDERR_FILENO)
        close(fd);
}}

int main(void)
{{
    pid_t pid;
    int status = 0;

    (void)mount("proc", "/proc", "proc", 0, NULL);
    (void)mount("sysfs", "/sys", "sysfs", 0, NULL);
    (void)mount("devtmpfs", "/dev", "devtmpfs", 0, NULL);
    redirect_serial();
    emit_marker("[kaudit] {banner} start\\n");
    puts("[kaudit] {banner} start");

    pid = fork();
    if (pid == 0) {{
        execl("/bin/sh", "sh", "/poc/run.sh", (char *)NULL);
        execl("/bin/sh", "sh", (char *)NULL);
        perror("execl /bin/sh");
        _exit(127);
    }}
    if (pid > 0)
        (void)waitpid(pid, &status, 0);

    sync();
    emit_marker("[kaudit] {banner} done\\n");
    puts("[kaudit] {banner} done; powering off");
    (void)reboot(LINUX_REBOOT_CMD_POWER_OFF);
    (void)reboot(LINUX_REBOOT_CMD_HALT);
    (void)reboot(LINUX_REBOOT_CMD_RESTART);
    return status;
}}
"""
    )
    init_c = root_dir / "init.c"
    init_bin = root_dir / "init-bin"
    write_text(init_c, source)
    run_cmd(["gcc", "-static", "-O2", "-s", str(init_c), "-o", str(init_bin)], cwd=root_dir, check=True)
    return init_bin


def busybox_initramfs_entries_for_assets(assets: Dict[str, Path], init_path: Path) -> List[str]:
    busybox_path = shutil.which("busybox")
    if not busybox_path:
        raise RuntimeError("busybox not found in PATH")

    lines = [
        "dir /dev 0755 0 0",
        "dir /proc 0555 0 0",
        "dir /sys 0555 0 0",
        "dir /tmp 1777 0 0",
        "dir /root 0700 0 0",
        "dir /bin 0755 0 0",
        "dir /sbin 0755 0 0",
        "dir /usr 0755 0 0",
        "dir /usr/bin 0755 0 0",
        "dir /poc 0755 0 0",
        "nod /dev/console 0600 0 0 c 5 1",
        "nod /dev/ttyS0 0600 0 0 c 4 64",
        f"file /bin/busybox {busybox_path} 0755 0 0",
    ]

    applets = [
        "sh",
        "mount",
        "umount",
        "mkdir",
        "cat",
        "echo",
        "grep",
        "dmesg",
        "sleep",
        "poweroff",
        "halt",
        "reboot",
        "ls",
        "chmod",
        "chown",
        "sync",
    ]
    for app in applets:
        lines.append(f"slink /bin/{app} /bin/busybox 0777 0 0")

    lines.append(f"file /init {init_path} 0755 0 0")

    for guest_path, host_path in assets.items():
        mode = "0755" if os.access(host_path, os.X_OK) else "0644"
        lines.append(f"file {guest_path} {host_path} {mode} 0 0")

    return lines


def build_case_busybox_initramfs(ctx: KernelAuditContext, case: Dict[str, Any], assets: Dict[str, Path]) -> Path:
    case_id = case["case_id"]
    rootfs_case_dir = ctx.rootfs_dir / case_id
    rootfs_case_dir.mkdir(parents=True, exist_ok=True)

    cpio_list = rootfs_case_dir / "cpio_list.txt"
    init_bin_path = build_guest_init_launcher(rootfs_case_dir, "guest init")
    entries = busybox_initramfs_entries_for_assets(assets, init_bin_path)
    cpio_list.write_text("\n".join(entries) + "\n", encoding="utf-8")

    out_path = rootfs_case_dir / "initramfs.cpio"
    gen_init_cpio = ensure_gen_init_cpio(ctx)
    run_cmd([str(gen_init_cpio), "-o", str(out_path), str(cpio_list)], cwd=ctx.repo_root, check=True)
    return out_path


def ensure_debian_rootfs_cache(
    ctx: KernelAuditContext, suite: str, mirror: str, include: str, force: bool = False
) -> Path:
    debian_root = ctx.rootfs_dir / "debian"
    debian_root.mkdir(parents=True, exist_ok=True)
    cache_tar = debian_root / f"{suite}-minbase.tar"
    meta_path = debian_root / f"{suite}-minbase.meta.json"

    if cache_tar.exists() and not force:
        return cache_tar

    builder = ""
    with tempfile.TemporaryDirectory(prefix="kaudit-debian-", dir=str(debian_root)) as td:
        td_path = Path(td)
        root_dir = td_path / "rootfs"
        root_dir.mkdir(parents=True, exist_ok=True)

        if shutil.which("mmdebstrap"):
            builder = "mmdebstrap"
            print(f"[kaudit] building Debian rootfs cache via {builder} (suite={suite}); this may take several minutes")
            cmd = ["mmdebstrap", "--variant=minbase", f"--include={include}", suite, str(root_dir), mirror]
            run_cmd(cmd, cwd=ctx.repo_root, check=True)
        elif shutil.which("debootstrap"):
            base_cmd = [
                "debootstrap",
                "--foreign",
                "--variant=minbase",
                f"--include={include}",
                suite,
                str(root_dir),
                mirror,
            ]
            print("[kaudit] building Debian rootfs cache via debootstrap; this may take several minutes")
            direct = run_cmd(base_cmd, cwd=ctx.repo_root, check=False)
            used_sudo = False
            if direct.returncode == 0:
                builder = "debootstrap-foreign"
            else:
                if shutil.which("sudo"):
                    sudo_cmd = ["sudo", "-n"] + base_cmd
                    sudo_res = run_cmd(sudo_cmd, cwd=ctx.repo_root, check=False)
                    if sudo_res.returncode == 0:
                        builder = "debootstrap-foreign-sudo"
                        used_sudo = True
                    else:
                        raise RuntimeError(
                            "debootstrap failed (direct + sudo). "
                            f"direct_err={direct.stdout.strip()} sudo_err={sudo_res.stdout.strip()}"
                        )
                else:
                    raise RuntimeError(f"debootstrap failed: {direct.stdout.strip()}")

            if cache_tar.exists():
                cache_tar.unlink()
            if used_sudo:
                tar_res = run_cmd(
                    ["sudo", "-n", "tar", "-C", str(root_dir), "-cf", str(cache_tar), "."],
                    cwd=ctx.repo_root,
                    check=False,
                )
                if tar_res.returncode != 0:
                    raise RuntimeError(f"sudo tar failed for debian cache: {tar_res.stdout.strip()}")
                run_cmd(
                    ["sudo", "-n", "chown", f"{os.getuid()}:{os.getgid()}", str(cache_tar)],
                    cwd=ctx.repo_root,
                    check=False,
                )
            else:
                run_cmd(["tar", "-C", str(root_dir), "-cf", str(cache_tar), "."], cwd=ctx.repo_root, check=True)
        else:
            raise RuntimeError("debian rootfs mode requires `mmdebstrap` or `debootstrap` in PATH")

        if not cache_tar.exists():
            raise RuntimeError(f"failed to create debian rootfs archive: {cache_tar}")

    write_json(
        meta_path,
        {
            "updated_at": utc_now_iso(),
            "suite": suite,
            "mirror": mirror,
            "include": include,
            "builder": builder or "unknown",
            "archive": str(cache_tar),
            "sha256": sha256_file(cache_tar),
        },
    )
    return cache_tar


def copy_assets_to_root(root_dir: Path, assets: Dict[str, Path]) -> None:
    for guest_path, host_path in assets.items():
        rel = guest_path.lstrip("/")
        dst = root_dir / rel
        dst.parent.mkdir(parents=True, exist_ok=True)
        shutil.copy2(host_path, dst)
        mode = 0o755 if os.access(host_path, os.X_OK) else 0o644
        os.chmod(dst, mode)


def build_case_debian_initramfs(
    ctx: KernelAuditContext,
    case: Dict[str, Any],
    assets: Dict[str, Path],
    suite: str,
    mirror: str,
    include: str,
    force_cache: bool = False,
) -> Path:
    if not shutil.which("cpio") or not shutil.which("gzip"):
        raise RuntimeError("debian rootfs mode requires `cpio` and `gzip` in PATH")

    case_id = case["case_id"]
    case_root = ctx.rootfs_dir / case_id / "debian"
    root_dir = case_root / "root"
    case_root.mkdir(parents=True, exist_ok=True)

    cache_tar = ensure_debian_rootfs_cache(ctx, suite=suite, mirror=mirror, include=include, force=force_cache)

    if root_dir.exists():
        shutil.rmtree(root_dir)
    root_dir.mkdir(parents=True, exist_ok=True)
    run_cmd(["tar", "-C", str(root_dir), "-xf", str(cache_tar)], cwd=ctx.repo_root, check=True)

    for d in ["proc", "sys", "dev", "tmp", "root", "poc"]:
        (root_dir / d).mkdir(parents=True, exist_ok=True)
    os.chmod(root_dir / "tmp", 0o1777)
    copy_assets_to_root(root_dir, assets)

    init_bin_path = build_guest_init_launcher(case_root, "debian initramfs guest")
    shutil.copy2(init_bin_path, root_dir / "init")
    os.chmod(root_dir / "init", 0o755)

    out_path = case_root / "initramfs-debian.cpio.gz"
    pack_cmd = f"cd '{root_dir}' && find . -print0 | cpio --null -ov --format=newc | gzip -9 > '{out_path}'"
    run_cmd(["bash", "-lc", pack_cmd], cwd=ctx.repo_root, check=True)
    return out_path


def build_case_initramfs(
    ctx: KernelAuditContext,
    case: Dict[str, Any],
    assets: Dict[str, Path],
    rootfs_mode: str,
    debian_suite: str,
    debian_mirror: str,
    debian_include: str,
    debian_force_cache: bool,
) -> Tuple[Path, str]:
    mode = rootfs_mode.strip().lower()
    if mode not in {"auto", "busybox", "debian"}:
        raise RuntimeError(f"unsupported rootfs mode: {rootfs_mode}")

    if mode == "busybox":
        return build_case_busybox_initramfs(ctx, case, assets), "busybox"

    if mode == "debian":
        return (
            build_case_debian_initramfs(
                ctx,
                case,
                assets,
                suite=debian_suite,
                mirror=debian_mirror,
                include=debian_include,
                force_cache=debian_force_cache,
            ),
            "debian",
        )

    # auto: prefer richer Debian rootfs, fallback to BusyBox.
    try:
        initrd = build_case_debian_initramfs(
            ctx,
            case,
            assets,
            suite=debian_suite,
            mirror=debian_mirror,
            include=debian_include,
            force_cache=debian_force_cache,
        )
        return initrd, "debian"
    except Exception as exc:
        print(f"[kaudit] rootfs auto fallback to busybox: {exc}")
        return build_case_busybox_initramfs(ctx, case, assets), "busybox"


def cmd_rootfs_prepare(ctx: KernelAuditContext, args: argparse.Namespace) -> int:
    ctx.ensure_layout()
    ensure_default_files(ctx)

    mode = str(args.mode).strip().lower()
    if mode not in {"auto", "busybox", "debian"}:
        return fail(f"invalid --mode: {mode}")

    if mode in {"busybox", "auto"}:
        if not shutil.which("busybox"):
            return fail("busybox not found in PATH")
        print("[kaudit] busybox rootfs prerequisites: OK")

    if mode in {"debian", "auto"}:
        try:
            cache = ensure_debian_rootfs_cache(
                ctx,
                suite=args.debian_suite,
                mirror=args.debian_mirror,
                include=args.debian_include,
                force=args.force,
            )
            print(f"[kaudit] debian rootfs cache ready: {cache}")
        except Exception as exc:
            if mode == "debian":
                return fail(str(exc))
            print(f"[kaudit] debian rootfs cache skipped in auto mode: {exc}")

    return 0


def case_extra_fragment(ctx: KernelAuditContext, case: Dict[str, Any]) -> Optional[Path]:
    req = case.get("required_config", [])
    if not isinstance(req, list):
        return None
    req_lines = []
    for item in req:
        normalized = normalize_config_entry(item)
        if normalized:
            req_lines.append(normalized)
    if not req_lines:
        return None

    frag = ctx.fragments_dir / f"case-{case['case_id']}.config"
    frag.write_text("\n".join(req_lines) + "\n", encoding="utf-8")
    return frag


def qemu_cmd_for_case(
    ctx: KernelAuditContext,
    bzimage: Path,
    initramfs: Path,
    kasan_args: str,
    *,
    debugcon_path: Optional[Path] = None,
) -> List[str]:
    accel = str(os.environ.get("KAUDIT_QEMU_ACCEL", "tcg") or "tcg").strip().lower()
    cpu_override = str(os.environ.get("KAUDIT_QEMU_CPU", "") or "").strip()
    smp_override = str(os.environ.get("KAUDIT_QEMU_SMP", "") or "").strip()
    smp_value = smp_override or ("2" if accel == "kvm" else "1")
    cmd = [
        "qemu-system-x86_64",
        "-m",
        "2048",
        "-smp",
        smp_value,
        "-no-reboot",
        "-nographic",
        "-monitor",
        "none",
        "-serial",
        "stdio",
        "-kernel",
        str(bzimage),
        "-initrd",
        str(initramfs),
        "-append",
        kasan_args,
    ]
    if debugcon_path is not None:
        cmd.extend(["-debugcon", f"file:{debugcon_path}", "-global", "isa-debugcon.iobase=0xe9"])

    if accel == "kvm" and os.path.exists("/dev/kvm") and os.access("/dev/kvm", os.R_OK | os.W_OK):
        cmd.extend(["-accel", "kvm", "-cpu", cpu_override or "host"])
    else:
        # WSL2 + TCG can triple-fault early on newer mainline kernels with the
        # default virtual CPU model. Use a richer emulated CPU so serial console
        # and initramfs boot remain observable without requiring KVM.
        cmd.extend(["-accel", "tcg", "-cpu", cpu_override or "max"])

    return cmd


def run_qemu(cmd: Sequence[str], timeout_sec: int, log_path: Path) -> Tuple[str, int, bool]:
    log_path.parent.mkdir(parents=True, exist_ok=True)
    proc = subprocess.Popen(cmd, text=True, stdout=subprocess.PIPE, stderr=subprocess.STDOUT)
    timed_out = False
    out = ""
    try:
        out, _ = proc.communicate(timeout=timeout_sec)
    except subprocess.TimeoutExpired:
        timed_out = True
        proc.kill()
        out, _ = proc.communicate()

    with log_path.open("w", encoding="utf-8") as f:
        f.write(f"$ {shlex_join(list(cmd))}\n")
        f.write(f"# timeout_sec={timeout_sec}\n\n")
        f.write(out)
        f.write(f"\n\n# returncode={proc.returncode} timed_out={timed_out}\n")

    return out, proc.returncode if proc.returncode is not None else -1, timed_out


def cmd_repro(ctx: KernelAuditContext, args: argparse.Namespace) -> int:
    ctx.ensure_layout()
    ensure_default_files(ctx)

    case = ensure_case_exists(ctx, args.case_id)
    case_id = case["case_id"]

    trigger = case.get("trigger", {}) if isinstance(case.get("trigger"), dict) else {}
    has_trigger = any(str(trigger.get(key, "") or "").strip() for key in ("command", "source_c", "run_script"))
    if getattr(args, "auto_generate_trigger", False) and not has_trigger:
        planned = plan_repro_for_case(ctx, case, args=args, attempt_index=1, last_feedback="")
        if planned:
            case = apply_repro_plan_to_case(case, planned)
            save_case(ctx, case)
        trigger = case.get("trigger", {}) if isinstance(case.get("trigger"), dict) else {}
        has_trigger = any(str(trigger.get(key, "") or "").strip() for key in ("command", "source_c", "run_script"))
    if not has_trigger:
        return fail(f"case {case_id} has no trigger. run verify/auto-repro or fill trigger fields first")

    extra_fragment = case_extra_fragment(ctx, case)
    repro_stable_fragment = ctx.fragments_dir / REPRO_STABLE_FRAGMENT_NAME
    repro_fragments = [p for p in [repro_stable_fragment, extra_fragment] if p and p.exists()]

    if not args.skip_build:
        ensure_target_source_compat(ctx)
        clear_compiled_source_cache(ctx)
        if not (ctx.build_dir / ".config").exists():
            cmd_build_init(ctx, argparse.Namespace(jobs=args.jobs or 0))
        else:
            apply_fragments(ctx, extra_fragments=repro_fragments or None)
            jobs = args.jobs if args.jobs and args.jobs > 0 else os.cpu_count() or 1
            run_cmd(
                [
                    "make",
                    f"O={ctx.build_dir}",
                    "ARCH=x86_64",
                    f"-j{jobs}",
                    "bzImage",
                ],
                cwd=ctx.repo_root,
                check=True,
            )

    bzimage = ctx.bzimage_path()
    if not bzimage.exists():
        return fail(f"bzImage not found: {bzimage}")

    try:
        assets = prepare_case_poc_assets(ctx, case)
        initramfs, selected_rootfs_mode = build_case_initramfs(
            ctx,
            case,
            assets,
            rootfs_mode=args.rootfs_mode,
            debian_suite=args.debian_suite,
            debian_mirror=args.debian_mirror,
            debian_include=args.debian_include,
            debian_force_cache=args.debian_force_cache,
        )

        append = (
            "console=ttyS0,115200n8 earlycon=uart8250,io,0x3f8,115200n8 "
            "rdinit=/init panic=-1 oops=panic "
            "kasan_multi_shot kunit.enable=0 "
            "initcall_blacklist=init_trace_selftests,test_ringbuffer,test_static_call_init,"
            "kallsyms_test_init,kcov_init,of_unittest,init_kgdbts,lwq_test,init_btrfs_fs"
        )
        debugcon_path = ctx.case_dir(case_id) / f"qemu-debugcon-{utc_stamp()}.log"
        cmd = qemu_cmd_for_case(ctx, bzimage, initramfs, append, debugcon_path=debugcon_path)

        log_path = ctx.case_dir(case_id) / f"qemu-{utc_stamp()}.log"
        out, rc, timed_out = run_qemu(cmd, timeout_sec=args.timeout, log_path=log_path)

        kasan_hit = bool(re.search(r"BUG:\s+KASAN|KASAN:\s", out))
        case["qemu_log"] = str(log_path)
        case["debugcon_log"] = str(debugcon_path)
        case["kasan_detected"] = kasan_hit
        case["kernel_version"] = kernel_release(ctx)
        case["poc_artifacts"] = [str(p) for p in sorted(ctx.case_dir(case_id).rglob("poc/*")) if p.is_file()]
        case["last_repro_at"] = utc_now_iso()
        case["last_qemu_cmd"] = cmd
        case["rootfs_mode"] = selected_rootfs_mode
        case["initramfs"] = str(initramfs)
        case["stage"] = "confirmed" if kasan_hit else "repro_failed"
        case.setdefault("repro_result", {})
        case["repro_result"] = {
            "returncode": rc,
            "timed_out": timed_out,
        }
        sync_case_status(case)

        save_case(ctx, case)
        if kasan_hit:
            pipeline = load_pipeline_state(ctx)
            pipeline["last_successful_kasan_at"] = utc_now_iso()
            save_pipeline_state(ctx, pipeline)

        campaign = ctx.load_campaign()
        refresh_campaign_metrics(ctx, campaign)
        ctx.save_campaign(campaign)

        print(f"[kaudit] repro complete for {case_id}")
        print(f"[kaudit] qemu log: {log_path}")
        print(f"[kaudit] rootfs_mode: {selected_rootfs_mode}")
        print(f"[kaudit] kasan_detected: {kasan_hit}")
        return 0
    except Exception as exc:
        case = ensure_case_exists(ctx, case_id)
        case["last_repro_at"] = utc_now_iso()
        case["stage"] = "repro_failed"
        case.setdefault("repro_result", {})
        case["repro_result"] = {
            "returncode": None,
            "timed_out": False,
            "error": str(exc),
        }
        sync_case_status(case)
        save_case(ctx, case)
        campaign = ctx.load_campaign()
        refresh_campaign_metrics(ctx, campaign)
        ctx.save_campaign(campaign)
        return fail(str(exc))


def extract_kasan_excerpt(log_text: str, radius: int = 80) -> str:
    lines = log_text.splitlines()
    idx = -1
    for i, line in enumerate(lines):
        if re.search(r"BUG:\s+KASAN|KASAN:\s", line):
            idx = i
            break
    if idx < 0:
        return "(no explicit KASAN signature found in log)"

    start = max(0, idx - 20)
    end = min(len(lines), idx + radius)
    return "\n".join(lines[start:end])


def extract_kasan_full_log(log_text: str) -> str:
    lines = log_text.splitlines()
    idx = -1
    for i, line in enumerate(lines):
        if re.search(r"BUG:\s+KASAN|KASAN:\s", line):
            idx = i
            break
    if idx < 0:
        return log_text.strip()
    start = max(0, idx - 20)
    return "\n".join(lines[start:]).strip()


def build_compact_kasan_trace(excerpt: str, *, max_stack_frames: int = 12) -> str:
    lines = excerpt.splitlines()
    out: List[str] = []
    collecting_stack = False
    stack_count = 0
    for line in lines:
        text = line.rstrip()
        if not text:
            continue
        if re.search(r"BUG:\s+KASAN|KASAN:\s", text):
            out.append(text)
            continue
        if re.search(r"\b(Read|Write) of size\b", text):
            out.append(text)
            continue
        if "Oops:" in text or "general protection fault" in text:
            out.append(text)
            continue
        if "RIP:" in text and not collecting_stack:
            out.append(text)
            continue
        if "Call Trace:" in text:
            collecting_stack = True
            out.append(text)
            continue
        if collecting_stack:
            if re.search(r"\]\s+<?[A-Za-z0-9_\.]+\+0x", text):
                out.append(text)
                stack_count += 1
                if stack_count >= max_stack_frames:
                    break
    return "\n".join(out).strip() or excerpt.strip()


def read_text_snippet(path: Path, max_lines: int = 80) -> str:
    if not path.exists() or not path.is_file():
        return ""
    lines = path.read_text(encoding="utf-8", errors="replace").splitlines()
    if len(lines) <= max_lines:
        return "\n".join(lines)
    return "\n".join(lines[:max_lines] + ["/* truncated */"])


def build_poc_bundle(ctx: KernelAuditContext, case: Dict[str, Any]) -> Optional[Path]:
    poc_dir = ctx.case_dir(case["case_id"]) / "poc"
    if not poc_dir.exists():
        return None
    files = sorted(path for path in poc_dir.rglob("*") if path.is_file())
    if not files:
        return None
    bundle_path = ctx.reports_dir / f"{case['case_id']}-poc.tar.gz"
    with tarfile.open(bundle_path, "w:gz") as tar:
        for path in files:
            tar.add(path, arcname=f"{case['case_id']}/poc/{path.relative_to(poc_dir)}")
    return bundle_path


def build_poc_context(ctx: KernelAuditContext, case: Dict[str, Any], log_file: Path) -> Dict[str, Any]:
    poc_dir = ctx.case_dir(case["case_id"]) / "poc"
    poc_c = poc_dir / "poc.c"
    run_sh = poc_dir / "run.sh"
    bundle_path = build_poc_bundle(ctx, case)
    attachment_paths: List[str] = []
    if bundle_path and bundle_path.exists():
        attachment_paths.append(str(bundle_path))
    if log_file.exists():
        attachment_paths.append(str(log_file))
    return {
        "bundle_path": str(bundle_path) if bundle_path and bundle_path.exists() else "",
        "attachment_paths": attachment_paths,
        "poc_c_path": str(poc_c) if poc_c.exists() else "",
        "run_sh_path": str(run_sh) if run_sh.exists() else "",
        "poc_c_excerpt": read_text_snippet(poc_c, max_lines=80),
        "run_sh_excerpt": read_text_snippet(run_sh, max_lines=40),
    }


def is_public_poc_safe(case: Dict[str, Any]) -> Tuple[bool, str]:
    combined = " ".join(
        [
            str(case.get("impact", "") or ""),
            str(case.get("root_cause", "") or ""),
            str(case.get("attack_scenario", "") or ""),
        ]
    ).lower()
    risky_markers = [
        "information disclosure",
        "infoleak",
        "memory disclosure",
        "disclose adjacent kernel memory",
        "direct privilege-escalation",
        "direct privilege escalation",
        "write primitive",
        "arbitrary write",
        "heap memory disclosure",
    ]
    for marker in risky_markers:
        if marker in combined:
            return False, f"Not inlining PoC because the case text indicates {marker} risk beyond a pure KASAN trigger."
    return True, "PoC appears to be KASAN-trigger-oriented and is suitable for public reproduction guidance."


def read_full_text_if_small(path: Path, *, max_lines: int = 500, max_chars: int = 40000) -> str:
    if not path.exists() or not path.is_file():
        return ""
    text = path.read_text(encoding="utf-8", errors="replace")
    if len(text) > max_chars:
        return ""
    lines = text.splitlines()
    if len(lines) > max_lines:
        return ""
    return text.strip()


def format_plain_code_block(title: str, content: str) -> str:
    text = str(content or "").rstrip()
    if not text:
        return ""
    return "\n".join([f"{title}:", "--- 8< ---", text, "--- >8 ---"])


def build_patch_sketch(case: Dict[str, Any]) -> str:
    target_path = next(iter(as_str_list(case.get("target_paths", []))), "")
    root_cause = str(case.get("root_cause", "") or "").lower()

    if target_path == "fs/adfs/map.c" and "nzones==0" in root_cause:
        return textwrap.dedent(
            """\
            --- a/fs/adfs/map.c
            +++ b/fs/adfs/map.c
            @@
             nzones = dr->nzones | (dr->nzones_high << 8);
            +if (!nzones)
            +    goto bad_disc;
             dm = kmalloc_array(nzones, sizeof(*dm), GFP_KERNEL);
             if (!dm)
                 goto nomem;
            """
        ).strip()

    if target_path == "fs/adfs/map.c" and "nzones==1" in root_cause:
        return textwrap.dedent(
            """\
            --- a/fs/adfs/map.c
            +++ b/fs/adfs/map.c
            @@
             dm[nzones - 1].dm_endbit = 32 + size;
            +if (dm[nzones - 1].dm_endbit > (sb->s_blocksize * 8))
            +    goto bad_disc;
            """
        ).strip()

    if target_path == "fs/adfs/dir_fplus.c":
        return textwrap.dedent(
            """\
            --- a/fs/adfs/dir_fplus.c
            +++ b/fs/adfs/dir_fplus.c
            @@
             name_len = bigdirobnamelen;
            +if (name_len > ADFS_MAX_NAME_LEN)
            +    return -EFSCORRUPTED;
            +if (name_ptr + name_len > names_end)
            +    return -EFSCORRUPTED;
             adfs_dir_copyfrom(obj->name, src, name_len);
            """
        ).strip()

    if target_path == "fs/affs/dir.c":
        return textwrap.dedent(
            """\
            --- a/fs/affs/dir.c
            +++ b/fs/affs/dir.c
            @@ -119,6 +119,8 @@ affs_readdir(struct file *file, struct dir_context *ctx)
             		pr_debug("readdir() left off=%d\\n", ino);
             		goto inside;
             	}
            +	if (hash_pos >= AFFS_SB(sb)->s_hashsize)
            +		goto done;
             
             	ino = be32_to_cpu(AFFS_HEAD(dir_bh)->table[hash_pos]);
             	for (i = 0; ino && i < chain_pos; i++) {
            """
        ).strip()

    if target_path == "fs/orangefs/xattr.c":
        return textwrap.dedent(
            """\
            --- a/fs/orangefs/xattr.c
            +++ b/fs/orangefs/xattr.c
            @@ -188,6 +188,10 @@ ssize_t orangefs_inode_getxattr(struct inode *inode, const char *name,
             	 * Length returned includes null terminator.
             	 */
             	length = new_op->downcall.resp.getxattr.val_sz;
            +	if (length < 0 || length > ORANGEFS_MAX_XATTR_VALUELEN) {
            +		ret = -EIO;
            +		goto out_release_op;
            +	}
             
             	/*
             	 * Just return the length of the queried attribute.
            """
        ).strip()

    if target_path == "net/6lowpan/nhc_udp.c":
        return textwrap.dedent(
            """\
            --- a/net/6lowpan/nhc_udp.c
            +++ b/net/6lowpan/nhc_udp.c
            @@ -114,6 +114,9 @@ static int udp_compress(struct sk_buff *skb, u8 **hc_ptr)
             static int udp_compress(struct sk_buff *skb, u8 **hc_ptr)
             {
            +	if (skb_transport_offset(skb) + sizeof(struct udphdr) > skb->len)
            +		return -EINVAL;
            +
             	const struct udphdr *uh = udp_hdr(skb);
             	u8 tmp;
            """
        ).strip()

    if target_path == "fs/bfs/file.c":
        return textwrap.dedent(
            """\
            --- a/fs/bfs/file.c
            +++ b/fs/bfs/file.c
            @@
            -    err = bfs_move_block(sb, i, where + i);
            +    if (where + (i - start) >= info->si_blocks)
            +        return -ENOSPC;
            +    err = bfs_move_block(sb, i, where + (i - start));
            """
        ).strip()

    if target_path == "fs/efs/symlink.c":
        return textwrap.dedent(
            """\
            --- a/fs/efs/symlink.c
            +++ b/fs/efs/symlink.c
            @@
            -efs_block_t size = inode->i_size;
            +u64 raw_size = inode->i_size;
            +if (raw_size > 2 * EFS_BLOCKSIZE - 1)
            +    return -EFSCORRUPTED;
            +efs_block_t size = raw_size;
            """
        ).strip()

    if target_path == "fs/freevxfs/vxfs_immed.c":
        return textwrap.dedent(
            """\
            --- a/fs/freevxfs/vxfs_immed.c
            +++ b/fs/freevxfs/vxfs_immed.c
            @@
            +if (inode->i_size > VXFS_NIMMED)
            +    return -EFSCORRUPTED;
             src = vip->vii_immed.vi_immed + folio_pos(folio);
            -memcpy(dst, src, PAGE_SIZE);
            +memcpy(dst, src, min_t(size_t, inode->i_size - folio_pos(folio), PAGE_SIZE));
            """
        ).strip()

    return textwrap.dedent(
        f"""\
        --- a/{target_path or 'kernel/unknown.c'}
        +++ b/{target_path or 'kernel/unknown.c'}
        @@
        +/* validate attacker-controlled size/offset/count fields before dereference/copy */
        +/* reject malformed state early with -EINVAL/-EIO/-EFSCORRUPTED as appropriate */
        """
    ).strip()


def infer_public_required_config(case: Dict[str, Any]) -> List[str]:
    required = case_effective_required_config(case)
    target_path = next(iter(as_str_list(case.get("target_paths", []))), "")
    inferred: List[str] = ["CONFIG_KASAN=y"]
    if target_path.startswith("fs/"):
        inferred.append("CONFIG_BLK_DEV_LOOP=y")
    fs_map = {
        "fs/adfs/": "CONFIG_ADFS_FS=y",
        "fs/affs/": "CONFIG_AFFS_FS=y",
        "fs/bfs/": "CONFIG_BFS_FS=y",
        "fs/efs/": "CONFIG_EFS_FS=y",
        "fs/freevxfs/": "CONFIG_VXFS_FS=y",
    }
    for prefix, config in fs_map.items():
        if target_path.startswith(prefix):
            inferred.append(config)
            break
    return merge_required_config(required, inferred)


def validate_patch_text(ctx: KernelAuditContext, patch_text: str) -> Dict[str, Any]:
    result = {
        "apply_check_ok": False,
        "error": "",
    }
    text = str(patch_text or "").strip()
    if not text.startswith("--- a/"):
        result["error"] = "patch text is not a unified diff"
        return result
    proc = run_cmd(
        ["git", "apply", "--check", "-"],
        cwd=ctx.repo_root,
        check=False,
        input_text=text + "\n",
    )
    result["apply_check_ok"] = proc.returncode == 0
    if proc.returncode != 0:
        result["error"] = proc.stdout.strip()[-2000:]
    return result


def build_public_report_artifacts(
    ctx: KernelAuditContext,
    case: Dict[str, Any],
    log_file: Path,
) -> Dict[str, Any]:
    case_id = str(case["case_id"])
    public_dir = ctx.public_reports_dir
    public_dir.mkdir(parents=True, exist_ok=True)

    safe_to_publish, safe_reason = is_public_poc_safe(case)
    poc_dir = ctx.case_dir(case_id) / "poc"
    poc_c_path = poc_dir / "poc.c"
    run_sh_path = poc_dir / "run.sh"

    reproducer_path = public_dir / f"{case_id}.reproducer.c"
    console_path = public_dir / f"{case_id}.console.txt"
    kasan_log_path = public_dir / f"{case_id}.kasan-log.txt"
    config_path = public_dir / f"{case_id}.kernel.config"
    config_summary_path = public_dir / f"{case_id}.config.txt"
    qemu_cmd_path = public_dir / f"{case_id}.qemu.txt"
    patch_path = public_dir / f"{case_id}.patch.diff"
    manifest_path = public_dir / f"{case_id}.manifest.txt"

    config_lines = infer_public_required_config(case)
    config_summary_text = "\n".join(
        [
            "# Minimum config options required for reproducing the attached KASAN report",
            f"# Full campaign build config: {ctx.build_dir / '.config'}",
            *config_lines,
            "",
        ]
    )
    write_text(config_summary_path, config_summary_text)

    full_log_text = log_file.read_text(encoding="utf-8", errors="replace")
    write_text(console_path, full_log_text)
    write_text(kasan_log_path, extract_kasan_full_log(full_log_text) + "\n")

    build_config_path = ctx.build_dir / ".config"
    if build_config_path.exists():
        write_text(config_path, build_config_path.read_text(encoding="utf-8", errors="replace"))
    else:
        write_text(config_path, config_summary_text)

    patch_text = build_patch_sketch(case).strip() + "\n"
    write_text(patch_path, patch_text)
    patch_validation = validate_patch_text(ctx, patch_text)

    last_qemu_cmd = case.get("last_qemu_cmd", [])
    qemu_cmd_text = ""
    if isinstance(last_qemu_cmd, list) and last_qemu_cmd:
        qemu_cmd_text = shlex.join(str(part) for part in last_qemu_cmd)
    elif last_qemu_cmd:
        qemu_cmd_text = str(last_qemu_cmd)
    if qemu_cmd_text:
        write_text(qemu_cmd_path, qemu_cmd_text + "\n")
    else:
        write_text(qemu_cmd_path, "# last_qemu_cmd not recorded for this case\n")

    inline_poc = ""
    inline_run_sh = ""
    if safe_to_publish and poc_c_path.exists():
        poc_text = poc_c_path.read_text(encoding="utf-8", errors="replace")
        write_text(reproducer_path, poc_text)
        inline_poc = read_full_text_if_small(poc_c_path)
        inline_run_sh = read_full_text_if_small(run_sh_path, max_lines=160, max_chars=20000)
    else:
        if reproducer_path.exists():
            reproducer_path.unlink()

    manifest_lines = [
        f"Case ID: {case_id}",
        "",
        "Upload targets for public mail body placeholders:",
        f"- C reproducer: {reproducer_path if safe_to_publish and reproducer_path.exists() else '(withheld: see rationale below)'}",
        f"- console output: {console_path}",
        f"- KASAN log: {kasan_log_path}",
        f"- kernel config: {config_path}",
        f"- kernel config summary: {config_summary_path}",
        f"- QEMU command / boot args: {qemu_cmd_path}",
        f"- root-cause patch sketch: {patch_path}",
        f"- patch apply check: {'ok' if patch_validation.get('apply_check_ok') else 'failed'}",
        "",
        f"PoC publication assessment: {'safe' if safe_to_publish else 'withheld'}",
        f"Reason: {safe_reason}",
        f"Patch validation error: {patch_validation.get('error') or '(none)'}",
        "",
    ]
    write_text(manifest_path, "\n".join(manifest_lines))

    return {
        "poc_public_safe": safe_to_publish,
        "poc_public_safe_reason": safe_reason,
        "reproducer_c_path": str(reproducer_path) if safe_to_publish and reproducer_path.exists() else "",
        "console_output_path": str(console_path),
        "kasan_log_path": str(kasan_log_path),
        "kernel_config_path": str(config_path),
        "kernel_config_summary_path": str(config_summary_path),
        "qemu_cmd_path": str(qemu_cmd_path),
        "patch_path": str(patch_path),
        "patch_apply_check_ok": bool(patch_validation.get("apply_check_ok")),
        "patch_apply_check_error": str(patch_validation.get("error") or ""),
        "manifest_path": str(manifest_path),
        "required_config": config_lines,
        "inline_poc_c": inline_poc,
        "inline_run_sh": inline_run_sh,
        "inline_patch": patch_text.strip(),
    }


def render_email_poc_section(poc_context: Dict[str, Any]) -> str:
    lines: List[str] = []
    for idx, path in enumerate(as_str_list(poc_context.get("attachment_paths", []))):
        if idx == 0:
            lines.append("Suggested attachments:")
        lines.append(f"- {path}")

    poc_c_excerpt = str(poc_context.get("poc_c_excerpt", "") or "").strip()
    if poc_c_excerpt:
        if lines:
            lines.append("")
        lines.append("Inline PoC excerpt (poc.c):")
        lines.append("```c")
        lines.append(poc_c_excerpt)
        lines.append("```")

    run_sh_excerpt = str(poc_context.get("run_sh_excerpt", "") or "").strip()
    if run_sh_excerpt:
        if lines:
            lines.append("")
        lines.append("Guest runner excerpt (run.sh):")
        lines.append("```sh")
        lines.append(run_sh_excerpt)
        lines.append("```")

    return "\n".join(lines).strip()


def render_markdown_poc_section(poc_context: Dict[str, Any]) -> str:
    lines: List[str] = []
    attachment_paths = as_str_list(poc_context.get("attachment_paths", []))
    if attachment_paths:
        lines.append("## Suggested Attachments")
        for path in attachment_paths:
            lines.append(f"- `{path}`")

    poc_c_excerpt = str(poc_context.get("poc_c_excerpt", "") or "").strip()
    if poc_c_excerpt:
        if lines:
            lines.append("")
        lines.append("## Inline PoC Excerpt")
        lines.append("```c")
        lines.append(poc_c_excerpt)
        lines.append("```")

    run_sh_excerpt = str(poc_context.get("run_sh_excerpt", "") or "").strip()
    if run_sh_excerpt:
        if lines:
            lines.append("")
        lines.append("## Guest Runner Excerpt")
        lines.append("```sh")
        lines.append(run_sh_excerpt)
        lines.append("```")

    return "\n".join(lines).strip()


def cmd_report(ctx: KernelAuditContext, args: argparse.Namespace) -> int:
    ctx.ensure_layout()
    case = ensure_case_exists(ctx, args.case_id)

    if bool(getattr(args, "dup_check", False)):
        dup_result = run_pre_disclosure_check(
            ctx,
            case,
            refresh=bool(getattr(args, "dup_refresh", False)),
            hard_threshold=float(getattr(args, "dup_hard_threshold", PRE_DISCLOSE_HARD_THRESHOLD_DEFAULT)),
            soft_threshold=float(getattr(args, "dup_soft_threshold", PRE_DISCLOSE_SOFT_THRESHOLD_DEFAULT)),
            max_results=max(1, as_int(getattr(args, "dup_max_results", PRE_DISCLOSE_MAX_RESULTS_DEFAULT), PRE_DISCLOSE_MAX_RESULTS_DEFAULT)),
            live_syzbot=bool(getattr(args, "dup_live_syzbot", True)),
        )
        case["pre_disclosure_check"] = dup_result
        save_case(ctx, case)
        print(f"[kaudit] attached pre-disclosure check: verdict={dup_result.get('verdict')}")
        print(f"[kaudit] pre-disclosure summary: {dup_result.get('summary')}")
        case = ensure_case_exists(ctx, args.case_id)

    log_path = case.get("qemu_log")
    if not log_path:
        return fail("case has no qemu_log. run repro first")
    log_file = Path(log_path)
    if not log_file.exists():
        return fail(f"qemu log file missing: {log_file}")

    log_text = log_file.read_text(encoding="utf-8", errors="replace")
    excerpt = extract_kasan_excerpt(log_text)

    case_id = case["case_id"]
    report_path = ctx.reports_dir / f"{case_id}.md"
    email_path = ctx.reports_dir / f"{case_id}.eml"
    disclosure = generate_disclosure_for_case(ctx, case, excerpt, args)
    poc_context = build_poc_context(ctx, case, log_file)
    report = build_markdown_report(ctx, case, excerpt, disclosure, log_file, poc_context)
    email_text = build_email_report(ctx, case, excerpt, disclosure, log_file, poc_context)

    write_text(report_path, report)
    write_text(email_path, email_text)
    case["report_path"] = str(report_path)
    case["email_report_path"] = str(email_path)
    case["poc_bundle_path"] = str(poc_context.get("bundle_path", "") or "")
    case["disclosure"] = disclosure
    if case_stage(case) == "confirmed":
        case["stage"] = "reported"
        sync_case_status(case)
    case["last_report_at"] = utc_now_iso()
    save_case(ctx, case)

    campaign = ctx.load_campaign()
    refresh_campaign_metrics(ctx, campaign)
    ctx.save_campaign(campaign)

    print(f"[kaudit] report generated: {report_path}")
    print(f"[kaudit] email draft: {email_path}")
    return 0


def cmd_pre_disclose_check(ctx: KernelAuditContext, args: argparse.Namespace) -> int:
    ctx.ensure_layout()
    ensure_default_files(ctx)
    case = ensure_case_exists(ctx, args.case_id)
    result = run_pre_disclosure_check(
        ctx,
        case,
        refresh=bool(getattr(args, "refresh", True)),
        hard_threshold=float(getattr(args, "hard_threshold", PRE_DISCLOSE_HARD_THRESHOLD_DEFAULT)),
        soft_threshold=float(getattr(args, "soft_threshold", PRE_DISCLOSE_SOFT_THRESHOLD_DEFAULT)),
        max_results=max(1, as_int(getattr(args, "max_results", PRE_DISCLOSE_MAX_RESULTS_DEFAULT), PRE_DISCLOSE_MAX_RESULTS_DEFAULT)),
        live_syzbot=bool(getattr(args, "live_syzbot", True)),
    )
    snapshot_path = write_pre_disclose_case_snapshot(ctx, case, result)
    result["snapshot_path"] = str(snapshot_path)
    case["pre_disclosure_check"] = result
    save_case(ctx, case)

    if bool(getattr(args, "json", False)):
        print(json.dumps(result, indent=2, sort_keys=True))
        return 0

    print("[kaudit] pre-disclosure check")
    print(f"- case_id: {case['case_id']}")
    print(f"- verdict: {result.get('verdict')}")
    print(f"- summary: {result.get('summary')}")
    print(f"- checked_at: {result.get('checked_at')}")
    print(f"- knowledge_refreshed_at: {result.get('knowledge_refreshed_at')}")
    print(f"- snapshot: {snapshot_path}")
    best = result.get("best_match") if isinstance(result.get("best_match"), dict) else None
    if best:
        print("- best_match:")
        print(f"  - source: {best.get('source')}")
        print(f"  - id: {best.get('id')}")
        print(f"  - title: {best.get('title')}")
        print(f"  - score: {best.get('score')}")
        if best.get("url"):
            print(f"  - url: {best.get('url')}")
    for key in ("knowledge", "live_syzbot", "git_commits", "local_cases"):
        matches = result.get("results", {}).get(key, []) if isinstance(result.get("results"), dict) else []
        print(f"- {key}: {len(matches)}")
        for item in matches[: max(0, min(len(matches), 3))]:
            print(f"  - {item.get('source')}:{item.get('id')} score={item.get('score')} title={item.get('title')}")
    errors = result.get("errors", []) if isinstance(result.get("errors"), list) else []
    if errors:
        print("- errors:")
        for err in errors:
            print(f"  - {err}")
    return 0


def cmd_pre_disclose_batch(ctx: KernelAuditContext, args: argparse.Namespace) -> int:
    ctx.ensure_layout()
    ensure_default_files(ctx)
    stages = {
        s.strip()
        for s in str(getattr(args, "stages", PRE_DISCLOSE_BATCH_STAGES_DEFAULT) or PRE_DISCLOSE_BATCH_STAGES_DEFAULT).split(",")
        if s.strip()
    }
    if not stages:
        return fail("--stages must include at least one stage")
    candidates = [case for case in collect_case_paths(ctx)]
    selected: List[Dict[str, Any]] = []
    for case_path in candidates:
        case = normalize_case(read_json(case_path, {}))
        if case_stage(case) in stages:
            selected.append(case)
    selected.sort(key=lambda item: str(item.get("last_report_at", item.get("last_repro_at", item.get("created_at", "")))), reverse=True)
    limit = max(0, as_int(getattr(args, "limit", 0), 0))
    if limit:
        selected = selected[:limit]
    if not selected:
        print("[kaudit] pre-disclosure batch: no matching cases")
        return 0

    verdict_counts: Dict[str, int] = {}
    rows: List[Dict[str, Any]] = []
    for case in selected:
        result = run_pre_disclosure_check(
            ctx,
            case,
            refresh=bool(getattr(args, "refresh", True)),
            hard_threshold=float(getattr(args, "hard_threshold", PRE_DISCLOSE_HARD_THRESHOLD_DEFAULT)),
            soft_threshold=float(getattr(args, "soft_threshold", PRE_DISCLOSE_SOFT_THRESHOLD_DEFAULT)),
            max_results=max(1, as_int(getattr(args, "max_results", PRE_DISCLOSE_MAX_RESULTS_DEFAULT), PRE_DISCLOSE_MAX_RESULTS_DEFAULT)),
            live_syzbot=bool(getattr(args, "live_syzbot", True)),
        )
        case["pre_disclosure_check"] = result
        save_case(ctx, case)
        verdict = str(result.get("verdict", "unchecked") or "unchecked")
        verdict_counts[verdict] = verdict_counts.get(verdict, 0) + 1
        rows.append(
            {
                "case_id": case["case_id"],
                "stage": case_stage(case),
                "verdict": verdict,
                "summary": str(result.get("summary", "") or ""),
                "best_match": result.get("best_match"),
            }
        )

    payload = {
        "generated_at": utc_now_iso(),
        "stages": sorted(stages),
        "refresh": bool(getattr(args, "refresh", True)),
        "live_syzbot": bool(getattr(args, "live_syzbot", True)),
        "counts": verdict_counts,
        "results": rows,
    }
    json_path, md_path = write_pre_disclose_batch_snapshot(ctx, payload)

    if bool(getattr(args, "json", False)):
        print(json.dumps(payload, indent=2, sort_keys=True))
        return 0

    print("[kaudit] pre-disclosure batch")
    print(f"- stages: {', '.join(sorted(stages))}")
    print(f"- scanned: {len(rows)}")
    print(f"- snapshot_json: {json_path}")
    print(f"- snapshot_md: {md_path}")
    for verdict, count in sorted(verdict_counts.items()):
        print(f"- {verdict}: {count}")
    print("- results:")
    for row in rows:
        best = row.get("best_match") if isinstance(row.get("best_match"), dict) else None
        best_text = ""
        if best:
            best_text = f" best={best.get('source')}:{best.get('id')} score={best.get('score')}"
        print(f"  - {row['case_id']} stage={row['stage']} verdict={row['verdict']}{best_text}")
        print(f"    {row['summary']}")
    return 0


def collect_cases_by_stage(ctx: KernelAuditContext, stages: Set[str]) -> List[Dict[str, Any]]:
    cases: List[Dict[str, Any]] = []
    for case_path in collect_case_paths(ctx):
        case = normalize_case(read_json(case_path, {}))
        if case_stage(case) in stages:
            cases.append(case)
    cases.sort(key=lambda item: str(item.get("created_at", "")))
    return cases


def update_pipeline_snapshot(
    ctx: KernelAuditContext,
    *,
    target: str,
    audit_queue: Optional[List[str]] = None,
    active_jobs: Optional[List[Dict[str, Any]]] = None,
    completed_jobs: Optional[List[Dict[str, Any]]] = None,
) -> Dict[str, Any]:
    state = load_pipeline_state(ctx)
    state["iteration"] = as_int(state.get("iteration", 0), 0) + 1
    state["last_iteration_at"] = utc_now_iso()
    if audit_queue is not None:
        state["audit_queue"] = audit_queue
    state["verify_queue"] = [case["case_id"] for case in collect_cases_by_stage(ctx, {"discovered"})]
    state["repro_queue"] = [case["case_id"] for case in collect_cases_by_stage(ctx, {"repro_queued", "repro_failed"})]
    state["report_queue"] = [case["case_id"] for case in collect_cases_by_stage(ctx, {"confirmed"})]
    if active_jobs is not None:
        state["active_jobs"] = active_jobs
    if completed_jobs is not None:
        state["completed_jobs"] = completed_jobs[-50:]
    state["target"] = target
    save_pipeline_state(ctx, state)
    return state


def apply_verification_to_case(case: Dict[str, Any], result: Dict[str, Any]) -> Dict[str, Any]:
    case = normalize_case(case)
    verdict = str(result.get("verdict", "reject") or "reject").strip().lower()
    if verdict not in {"reject", "manual_only", "repro_ready"}:
        verdict = "reject"

    case["verification"] = {
        "verdict": verdict,
        "confidence": round(max(0.0, min(1.0, as_float(result.get("confidence", 0.0), 0.0))), 4),
        "proof": str(result.get("proof", "") or ""),
        "duplicate_analysis": str(result.get("duplicate_analysis", "") or ""),
        "trigger_contract": str(result.get("trigger_contract", "") or ""),
        "repro_requirements": str(result.get("repro_requirements", "") or ""),
        "auto_repro_supported": bool(result.get("auto_repro_supported", False)),
        "manual_constraints": str(result.get("manual_constraints", "") or ""),
    }
    case["root_cause"] = str(result.get("root_cause", "") or case.get("root_cause", ""))
    case["impact"] = str(result.get("impact", "") or case.get("impact", ""))
    case["attack_scenario"] = str(result.get("attack_scenario", "") or case.get("attack_scenario", ""))
    case["required_config"] = merge_required_config(case.get("required_config", []), as_str_list(result.get("required_config", [])))

    if verdict == "reject":
        case["stage"] = "rejected"
    elif verdict == "manual_only" or not bool(result.get("auto_repro_supported", False)):
        case["stage"] = "manual_only"
    else:
        case["stage"] = "repro_queued"
    sync_case_status(case)
    case["last_verified_at"] = utc_now_iso()
    return case


def run_verify_case(ctx: KernelAuditContext, case: Dict[str, Any], args: argparse.Namespace) -> Dict[str, Any]:
    payload = {
        "pipeline_version": PIPELINE_VERSION,
        "repo_root": str(ctx.repo_root),
        "case_path": str(ctx.case_json_path(case["case_id"])),
        "knowledge_paths": {
            "snapshot": str(ctx.knowledge_snapshot_path),
            "syzbot": str(ctx.syzbot_path),
            "cve": str(ctx.cve_path),
        },
        "case": case,
    }
    result = run_codex_worker_json(
        ctx,
        ctx.prompt_name("verify"),
        VERIFY_SCHEMA_NAME,
        payload,
        label=case["case_id"],
        stage="verify",
        model=str(getattr(args, "worker_model", "") or ""),
        reasoning_effort=str(
            getattr(args, "worker_reasoning_effort", CODEX_WORKER_REASONING_DEFAULT) or CODEX_WORKER_REASONING_DEFAULT
        ),
        timeout=max(120, as_int(getattr(args, "worker_timeout", CODEX_WORKER_TIMEOUT_DEFAULT), CODEX_WORKER_TIMEOUT_DEFAULT)),
        case_id=case["case_id"],
    )
    case = apply_verification_to_case(case, result)
    save_case(ctx, case)
    return case


def cmd_verify(ctx: KernelAuditContext, args: argparse.Namespace) -> int:
    ctx.ensure_layout()
    ensure_default_files(ctx)
    case = ensure_case_exists(ctx, args.case_id)
    case = run_verify_case(ctx, case, args)
    print(f"[kaudit] verify complete for {case['case_id']}")
    print(f"[kaudit] verdict: {case.get('verification', {}).get('verdict')}")
    print(f"[kaudit] stage: {case.get('stage')}")
    return 0


def run_verify_batch(ctx: KernelAuditContext, args: argparse.Namespace) -> List[str]:
    limit = max(1, as_int(getattr(args, "verify_workers", DEFAULT_VERIFY_WORKERS), DEFAULT_VERIFY_WORKERS))
    pending = sorted(
        collect_cases_by_stage(ctx, {"discovered"}),
        key=lambda item: str(item.get("created_at", "")),
        reverse=not bool(getattr(args, "oldest_first", False)),
    )[:limit]
    if not pending:
        return []

    verified_ids: List[str] = []
    with concurrent.futures.ThreadPoolExecutor(max_workers=max(1, limit)) as pool:
        futures = {pool.submit(run_verify_case, ctx, case, args): case["case_id"] for case in pending}
        for future in concurrent.futures.as_completed(futures):
            case_id = futures[future]
            try:
                case = future.result()
            except Exception as exc:
                print(f"[kaudit] verify worker failed for {case_id}: {exc}")
                continue
            verified_ids.append(case["case_id"])
            print(
                f"[kaudit] verify verdict: {case['case_id']} -> {case.get('verification', {}).get('verdict')} "
                f"(stage={case.get('stage')})"
            )
    return verified_ids


def apply_repro_plan_to_case(case: Dict[str, Any], plan: Dict[str, Any]) -> Dict[str, Any]:
    case = normalize_case(case)
    trigger = case.get("trigger", {})
    if not isinstance(trigger, dict):
        trigger = deep_copy_json(CASE_TEMPLATE["trigger"])
    trigger["description"] = "Auto-generated by repro planning worker."
    trigger["command"] = str(plan.get("command", "") or "")
    trigger["source_c"] = str(plan.get("source_c", "") or "")
    trigger["run_script"] = str(plan.get("run_script", "") or "")
    case["trigger"] = trigger

    case["repro_plan"] = {
        "supported": bool(plan.get("supported", False)),
        "rootfs_mode": str(plan.get("rootfs_mode", "auto") or "auto"),
        "reasoning": str(plan.get("reasoning", "") or ""),
        "required_config": merge_required_config(as_str_list(plan.get("required_config", []))),
        "why_self_contained": str(plan.get("why_self_contained", "") or ""),
        "compile_strategy": str(plan.get("compile_strategy", "") or ""),
    }
    case["required_config"] = merge_required_config(case.get("required_config", []), case["repro_plan"]["required_config"])
    return case


def plan_repro_for_case(
    ctx: KernelAuditContext,
    case: Dict[str, Any],
    *,
    args: argparse.Namespace,
    attempt_index: int,
    last_feedback: str,
) -> Dict[str, Any]:
    payload = {
        "pipeline_version": PIPELINE_VERSION,
        "repo_root": str(ctx.repo_root),
        "case_path": str(ctx.case_json_path(case["case_id"])),
        "case": case,
        "attempt_index": attempt_index,
        "last_feedback": last_feedback,
        "rootfs_modes": ["auto", "busybox", "debian"],
    }
    return run_codex_worker_json(
        ctx,
        ctx.prompt_name("repro"),
        REPRO_SCHEMA_NAME,
        payload,
        label=f"{case['case_id']}-attempt-{attempt_index}",
        stage="repro-plan",
        model=str(getattr(args, "worker_model", "") or ""),
        reasoning_effort=str(
            getattr(args, "worker_reasoning_effort", CODEX_WORKER_REASONING_DEFAULT) or CODEX_WORKER_REASONING_DEFAULT
        ),
        timeout=max(120, as_int(getattr(args, "worker_timeout", CODEX_WORKER_TIMEOUT_DEFAULT), CODEX_WORKER_TIMEOUT_DEFAULT)),
        case_id=case["case_id"],
    )


def extract_repro_feedback(case: Dict[str, Any]) -> str:
    qemu_log = str(case.get("qemu_log", "") or "")
    if qemu_log and Path(qemu_log).exists():
        text = Path(qemu_log).read_text(encoding="utf-8", errors="replace")
        excerpt = extract_kasan_excerpt(text)
        if excerpt and "no explicit KASAN signature" not in excerpt:
            return excerpt
        lines = text.splitlines()
        return "\n".join(lines[-80:])
    repro_result = case.get("repro_result", {}) if isinstance(case.get("repro_result"), dict) else {}
    return json.dumps(repro_result, indent=2, sort_keys=True)


def repro_requires_manual_validation(case: Dict[str, Any]) -> str:
    verification = case.get("verification", {}) if isinstance(case.get("verification"), dict) else {}
    haystacks = [
        str(case.get("impact", "") or ""),
        str(verification.get("repro_requirements", "") or ""),
        str(verification.get("trigger_contract", "") or ""),
        str(case.get("root_cause", "") or ""),
    ]
    combined = "\n".join(haystacks).lower()
    if "kasan is not expected" in combined:
        return "Verifier states that KASAN is not the right success signal for this case; manual validation is required."
    if "success should be defined as deterministic userspace observation" in combined:
        return "Verifier requires userspace disclosure observation instead of KASAN; keeping the case manual_only."
    if "information disclosure" in combined or "infoleak" in combined:
        if "kasan" not in combined or "not expected" in combined:
            return "This case is framed as an information disclosure path, so the automatic KASAN-only repro pipeline is not appropriate."
    return ""


def mark_case_repro_failure(case: Dict[str, Any], error: str, *, stage: str = "repro_failed") -> Dict[str, Any]:
    case = normalize_case(case)
    case["stage"] = stage
    sync_case_status(case)
    case.setdefault("repro_attempts", [])
    case["repro_attempts"].append(
        {
            "attempt": len(case["repro_attempts"]) + 1,
            "planned_at": utc_now_iso(),
            "kasan_detected": bool(case.get("kasan_detected", False)),
            "planner_error": error.strip(),
        }
    )
    case["repro_attempts"] = case["repro_attempts"][-10:]
    return case


def run_auto_repro_case(ctx: KernelAuditContext, case_id: str, args: argparse.Namespace) -> bool:
    current = ensure_case_exists(ctx, case_id)
    manual_reason = repro_requires_manual_validation(current)
    if manual_reason:
        current.setdefault("verification", {})
        current["verification"]["manual_constraints"] = manual_reason
        current["stage"] = "manual_only"
        sync_case_status(current)
        save_case(ctx, current)
        print(f"[kaudit] auto-repro deferred for {case_id}: {manual_reason}")
        return False

    max_attempts = max(1, as_int(getattr(args, "repro_attempts", 3), 3))
    last_feedback = ""
    for attempt_index in range(1, max_attempts + 1):
        case = ensure_case_exists(ctx, case_id)
        case["stage"] = "repro_running"
        sync_case_status(case)
        save_case(ctx, case)

        try:
            plan = plan_repro_for_case(ctx, case, args=args, attempt_index=attempt_index, last_feedback=last_feedback)
        except Exception as exc:
            case = ensure_case_exists(ctx, case_id)
            case = mark_case_repro_failure(case, f"repro planner failed: {exc}")
            save_case(ctx, case)
            print(f"[kaudit] auto-repro planner failed for {case_id}: {exc}")
            return False
        if not bool(plan.get("supported", False)):
            case["verification"]["manual_constraints"] = str(plan.get("manual_constraints", "") or "")
            case["stage"] = "manual_only"
            sync_case_status(case)
            save_case(ctx, case)
            print(f"[kaudit] auto-repro unsupported for {case_id}: {case['verification']['manual_constraints']}")
            return False

        case = apply_repro_plan_to_case(case, plan)
        case["stage"] = "repro_running"
        sync_case_status(case)
        save_case(ctx, case)

        repro_ns = argparse.Namespace(
            case_id=case_id,
            timeout=getattr(args, "repro_timeout", 240),
            jobs=getattr(args, "jobs", 0),
            skip_build=getattr(args, "repro_skip_build", False),
            rootfs_mode=case.get("repro_plan", {}).get("rootfs_mode", getattr(args, "rootfs_mode", "auto")),
            debian_suite=getattr(args, "debian_suite", "bookworm"),
            debian_mirror=getattr(args, "debian_mirror", "http://deb.debian.org/debian"),
            debian_include=getattr(args, "debian_include", "busybox,ca-certificates"),
            debian_force_cache=getattr(args, "debian_force_cache", False),
            auto_generate_trigger=False,
        )
        try:
            rc = cmd_repro(ctx, repro_ns)
        except Exception as exc:
            case = ensure_case_exists(ctx, case_id)
            case = mark_case_repro_failure(case, f"cmd_repro failed: {exc}")
            save_case(ctx, case)
            print(f"[kaudit] auto-repro execution failed for {case_id}: {exc}")
            return False
        case = ensure_case_exists(ctx, case_id)
        attempt_record = {
            "attempt": attempt_index,
            "planned_at": utc_now_iso(),
            "rootfs_mode": case.get("rootfs_mode") or case.get("repro_plan", {}).get("rootfs_mode", "auto"),
            "command": str(case.get("trigger", {}).get("command", "") or ""),
            "kasan_detected": bool(case.get("kasan_detected", False)),
            "qemu_log": case.get("qemu_log"),
            "returncode": case.get("repro_result", {}).get("returncode"),
            "timed_out": case.get("repro_result", {}).get("timed_out"),
            "planner_reasoning": str(plan.get("reasoning", "") or ""),
            "manual_constraints": str(plan.get("manual_constraints", "") or ""),
            "cmd_repro_rc": rc,
        }
        case.setdefault("repro_attempts", [])
        case["repro_attempts"].append(attempt_record)

        if bool(case.get("kasan_detected", False)):
            case["stage"] = "confirmed"
            sync_case_status(case)
            save_case(ctx, case)
            pipeline = load_pipeline_state(ctx)
            pipeline["last_successful_kasan_at"] = utc_now_iso()
            save_pipeline_state(ctx, pipeline)
            print(f"[kaudit] auto-repro confirmed: {case_id}")
            return True

        last_feedback = extract_repro_feedback(case)
        if attempt_index < max_attempts:
            case["stage"] = "repro_queued"
            sync_case_status(case)
            save_case(ctx, case)
        else:
            case["stage"] = "repro_failed"
            sync_case_status(case)
            save_case(ctx, case)

    print(f"[kaudit] auto-repro exhausted attempts for {case_id}")
    return False


def run_repro_batch(ctx: KernelAuditContext, args: argparse.Namespace) -> List[str]:
    limit = max(1, as_int(getattr(args, "repro_workers", DEFAULT_REPRO_WORKERS), DEFAULT_REPRO_WORKERS))
    pending, skipped_missing_config = select_repro_batch_cases(ctx, args, limit)
    confirmed_ids: List[str] = []
    for case_id, missing in skipped_missing_config:
        print(
            f"[kaudit] repro deferred for {case_id}: current bzImage is missing required config "
            f"({', '.join(missing)})"
        )

    def _run_one(case_id: str) -> Tuple[str, bool, Optional[str]]:
        try:
            confirmed = run_auto_repro_case(ctx, case_id, args)
            return case_id, confirmed, None
        except Exception as exc:
            current = ensure_case_exists(ctx, case_id)
            current = mark_case_repro_failure(current, f"unexpected repro-batch failure: {exc}")
            save_case(ctx, current)
            return case_id, False, str(exc)

    parallel_repro = bool(getattr(args, "repro_skip_build", False)) and limit > 1
    if limit > 1 and not parallel_repro:
        print(
            "[kaudit] repro parallelism disabled because shared build tree rebuild is unsafe; "
            "use --repro-skip-build after a fresh build to run multiple QEMU repro workers in parallel"
        )

    if parallel_repro:
        with concurrent.futures.ThreadPoolExecutor(max_workers=max(1, limit)) as pool:
            futures = {pool.submit(_run_one, case["case_id"]): case["case_id"] for case in pending}
            for future in concurrent.futures.as_completed(futures):
                case_id, confirmed, error = future.result()
                if error:
                    print(f"[kaudit] repro worker failed for {case_id}: {error}")
                    continue
                if confirmed:
                    confirmed_ids.append(case_id)
    else:
        for case in pending:
            case_id, confirmed, error = _run_one(case["case_id"])
            if error:
                print(f"[kaudit] repro worker failed for {case_id}: {error}")
                continue
            if confirmed:
                confirmed_ids.append(case_id)
    return confirmed_ids


def generate_disclosure_for_case(
    ctx: KernelAuditContext,
    case: Dict[str, Any],
    excerpt: str,
    args: argparse.Namespace,
) -> Dict[str, Any]:
    git_head = run_cmd(["git", "rev-parse", "HEAD"], cwd=ctx.repo_root, check=True).stdout.strip()
    if os.environ.get("KAUDIT_DISCLOSURE_LOCAL_ONLY", "").strip().lower() in {"1", "true", "yes", "on"}:
        return build_local_disclosure(case, excerpt, git_head)
    payload = {
        "pipeline_version": PIPELINE_VERSION,
        "repo_root": str(ctx.repo_root),
        "case": case,
        "kasan_excerpt": excerpt,
        "git_head": git_head,
    }
    try:
        result = run_codex_worker_json(
            ctx,
            ctx.prompt_name("disclosure"),
            DISCLOSURE_SCHEMA_NAME,
            payload,
            label=case["case_id"],
            stage="disclosure",
            model=str(getattr(args, "worker_model", "") or ""),
            reasoning_effort=str(
                getattr(args, "worker_reasoning_effort", CODEX_WORKER_REASONING_DEFAULT) or CODEX_WORKER_REASONING_DEFAULT
            ),
            timeout=max(
                120,
                as_int(getattr(args, "worker_timeout", CODEX_WORKER_TIMEOUT_DEFAULT), CODEX_WORKER_TIMEOUT_DEFAULT),
            ),
            case_id=case["case_id"],
        )
        disclosure = {
            "subject": str(result.get("subject", "") or ""),
            "to": as_str_list(result.get("to", [])),
            "cc": as_str_list(result.get("cc", [])),
            "body_text": str(result.get("body_text", "") or ""),
            "markdown_summary": str(result.get("markdown_summary", "") or ""),
        }
        if any(str(disclosure.get(key, "") or "").strip() for key in ("subject", "body_text", "markdown_summary")):
            return disclosure
        print(f"[kaudit] disclosure worker returned empty content for {case['case_id']}; using local fallback")
    except Exception as exc:
        print(f"[kaudit] disclosure worker failed for {case['case_id']}: {exc}; using local fallback")
    return build_local_disclosure(case, excerpt, git_head)


def build_local_disclosure(case: Dict[str, Any], excerpt: str, git_head: str) -> Dict[str, Any]:
    target_path = next(iter(as_str_list(case.get("target_paths", []))), "fs/")
    subsystem = infer_subsystem_from_target_path(target_path)
    fs_label = infer_component_label_from_target_path(target_path)
    domain_label = "filesystem" if target_path.startswith("fs/") else "networking" if target_path.startswith("net/") else "kernel subsystem"
    root_cause = str(case.get("root_cause", "") or case.get("verification", {}).get("proof", "") or "unknown root cause").strip()
    impact = str(case.get("impact", "") or "kernel crash / denial of service").strip()
    default_scenario = (
        "mounting a crafted filesystem image"
        if target_path.startswith("fs/")
        else "issuing attacker-controlled networking operations"
        if target_path.startswith("net/")
        else "running attacker-controlled local guest operations against the configured kernel surface"
    )
    scenario = str(case.get("attack_scenario", "") or default_scenario).strip()
    kernel_release = str(case.get("kernel_version", "") or "unknown").strip()
    trigger_cmd = str(case.get("trigger", {}).get("command", "") or "").strip() or "the generated trigger"
    kasan_line = ""
    for line in excerpt.splitlines():
        if "BUG: KASAN:" in line:
            kasan_line = line.strip()
            break
    kasan_kind = "KASAN-detected memory-safety failure"
    kasan_match = re.search(r"BUG: KASAN:\s*([^\n]+)", kasan_line)
    if kasan_match:
        kasan_kind = kasan_match.group(1).strip()
    route_hint = infer_route_hint_from_excerpt(excerpt, case)
    subject = f"[SECURITY] {target_path}: case-specific {fs_label} trigger causes {kasan_kind} during {route_hint}"

    if target_path.startswith("net/"):
        trigger_summary = f"the case-specific {fs_label} trigger sequence"
    else:
        trigger_summary = f"the case-specific {fs_label} image and trigger sequence"
    trigger_contract = str(case.get("verification", {}).get("trigger_contract", "") or "").strip()
    if "nzones=1" in trigger_contract or "nzones == 1" in trigger_contract:
        trigger_summary = "the case-specific one-zone ADFS image and trigger sequence"
    elif "nzones=0" in trigger_contract or "nzones == 0" in trigger_contract:
        trigger_summary = "the case-specific zero-zone ADFS image and trigger sequence"

    summary = textwrap.dedent(
        f"""\
Confirmed in QEMU with the campaign kernel and BusyBox initramfs. The guest reached `/init`,
executed `{trigger_cmd}`, and {trigger_summary} triggered `{kasan_kind}` during {route_hint} on kernel commit
`{git_head}` (`{kernel_release}`).
"""
    ).strip()
    body = textwrap.dedent(
        f"""\
Hello Linux kernel security team,

            I am reporting a {domain_label} vulnerability that was reproduced in QEMU with KASAN enabled.

Affected tree: linux-up / mainline-derived local tree
Git head: {git_head}
Kernel release: {kernel_release}
Subsystem: {subsystem}
Case ID: {case['case_id']}

Root cause:
{root_cause}

Impact:
{impact}

Attack scenario:
{scenario}

Reproduction summary:
            - Boot the provided bzImage with the generated BusyBox initramfs
            - Guest `/init` launches `{trigger_cmd}`
            - The PoC drives {trigger_summary}
            - A normal kernel operation triggers the KASAN report during {route_hint}

KASAN excerpt:
{excerpt}

Primary artifacts:
- QEMU log: {case.get('qemu_log') or ''}
- PoC artifacts: {", ".join(as_str_list(case.get('poc_artifacts', [])))}

This draft is plain text to match the kernel security reporting guidance. I have not publicly disclosed the issue.
"""
    ).strip()
    return {
        "subject": subject,
        "to": ["security@kernel.org"],
        "cc": [],
        "body_text": body,
        "markdown_summary": summary,
    }


def build_markdown_report(
    ctx: KernelAuditContext,
    case: Dict[str, Any],
    excerpt: str,
    disclosure: Dict[str, Any],
    log_file: Path,
    poc_context: Dict[str, Any],
) -> str:
    required_config = case_effective_required_config(case)
    kernel_version = case.get("kernel_version") or "unknown"
    root_cause = case.get("root_cause") or "unknown"
    impact = case.get("impact") or "unknown"
    scenario = case.get("attack_scenario") or "unknown"
    git_head = run_cmd(["git", "rev-parse", "HEAD"], cwd=ctx.repo_root, check=True).stdout.strip()
    summary = str(disclosure.get("markdown_summary", "") or "").strip()
    poc_section = render_markdown_poc_section(poc_context)

    report = textwrap.dedent(
        f"""\
# Kernel Vulnerability Report - {case['case_id']}

## Kernel Version
- git_head: {git_head}
- kernel_release: {kernel_version}

## Root Cause
{root_cause}

## KASAN Log (excerpt)
```text
{excerpt}
```

## Impact
{impact}

## Attack Scenario
{scenario}

## Required Config
{os.linesep.join(f'- {line}' for line in required_config) if required_config else '- CONFIG_KASAN=y (minimum baseline)'}

## Reproduction Steps
1. Ensure baseline artifacts exist: `./.omx/kernel-audit/bin/kaudit bootstrap`
2. Build kernel (if needed): `./.omx/kernel-audit/bin/kaudit build init`
3. Re-run case trigger: `./.omx/kernel-audit/bin/kaudit repro {case['case_id']}`
4. Inspect full log: `{log_file}`

## Disclosure Draft Summary
{summary or 'No additional disclosure summary.'}

{poc_section if poc_section else ''}

## Artifacts
- case_json: `{ctx.case_json_path(case['case_id'])}`
- qemu_log: `{log_file}`
- poc_artifacts: `{', '.join(case.get('poc_artifacts', []))}`
"""
    ).strip() + "\n"
    return report


def build_email_report(
    ctx: KernelAuditContext,
    case: Dict[str, Any],
    excerpt: str,
    disclosure: Dict[str, Any],
    log_file: Path,
    poc_context: Dict[str, Any],
) -> str:
    subject = disclosure.get("subject") or f"[SECURITY] kernel: {case['case_id']} potential memory corruption"
    to_line = ", ".join(as_str_list(disclosure.get("to", [])))
    cc_line = ", ".join(as_str_list(disclosure.get("cc", [])))
    body = str(disclosure.get("body_text", "") or "").strip()
    required_config = case_effective_required_config(case)
    if not body:
        body = textwrap.dedent(
            f"""\
            Hello kernel security team,

            I am reporting a candidate kernel vulnerability reproduced with KASAN.

            Case ID: {case['case_id']}
            Kernel release: {case.get('kernel_version') or 'unknown'}
            Git head: {run_cmd(['git', 'rev-parse', 'HEAD'], cwd=ctx.repo_root, check=True).stdout.strip()}

            Root cause:
            {case.get('root_cause') or 'unknown'}

            Impact:
            {case.get('impact') or 'unknown'}

            Attack scenario:
            {case.get('attack_scenario') or 'unknown'}

            KASAN excerpt:
            {excerpt}

            Repro:
            - ./.omx/kernel-audit/bin/kaudit repro {case['case_id']}
            - log: {log_file}
            """
        ).strip()
    if required_config:
        body = f"{body}\n\nRequired config:\n" + "\n".join(f"- {line}" for line in required_config)

    poc_section = render_email_poc_section(poc_context)
    if poc_section:
        body = f"{body}\n\n{poc_section}".strip()

    headers = [
        f"Subject: {subject}",
        f"To: {to_line}",
        f"Cc: {cc_line}",
        "MIME-Version: 1.0",
        "Content-Type: text/plain; charset=UTF-8",
        "",
    ]
    return "\n".join(headers) + body + "\n"


def build_public_mailing_payload(
    ctx: KernelAuditContext,
    case: Dict[str, Any],
    excerpt: str,
    log_file: Path,
) -> Dict[str, Any]:
    target_path = next(iter(as_str_list(case.get("target_paths", []))), "fs/")
    subsystem = infer_subsystem_from_target_path(target_path)
    domain_label = "filesystem" if target_path.startswith("fs/") else "networking" if target_path.startswith("net/") else "kernel"
    git_head = run_cmd(["git", "rev-parse", "HEAD"], cwd=ctx.repo_root, check=True).stdout.strip()
    kernel_release = str(case.get("kernel_version") or "unknown").strip()
    root_cause = str(case.get("root_cause") or case.get("verification", {}).get("proof") or "unknown").strip()
    route_hint = infer_route_hint_from_excerpt(excerpt, case)
    route_phrase = public_route_phrase(route_hint)
    crash_kind = extract_crash_kind(excerpt)
    crash_func = extract_crash_function(excerpt)
    recipients = suggest_public_recipients(ctx, target_path)
    subject = build_public_subject(case, excerpt)
    rootfs_mode = str(case.get("rootfs_mode") or "busybox").strip() or "busybox"
    artifacts = build_public_report_artifacts(ctx, case, log_file)
    config_lines = as_str_list(artifacts.get("required_config", []))
    reproducer_path = str(artifacts.get("reproducer_c_path", "") or "")
    poc_safe = bool(artifacts.get("poc_public_safe", False))
    poc_safe_reason = str(artifacts.get("poc_public_safe_reason", "") or "")
    compact_trace = build_compact_kasan_trace(excerpt)
    contact_name = os.environ.get("KAUDIT_PUBLIC_CONTACT_NAME", "Hyungjung Joo").strip() or "Hyungjung Joo"
    contact_email = os.environ.get("KAUDIT_PUBLIC_CONTACT_EMAIL", "jhj140711@gmail.com").strip() or "jhj140711@gmail.com"

    crash_line = crash_kind
    kind_has_function = bool(re.search(r"\bin [A-Za-z0-9_]+\+", crash_kind))
    if crash_func and not kind_has_function:
        crash_line = f"{crash_kind} in {crash_func}()"
    if route_phrase == "mount-time":
        observed = f"mount-time {crash_line}"
    else:
        observed = f"{crash_line} {route_phrase}"

    reproducer_line = "C reproducer: <pastebin url>"
    if not reproducer_path:
        reproducer_line = f"C reproducer: intentionally omitted from public mail ({poc_safe_reason})"

    body_lines = [
        "Hello,",
        "",
        f"I am reporting a {domain_label} bug reproduced on current mainline with",
        "KASAN enabled.",
        "",
        f"Target file: {target_path}",
        f"Subsystem: {subsystem}",
        f"Git head: {git_head}",
        f"Kernel release: {kernel_release}",
        "",
        "Root cause:",
        root_cause,
        "",
        "Reproducer",
        reproducer_line,
        "console output: <pastebin url>",
        "KASAN full log: <pastebin url>",
        "Kernel config: <pastebin url>",
        "QEMU command / boot args: <pastebin url>",
        "Root-cause patch sketch: <pastebin url>",
        "",
        "Key config options:",
        *(f"- {line}" for line in config_lines),
        "",
        "Brief KASAN call trace:",
        compact_trace,
        "",
        "Reproducibility notes:",
        f"- observed crash: {observed}",
        f"- rootfs mode: {rootfs_mode}",
        "- guest /init runs the case-specific trigger binary automatically",
        "",
        "If you need anything else, please let me know.",
        "Thank you.",
        "",
        "Best regards,",
        f"{contact_name}, {contact_email}",
        "",
    ]
    body = "\n".join(body_lines)
    email_text = "\n".join(
        [
            f"Subject: {subject}",
            f"To: {', '.join(recipients['to'])}",
            f"Cc: {', '.join(recipients['cc'])}",
            "MIME-Version: 1.0",
            "Content-Type: text/plain; charset=UTF-8",
            "",
            body,
            "",
        ]
    )
    return {
        "subject": subject,
        "to": recipients["to"],
        "cc": recipients["cc"],
        "body_text": body,
        "email_text": email_text,
        "artifacts": artifacts,
    }


def cmd_public_report(ctx: KernelAuditContext, args: argparse.Namespace) -> int:
    ctx.ensure_layout()
    case = ensure_case_exists(ctx, args.case_id)

    log_path = case.get("qemu_log")
    if not log_path:
        return fail("case has no qemu_log. run repro first")
    log_file = Path(log_path)
    if not log_file.exists():
        return fail(f"qemu log file missing: {log_file}")

    excerpt = extract_kasan_excerpt(log_file.read_text(encoding="utf-8", errors="replace"))
    payload = build_public_mailing_payload(ctx, case, excerpt, log_file)

    text_path = ctx.public_reports_dir / f"{case['case_id']}.txt"
    email_path = ctx.public_reports_dir / f"{case['case_id']}.eml"
    write_text(text_path, str(payload["body_text"]).strip() + "\n")
    write_text(email_path, str(payload["email_text"]).strip() + "\n")

    case["public_report_path"] = str(text_path)
    case["public_email_report_path"] = str(email_path)
    case["public_disclosure"] = {
        "subject": payload["subject"],
        "to": payload["to"],
        "cc": payload["cc"],
        "body_text": payload["body_text"],
        "poc_public_safe": bool(payload.get("artifacts", {}).get("poc_public_safe", False)),
        "poc_public_safe_reason": str(payload.get("artifacts", {}).get("poc_public_safe_reason", "") or ""),
        "reproducer_c_path": str(payload.get("artifacts", {}).get("reproducer_c_path", "") or ""),
        "console_output_path": str(payload.get("artifacts", {}).get("console_output_path", "") or ""),
        "kasan_log_path": str(payload.get("artifacts", {}).get("kasan_log_path", "") or ""),
        "kernel_config_path": str(payload.get("artifacts", {}).get("kernel_config_path", "") or ""),
        "qemu_cmd_path": str(payload.get("artifacts", {}).get("qemu_cmd_path", "") or ""),
        "patch_path": str(payload.get("artifacts", {}).get("patch_path", "") or ""),
        "manifest_path": str(payload.get("artifacts", {}).get("manifest_path", "") or ""),
    }
    save_case(ctx, case)

    print(f"[kaudit] public report generated: {text_path}")
    print(f"[kaudit] public email draft: {email_path}")
    return 0


def cmd_public_report_batch(ctx: KernelAuditContext, args: argparse.Namespace) -> int:
    ctx.ensure_layout()
    stages = {stage.strip() for stage in str(args.stages or "reported").split(",") if stage.strip()}
    if not stages:
        stages = {"reported"}
    cases = sorted(
        collect_cases_by_stage(ctx, stages),
        key=lambda item: str(item.get("last_report_at", item.get("created_at", ""))),
        reverse=not getattr(args, "oldest_first", False),
    )
    if args.limit and args.limit > 0:
        cases = cases[: args.limit]
    if not cases:
        print("[kaudit] public report batch: no matching cases")
        return 0

    generated: List[str] = []
    for case in cases:
        rc = cmd_public_report(ctx, argparse.Namespace(case_id=case["case_id"]))
        if rc == 0:
            generated.append(case["case_id"])

    print("[kaudit] public report batch")
    print(f"- generated: {len(generated)}")
    for case_id in generated:
        print(f"  - {case_id}")
    return 0


def run_report_batch(ctx: KernelAuditContext, args: argparse.Namespace) -> List[str]:
    limit = max(1, as_int(getattr(args, "report_workers", DEFAULT_REPORT_WORKERS), DEFAULT_REPORT_WORKERS))
    pending = sorted(
        collect_cases_by_stage(ctx, {"confirmed"}),
        key=lambda item: str(item.get("last_repro_at", item.get("created_at", ""))),
        reverse=not bool(getattr(args, "oldest_first", False)),
    )[:limit]
    reported: List[str] = []
    for case in pending:
        report_args = argparse.Namespace(
            case_id=case["case_id"],
            worker_model=str(getattr(args, "worker_model", "") or ""),
            worker_reasoning_effort=str(
                getattr(args, "worker_reasoning_effort", CODEX_WORKER_REASONING_DEFAULT)
                or CODEX_WORKER_REASONING_DEFAULT
            ),
            worker_timeout=max(
                120,
                as_int(getattr(args, "worker_timeout", CODEX_WORKER_TIMEOUT_DEFAULT), CODEX_WORKER_TIMEOUT_DEFAULT),
            ),
        )
        rc = cmd_report(ctx, report_args)
        if rc == 0:
            reported.append(case["case_id"])
            if bool(getattr(args, "auto_public_report", True)):
                public_rc = cmd_public_report(ctx, argparse.Namespace(case_id=case["case_id"]))
                if public_rc != 0:
                    print(f"[kaudit] public report generation failed for {case['case_id']}")
    return reported


def print_omx_snapshot(snapshot: Dict[str, Any], limit: int = 5) -> None:
    installed = snapshot.get("installed", {}) if isinstance(snapshot.get("installed"), dict) else {}
    github_latest = snapshot.get("github_latest", {}) if isinstance(snapshot.get("github_latest"), dict) else {}
    npm_latest = snapshot.get("npm_latest", {}) if isinstance(snapshot.get("npm_latest"), dict) else {}
    docs_summary = snapshot.get("docs_summary", {}) if isinstance(snapshot.get("docs_summary"), dict) else {}

    print("[kaudit] omx status")
    print(f"- generated_at: {snapshot.get('generated_at')}")
    print(f"- installed_version: {installed.get('installed_version')}")
    print(f"- reasoning_effort: {installed.get('reasoning_effort')}")
    print(f"- github_latest: {github_latest.get('version')}")
    print(f"- npm_latest: {npm_latest.get('version')}")
    print(f"- installable_latest: {snapshot.get('installable_latest')}")
    print(f"- github_ahead_of_installable: {snapshot.get('github_ahead_of_installable')}")
    print(f"- docs_latest: {docs_summary.get('docs_version')}")
    print(f"- docs_lagging: {snapshot.get('docs_lagging')}")
    print(f"- upstream_latest: {snapshot.get('upstream_latest')}")
    print(f"- update_available: {snapshot.get('update_available')}")
    print(f"- omx_bin: {installed.get('omx_bin')}")
    print(f"- install_root: {installed.get('install_root')}")
    print(f"- team_api_available: {installed.get('team_api_available')}")
    print(f"- team_api_event_query_available: {installed.get('team_api_event_query_available')}")
    print(f"- team_api_monitor_snapshot_available: {installed.get('team_api_monitor_snapshot_available')}")
    print(f"- session_command_available: {installed.get('session_command_available')}")
    print(f"- resume_command_available: {installed.get('resume_command_available')}")
    print(f"- tmux_hook_available: {installed.get('tmux_hook_available')}")
    print(f"- hooks_command_available: {installed.get('hooks_command_available')}")
    print(f"- reasoning_command_available: {installed.get('reasoning_command_available')}")
    print(f"- agents_init_available: {installed.get('agents_init_available')}")
    print(f"- notifications_configured: {installed.get('notifications_configured')}")
    print(f"- recommended_team_worker_launch_args: {snapshot.get('recommended_team_worker_launch_args')}")

    reflections = snapshot.get("reflections", [])
    if isinstance(reflections, list) and reflections:
        print("- reflections:")
        for item in reflections[: max(limit, 0)]:
            print(
                f"  - [{item.get('status')}] v{item.get('version')}: {item.get('feature')} | "
                f"reflect: {item.get('reflection')}"
            )

    operator_tips = snapshot.get("operator_tips", [])
    if isinstance(operator_tips, list) and operator_tips:
        print("- operator_tips:")
        for item in operator_tips[: max(limit, 0)]:
            print(f"  - {item}")

    cache_fallback_used = snapshot.get("cache_fallback_used", [])
    if isinstance(cache_fallback_used, list) and cache_fallback_used:
        print("- cache_fallback_used:")
        for item in cache_fallback_used:
            print(f"  - {item}")

    errors = snapshot.get("errors", [])
    if isinstance(errors, list) and errors:
        print("- fetch_errors:")
        for err in errors:
            print(f"  - {err}")


def cmd_omx_refresh(ctx: KernelAuditContext, args: argparse.Namespace) -> int:
    ctx.ensure_layout()
    snapshot = omx_snapshot(ctx)
    write_json(ctx.omx_upstream_path, snapshot)
    print_omx_snapshot(snapshot, limit=args.limit)
    print(f"[kaudit] omx snapshot: {ctx.omx_upstream_path}")
    return 0


def cmd_omx_status(ctx: KernelAuditContext, args: argparse.Namespace) -> int:
    ctx.ensure_layout()
    if args.refresh or not ctx.omx_upstream_path.exists():
        return cmd_omx_refresh(ctx, argparse.Namespace(limit=args.limit))

    snapshot = read_json(ctx.omx_upstream_path, {})
    if not snapshot:
        return cmd_omx_refresh(ctx, argparse.Namespace(limit=args.limit))

    snapshot["installed"] = omx_local_info(ctx.repo_root)
    installed_version = normalize_version(str(snapshot["installed"].get("installed_version", "") or ""))
    upstream_latest = normalize_version(str(snapshot.get("upstream_latest", "") or ""))
    installable_latest = normalize_version(str(snapshot.get("installable_latest", "") or ""))
    docs_latest = normalize_version(str(snapshot.get("docs_summary", {}).get("docs_version", "") or ""))
    snapshot["docs_lagging"] = bool(docs_latest and upstream_latest and compare_versions(docs_latest, upstream_latest) < 0)
    snapshot["update_available"] = bool(
        installed_version and installable_latest and compare_versions(installed_version, installable_latest) < 0
    )
    print_omx_snapshot(snapshot, limit=args.limit)
    print(f"[kaudit] omx snapshot: {ctx.omx_upstream_path}")
    return 0


def cmd_omx_update(ctx: KernelAuditContext, args: argparse.Namespace) -> int:
    ctx.ensure_layout()
    ensure_default_files(ctx)
    target_version, snapshot = omx_resolve_update_target(ctx, str(args.version or ""))

    package_spec = f"oh-my-codex@{target_version}" if target_version != "latest" else "oh-my-codex@latest"
    log_path = ctx.omx_update_log_path
    commands: List[List[str]] = [["npm", "install", "-g", package_spec]]
    if args.run_setup:
        setup_cmd = ["omx", "setup", "--scope", args.scope]
        if args.force_setup:
            setup_cmd.append("--force")
        commands.append(setup_cmd)
    if args.run_doctor:
        commands.append(["omx", "doctor"])
        if args.team_doctor:
            commands.append(["omx", "doctor", "--team"])

    print("[kaudit] omx update plan")
    print(f"- package_spec: {package_spec}")
    print(f"- log_path: {log_path}")
    for cmd in commands:
        print(f"- cmd: {shlex_join(cmd)}")

    if args.dry_run:
        return 0

    for cmd in commands:
        res = run_logged(cmd, cwd=ctx.repo_root, log_path=log_path)
        if res.returncode != 0:
            return fail(f"command failed during omx update (see {log_path}): {shlex_join(cmd)}")

    snapshot = omx_snapshot(ctx)
    write_json(ctx.omx_upstream_path, snapshot)
    print(f"[kaudit] omx update complete: {package_spec}")
    print(f"[kaudit] omx snapshot: {ctx.omx_upstream_path}")
    print(f"[kaudit] update log: {log_path}")
    return 0


def cmd_status(ctx: KernelAuditContext, _args: argparse.Namespace) -> int:
    ctx.ensure_layout()
    campaign = ctx.load_campaign()
    refresh_campaign_metrics(ctx, campaign)
    ctx.save_campaign(campaign)

    build_state = read_json(ctx.build_state_path, {})
    case_counts = count_case_statuses(ctx)
    pipeline = load_pipeline_state(ctx)

    print("[kaudit] status")
    print(f"- target: {ctx.target}")
    print(f"- campaign_id: {campaign.get('campaign_id')}")
    print(f"- kernel_head: {campaign.get('kernel_head')}")
    print(f"- knowledge_snapshot: {campaign.get('knowledge_snapshot')}")
    print(f"- queue_depth: {campaign.get('queue_depth')}")
    print(f"- completed_cases: {campaign.get('completed_cases')}")
    print(f"- rejected_as_known: {campaign.get('rejected_as_known')}")
    print(f"- last_cycle_at: {campaign.get('last_cycle_at')}")

    if build_state:
        print("- build:")
        print(f"  - build_dir: {build_state.get('build_dir')}")
        print(f"  - kernel_release: {build_state.get('kernel_release')}")
        print(f"  - bzImage: {build_state.get('bzImage')}")
        print(f"  - updated_at: {build_state.get('updated_at')}")
        if build_state.get("config_seed"):
            print(f"  - config_seed: {build_state.get('config_seed')}")

    if case_counts:
        print("- case_counts:")
        for status, count in sorted(case_counts.items()):
            print(f"  - {status}: {count}")

    print("- pipeline:")
    print(f"  - iteration: {pipeline.get('iteration')}")
    print(f"  - runtime_policy: {pipeline.get('runtime_policy')}")
    print(f"  - last_iteration_at: {pipeline.get('last_iteration_at')}")
    print(f"  - last_successful_kasan_at: {pipeline.get('last_successful_kasan_at')}")
    print(f"  - audit_queue: {len(pipeline.get('audit_queue', []))}")
    print(f"  - verify_queue: {len(pipeline.get('verify_queue', []))}")
    print(f"  - repro_queue: {len(pipeline.get('repro_queue', []))}")
    print(f"  - report_queue: {len(pipeline.get('report_queue', []))}")
    print(f"  - active_jobs: {len(pipeline.get('active_jobs', []))}")

    omx_snapshot = read_json(ctx.omx_upstream_path, {})
    if isinstance(omx_snapshot, dict) and omx_snapshot:
        installed = omx_local_info(ctx.repo_root)
        upstream_latest = normalize_version(str(omx_snapshot.get("upstream_latest", "") or ""))
        installable_latest = normalize_version(str(omx_snapshot.get("installable_latest", "") or ""))
        installed_version = normalize_version(str(installed.get("installed_version", "") or ""))
        update_available = bool(
            installed_version and installable_latest and compare_versions(installed_version, installable_latest) < 0
        )
        print("- omx:")
        print(f"  - installed_version: {installed_version}")
        print(f"  - upstream_latest: {upstream_latest}")
        print(f"  - installable_latest: {installable_latest}")
        print(f"  - update_available: {update_available}")
        print(f"  - team_api_available: {installed.get('team_api_available')}")
        print(f"  - notifications_configured: {installed.get('notifications_configured')}")
        print(f"  - snapshot: {ctx.omx_upstream_path}")

    return 0


def add_target_option(parser: argparse.ArgumentParser, *, default: str = "fs") -> None:
    parser.add_argument("--target", choices=list(SUPPORTED_TARGETS), default=default)


def build_parser() -> argparse.ArgumentParser:
    p = argparse.ArgumentParser(prog="kaudit", description="Kernel audit helper (OMX)")
    sub = p.add_subparsers(dest="command", required=True)

    sub.add_parser("bootstrap", help="initialize workspace layout and default state")
    sub.add_parser("sync-mainline", help="ff-only update of linux-up from origin/master")
    status_cmd = sub.add_parser("status", help="show campaign/build/case status")
    add_target_option(status_cmd)

    omx = sub.add_parser("omx", help="check, refresh, and update oh-my-codex itself")
    omx_sub = omx.add_subparsers(dest="omx_cmd", required=True)
    omx_status = omx_sub.add_parser("status", help="show installed OMX version and cached upstream status")
    omx_status.add_argument("--refresh", action="store_true", help="refresh upstream metadata before showing status")
    omx_status.add_argument("--limit", type=int, default=5, help="max reflection items to print")
    omx_refresh = omx_sub.add_parser("refresh", help="fetch upstream OMX metadata and release reflections")
    omx_refresh.add_argument("--limit", type=int, default=5, help="max reflection items to print")
    omx_update = omx_sub.add_parser("update", help="update oh-my-codex and rerun project setup")
    omx_update.add_argument("--version", default="latest", help="target version or latest")
    omx_update.add_argument("--dry-run", action="store_true", help="print update plan without executing")
    omx_update.add_argument("--no-setup", dest="run_setup", action="store_false", help="skip post-update omx setup")
    omx_update.set_defaults(run_setup=True)
    omx_update.add_argument("--scope", choices=["project", "user"], default="project", help="scope for post-update setup")
    omx_update.add_argument("--force-setup", action="store_true", help="pass --force to post-update omx setup")
    omx_update.add_argument("--no-doctor", dest="run_doctor", action="store_false", help="skip post-update omx doctor")
    omx_update.set_defaults(run_doctor=True)
    omx_update.add_argument("--no-team-doctor", dest="team_doctor", action="store_false", help="skip omx doctor --team")
    omx_update.set_defaults(team_doctor=True)

    orchestrate = sub.add_parser("orchestrate", help="team-aware end-to-end single-pass workflow")
    orchestrate.add_argument("--sync-mainline", action="store_true", help="run sync-mainline before workflow")
    add_target_option(orchestrate)
    orchestrate.add_argument("--similarity-threshold", type=float, default=0.45)
    orchestrate.add_argument("--dispatch", choices=["auto", "team", "local"], default="auto")
    orchestrate.add_argument("--jobs", type=int, default=0)
    orchestrate.add_argument("--force-refresh", action="store_true")
    orchestrate.add_argument("--force-build", action="store_true")
    orchestrate.add_argument("--team-workers", type=int, default=3)
    orchestrate.add_argument("--team-agent-type", default="executor")
    orchestrate.add_argument("--team-timeout", type=int, default=TEAM_PREFLIGHT_TIMEOUT_DEFAULT)
    orchestrate.add_argument("--team-poll-interval", type=int, default=15)
    orchestrate.add_argument("--team-model", default="", help="append --model to worker launch args when absent")
    orchestrate.add_argument(
        "--team-worker-launch-args",
        default="",
        help="raw OMX_TEAM_WORKER_LAUNCH_ARGS override/append path for team workers",
    )
    orchestrate.add_argument(
        "--team-reasoning-effort",
        choices=["low", "medium", "high", "xhigh"],
        default=None,
        help="append -c model_reasoning_effort=... to team workers when absent",
    )
    orchestrate.add_argument(
        "--team-omx-global-args",
        default="",
        help="supported OMX launch-style flags translated for team start (for example: --notify-temp --slack, --spark, --worktree=branch)",
    )
    orchestrate.add_argument(
        "--team-scaling",
        action="store_true",
        help="set OMX_TEAM_SCALING_ENABLED=1 for the team preflight run",
    )
    orchestrate.add_argument("--worker-model", default="", help="explicit Codex model for discovery/verify/repro/report workers")
    orchestrate.add_argument(
        "--worker-reasoning-effort",
        choices=["low", "medium", "high", "xhigh"],
        default=CODEX_WORKER_REASONING_DEFAULT,
        help="reasoning effort for Codex discovery/verify/repro/report workers",
    )
    orchestrate.add_argument("--worker-timeout", type=int, default=CODEX_WORKER_TIMEOUT_DEFAULT)
    orchestrate.add_argument("--audit-workers", type=int, default=DEFAULT_AUDIT_WORKERS)
    orchestrate.add_argument("--verify-workers", type=int, default=DEFAULT_VERIFY_WORKERS)
    orchestrate.add_argument("--repro-workers", type=int, default=DEFAULT_REPRO_WORKERS)
    orchestrate.add_argument("--report-workers", type=int, default=DEFAULT_REPORT_WORKERS)
    orchestrate.add_argument("--auto-verify", dest="auto_verify", action="store_true", help="auto run verifier stage")
    orchestrate.add_argument("--no-auto-verify", dest="auto_verify", action="store_false", help="skip verifier stage")
    orchestrate.add_argument("--auto-repro", dest="auto_repro", action="store_true", help="auto run repro stage")
    orchestrate.add_argument("--no-auto-repro", dest="auto_repro", action="store_false", help="skip repro stage")
    orchestrate.add_argument("--auto-report", dest="auto_report", action="store_true", help="auto run report stage")
    orchestrate.add_argument("--no-auto-report", dest="auto_report", action="store_false", help="skip report stage")
    orchestrate.add_argument(
        "--auto-public-report",
        dest="auto_public_report",
        action="store_true",
        help="after internal report generation, also generate public-report artifacts",
    )
    orchestrate.add_argument(
        "--no-auto-public-report",
        dest="auto_public_report",
        action="store_false",
        help="skip automatic public-report generation after internal report",
    )
    orchestrate.set_defaults(auto_verify=True, auto_repro=True, auto_report=True, auto_public_report=True)
    orchestrate.add_argument("--repro-timeout", type=int, default=240)
    orchestrate.add_argument("--repro-attempts", type=int, default=3)
    orchestrate.add_argument("--repro-skip-build", action="store_true")
    orchestrate.add_argument("--rootfs-mode", choices=["auto", "busybox", "debian"], default="auto")
    orchestrate.add_argument("--debian-suite", default="bookworm")
    orchestrate.add_argument("--debian-mirror", default="http://deb.debian.org/debian")
    orchestrate.add_argument("--debian-include", default="busybox,ca-certificates")
    orchestrate.add_argument("--debian-force-cache", action="store_true")

    refresh = sub.add_parser("refresh", help="alias for knowledge refresh")
    add_target_option(refresh)
    refresh.add_argument("--syzbot", action="store_true", default=False, help="accepted for compatibility")
    refresh.add_argument("--cve", action="store_true", default=False, help="accepted for compatibility")

    knowledge = sub.add_parser("knowledge", help="knowledge operations")
    knowledge_sub = knowledge.add_subparsers(dest="knowledge_cmd", required=True)
    knowledge_refresh = knowledge_sub.add_parser("refresh", help="refresh syzbot/cve knowledge caches for the selected target")
    add_target_option(knowledge_refresh)

    build = sub.add_parser("build", help="build operations")
    build_sub = build.add_subparsers(dest="build_cmd", required=True)
    build_init = build_sub.add_parser("init", help="initial target seed config + kasan build")
    add_target_option(build_init)
    build_init.add_argument("--jobs", type=int, default=0, help="parallel build jobs (default: nproc)")
    build_repro_backlog = build_sub.add_parser(
        "repro-backlog",
        help="merge required_config from repro backlog cases and build one target bzImage",
    )
    build_repro_backlog.add_argument(
        "--stages",
        default="repro_queued",
        help="comma-separated case stages to collect config from (default: repro_queued)",
    )
    add_target_option(build_repro_backlog)
    build_repro_backlog.add_argument("--jobs", type=int, default=0, help="parallel build jobs (default: nproc)")
    build_repro_backlog.add_argument("--limit", type=int, default=0, help="optional max cases to inspect")
    build_repro_backlog.add_argument(
        "--oldest-first",
        action="store_true",
        help="collect cases oldest-first instead of newest-first",
    )
    build_repro_backlog.add_argument(
        "--no-missing-only",
        dest="missing_only",
        action="store_false",
        help="apply all merged required_config entries instead of only those missing from current .config",
    )
    build_repro_backlog.set_defaults(missing_only=True)

    build_init_alias = sub.add_parser("build-init", help="alias for build init")
    add_target_option(build_init_alias)
    build_init_alias.add_argument("--config", default="allmodconfig", help="accepted for compatibility")
    build_init_alias.add_argument("--kasan", action="store_true", default=False, help="accepted for compatibility")
    build_init_alias.add_argument("--jobs", type=int, default=0, help="parallel build jobs (default: nproc)")

    cycle = sub.add_parser("cycle", help="run candidate discovery cycle")
    add_target_option(cycle)
    cycle.add_argument("--once", action="store_true", help="run exactly one cycle")
    cycle.add_argument("--loop", action="store_true", help="run continuous cycles")
    cycle.add_argument("--interval", type=int, default=900, help="loop sleep interval in seconds")
    cycle.add_argument("--max-iterations", type=int, default=0, help="max loop iterations (0 means infinite)")
    cycle.add_argument(
        "--similarity-threshold",
        type=float,
        default=0.45,
        help="reject candidate when similarity to known bug root cause >= threshold",
    )
    cycle.add_argument(
        "--preflight",
        dest="preflight",
        action="store_true",
        default=True,
        help="run refresh/build preflight before cycle (default: enabled)",
    )
    cycle.add_argument(
        "--no-preflight",
        dest="preflight",
        action="store_false",
        help="skip refresh/build preflight before cycle",
    )
    cycle.add_argument(
        "--dispatch",
        choices=["auto", "team", "local"],
        default="auto",
        help="preflight execution mode: auto/team/local",
    )
    cycle.add_argument("--jobs", type=int, default=0, help="build jobs for preflight build")
    cycle.add_argument("--force-refresh", action="store_true", help="force refresh during local preflight")
    cycle.add_argument("--force-build", action="store_true", help="force build during local preflight")
    cycle.add_argument("--team-workers", type=int, default=3, help="worker count for team preflight")
    cycle.add_argument("--team-agent-type", default="executor", help="omx team worker role (default: executor)")
    cycle.add_argument(
        "--team-timeout",
        type=int,
        default=TEAM_PREFLIGHT_TIMEOUT_DEFAULT,
        help="team preflight timeout seconds (default: 7200)",
    )
    cycle.add_argument("--team-poll-interval", type=int, default=15, help="team status polling interval seconds")
    cycle.add_argument(
        "--team-model",
        default="",
        help="append --model to worker launch args when absent",
    )
    cycle.add_argument(
        "--team-worker-launch-args",
        default="",
        help="raw OMX_TEAM_WORKER_LAUNCH_ARGS override/append path for team workers",
    )
    cycle.add_argument(
        "--team-reasoning-effort",
        choices=["low", "medium", "high", "xhigh"],
        default=None,
        help="append -c model_reasoning_effort=... to team workers when absent",
    )
    cycle.add_argument(
        "--team-omx-global-args",
        default="",
        help="supported OMX launch-style flags translated for team start (for example: --notify-temp --slack, --spark, --worktree=branch)",
    )
    cycle.add_argument(
        "--team-scaling",
        action="store_true",
        help="set OMX_TEAM_SCALING_ENABLED=1 for the team preflight run",
    )
    cycle.add_argument("--worker-model", default="", help="explicit Codex model for discovery/verify/repro/report workers")
    cycle.add_argument(
        "--worker-reasoning-effort",
        choices=["low", "medium", "high", "xhigh"],
        default=CODEX_WORKER_REASONING_DEFAULT,
        help="reasoning effort for Codex discovery/verify/repro/report workers",
    )
    cycle.add_argument("--worker-timeout", type=int, default=CODEX_WORKER_TIMEOUT_DEFAULT)
    cycle.add_argument("--audit-workers", type=int, default=DEFAULT_AUDIT_WORKERS)
    cycle.add_argument("--verify-workers", type=int, default=DEFAULT_VERIFY_WORKERS)
    cycle.add_argument("--repro-workers", type=int, default=DEFAULT_REPRO_WORKERS)
    cycle.add_argument("--report-workers", type=int, default=DEFAULT_REPORT_WORKERS)
    cycle.add_argument(
        "--backlog-only",
        action="store_true",
        help="skip new discovery and drain existing discovered/repro_queued/confirmed backlog only",
    )
    cycle.add_argument(
        "--oldest-first",
        action="store_true",
        help="process verify/repro/report queues oldest-first instead of newest-first",
    )
    cycle.add_argument("--auto-verify", dest="auto_verify", action="store_true", help="auto run verifier stage")
    cycle.add_argument("--no-auto-verify", dest="auto_verify", action="store_false", help="skip verifier stage")
    cycle.add_argument("--auto-repro", dest="auto_repro", action="store_true", help="auto run repro stage")
    cycle.add_argument("--no-auto-repro", dest="auto_repro", action="store_false", help="skip repro stage")
    cycle.add_argument("--auto-report", dest="auto_report", action="store_true", help="auto run report stage")
    cycle.add_argument("--no-auto-report", dest="auto_report", action="store_false", help="skip report stage")
    cycle.add_argument(
        "--auto-public-report",
        dest="auto_public_report",
        action="store_true",
        help="after internal report generation, also generate public-report artifacts",
    )
    cycle.add_argument(
        "--no-auto-public-report",
        dest="auto_public_report",
        action="store_false",
        help="skip automatic public-report generation after internal report",
    )
    cycle.set_defaults(auto_verify=True, auto_repro=True, auto_report=True, auto_public_report=True)
    cycle.add_argument("--repro-timeout", type=int, default=240)
    cycle.add_argument("--repro-attempts", type=int, default=3)
    cycle.add_argument("--repro-skip-build", action="store_true")
    cycle.add_argument("--rootfs-mode", choices=["auto", "busybox", "debian"], default="auto")
    cycle.add_argument("--debian-suite", default="bookworm")
    cycle.add_argument("--debian-mirror", default="http://deb.debian.org/debian")
    cycle.add_argument("--debian-include", default="busybox,ca-certificates")
    cycle.add_argument("--debian-force-cache", action="store_true")

    verify = sub.add_parser("verify", help="deep root-cause verification for a case")
    verify.add_argument("case_id", help="case identifier")
    add_target_option(verify)
    verify.add_argument("--worker-model", default="", help="explicit Codex model for verifier worker")
    verify.add_argument(
        "--worker-reasoning-effort",
        choices=["low", "medium", "high", "xhigh"],
        default=CODEX_WORKER_REASONING_DEFAULT,
        help="reasoning effort for verifier worker",
    )
    verify.add_argument("--worker-timeout", type=int, default=CODEX_WORKER_TIMEOUT_DEFAULT)

    case_cmd = sub.add_parser("case", help="operator case management helpers")
    case_sub = case_cmd.add_subparsers(dest="case_cmd", required=True)

    case_show = case_sub.add_parser("show", help="show normalized case metadata")
    case_show.add_argument("case_id", help="case identifier")
    add_target_option(case_show)
    case_show.add_argument("--json", action="store_true", help="print raw normalized case json")
    case_show.add_argument("--recent", type=int, default=5, help="recent operator notes/actions to show")

    case_note = case_sub.add_parser("note", help="append an operator note to a case")
    case_note.add_argument("case_id", help="case identifier")
    add_target_option(case_note)
    case_note.add_argument("--message", required=True, help="operator note text")
    case_note.add_argument("--category", default="note", help="free-form note category label")

    case_promote = case_sub.add_parser("promote", help="operator-approved stage override for a case")
    case_promote.add_argument("case_id", help="case identifier")
    add_target_option(case_promote)
    case_promote.add_argument(
        "--to",
        dest="to_stage",
        required=True,
        choices=sorted(CASE_STAGE_TO_STATUS.keys()),
        help="target stage",
    )
    case_promote.add_argument("--reason", required=True, help="why the operator is overriding the stage")
    case_promote.add_argument("--force", action="store_true", help="allow non-standard stage transitions")

    case_backfill = case_sub.add_parser("backfill", help="rewrite normalized case schema/stage into existing cases")
    add_target_option(case_backfill)
    case_backfill.add_argument(
        "--rewrite-notes",
        action="store_true",
        help="rewrite notes.md even when the JSON payload is already normalized",
    )

    repro = sub.add_parser("repro", help="boot qemu and run case trigger")
    repro.add_argument("case_id", help="case identifier")
    add_target_option(repro)
    repro.add_argument("--timeout", type=int, default=240, help="qemu runtime timeout seconds")
    repro.add_argument("--jobs", type=int, default=0, help="parallel build jobs before repro")
    repro.add_argument("--skip-build", action="store_true", help="skip kernel rebuild before qemu run")
    repro.add_argument(
        "--auto-generate-trigger",
        dest="auto_generate_trigger",
        action="store_true",
        help="auto synthesize trigger via Codex repro planner when trigger fields are empty",
    )
    repro.add_argument(
        "--no-auto-generate-trigger",
        dest="auto_generate_trigger",
        action="store_false",
        help="require manually populated trigger fields",
    )
    repro.set_defaults(auto_generate_trigger=True)
    repro.add_argument("--worker-model", default="", help="explicit Codex model for repro planner worker")
    repro.add_argument(
        "--worker-reasoning-effort",
        choices=["low", "medium", "high", "xhigh"],
        default=CODEX_WORKER_REASONING_DEFAULT,
        help="reasoning effort for repro planner worker",
    )
    repro.add_argument("--worker-timeout", type=int, default=CODEX_WORKER_TIMEOUT_DEFAULT)
    repro.add_argument(
        "--rootfs-mode",
        choices=["auto", "busybox", "debian"],
        default="auto",
        help="guest rootfs profile for repro boot",
    )
    repro.add_argument("--debian-suite", default="bookworm", help="debian suite for debian rootfs mode")
    repro.add_argument(
        "--debian-mirror",
        default="http://deb.debian.org/debian",
        help="debian mirror for debian rootfs mode",
    )
    repro.add_argument(
        "--debian-include",
        default="busybox,ca-certificates",
        help="comma-separated package include list for debian rootfs cache",
    )
    repro.add_argument(
        "--debian-force-cache",
        action="store_true",
        help="recreate debian rootfs cache before repro",
    )

    rootfs = sub.add_parser("rootfs", help="rootfs preparation and cache controls")
    rootfs_sub = rootfs.add_subparsers(dest="rootfs_cmd", required=True)
    rootfs_prepare = rootfs_sub.add_parser("prepare", help="prepare rootfs prerequisites/cache")
    add_target_option(rootfs_prepare)
    rootfs_prepare.add_argument("--mode", choices=["auto", "busybox", "debian"], default="auto")
    rootfs_prepare.add_argument("--debian-suite", default="bookworm")
    rootfs_prepare.add_argument("--debian-mirror", default="http://deb.debian.org/debian")
    rootfs_prepare.add_argument("--debian-include", default="busybox,ca-certificates")
    rootfs_prepare.add_argument("--force", action="store_true", help="rebuild debian cache")

    report = sub.add_parser("report", help="generate markdown report for a case")
    report.add_argument("case_id", help="case identifier")
    add_target_option(report)
    report.add_argument("--worker-model", default="", help="explicit Codex model for disclosure writer worker")
    report.add_argument(
        "--worker-reasoning-effort",
        choices=["low", "medium", "high", "xhigh"],
        default=CODEX_WORKER_REASONING_DEFAULT,
        help="reasoning effort for disclosure writer worker",
    )
    report.add_argument("--worker-timeout", type=int, default=CODEX_WORKER_TIMEOUT_DEFAULT)
    report.add_argument("--dup-check", dest="dup_check", action="store_true", help="optionally attach a duplicate-check snapshot without blocking report generation")
    report.add_argument("--no-dup-check", dest="dup_check", action="store_false", help="skip duplicate-check snapshot attachment")
    report.set_defaults(dup_check=False)
    report.add_argument("--dup-refresh", action="store_true", help="force knowledge refresh before optional duplicate-check attachment")
    report.add_argument("--allow-duplicate-risk", action="store_true", help="deprecated no-op; report generation is non-blocking")
    report.add_argument("--dup-hard-threshold", type=float, default=PRE_DISCLOSE_HARD_THRESHOLD_DEFAULT)
    report.add_argument("--dup-soft-threshold", type=float, default=PRE_DISCLOSE_SOFT_THRESHOLD_DEFAULT)
    report.add_argument("--dup-max-results", type=int, default=PRE_DISCLOSE_MAX_RESULTS_DEFAULT)
    report.add_argument("--dup-live-syzbot", dest="dup_live_syzbot", action="store_true", help="include live syzbot search when --dup-check is used")
    report.add_argument("--no-dup-live-syzbot", dest="dup_live_syzbot", action="store_false", help="disable live syzbot search when --dup-check is used")
    report.set_defaults(dup_live_syzbot=True)

    public_report = sub.add_parser("public-report", help="generate plain-text public mailing drafts for a case")
    public_report.add_argument("case_id", help="case identifier")
    add_target_option(public_report)

    public_report_batch = sub.add_parser(
        "public-report-batch",
        help="generate plain-text public mailing drafts for reported cases",
    )
    add_target_option(public_report_batch)
    public_report_batch.add_argument("--stages", default="reported", help="comma-separated stages to scan (default: reported)")
    public_report_batch.add_argument("--limit", type=int, default=0, help="limit number of matching cases (0 = all)")
    public_report_batch.add_argument("--oldest-first", action="store_true", help="process oldest matching cases first")

    pre_disclose = sub.add_parser(
        "pre-disclose-check",
        help="refresh knowledge and compare a confirmed/reported case against latest public signals before disclosure",
    )
    pre_disclose.add_argument("case_id", help="case identifier")
    add_target_option(pre_disclose)
    pre_disclose.add_argument("--refresh", dest="refresh", action="store_true", help="refresh knowledge snapshot before checking")
    pre_disclose.add_argument("--no-refresh", dest="refresh", action="store_false", help="reuse existing knowledge snapshot when available")
    pre_disclose.set_defaults(refresh=True)
    pre_disclose.add_argument("--json", action="store_true", help="print raw JSON result")
    pre_disclose.add_argument("--hard-threshold", type=float, default=PRE_DISCLOSE_HARD_THRESHOLD_DEFAULT)
    pre_disclose.add_argument("--soft-threshold", type=float, default=PRE_DISCLOSE_SOFT_THRESHOLD_DEFAULT)
    pre_disclose.add_argument("--max-results", type=int, default=PRE_DISCLOSE_MAX_RESULTS_DEFAULT)
    pre_disclose.add_argument("--live-syzbot", dest="live_syzbot", action="store_true", help="query live syzbot search pages")
    pre_disclose.add_argument("--no-live-syzbot", dest="live_syzbot", action="store_false", help="skip live syzbot search and use local knowledge/git only")
    pre_disclose.set_defaults(live_syzbot=True)

    pre_disclose_batch = sub.add_parser(
        "pre-disclose-batch",
        help="run duplicate checks for reported/confirmed cases outside the loop and write batch snapshots",
    )
    add_target_option(pre_disclose_batch)
    pre_disclose_batch.add_argument("--stages", default=PRE_DISCLOSE_BATCH_STAGES_DEFAULT, help="comma-separated stages to scan (default: reported)")
    pre_disclose_batch.add_argument("--limit", type=int, default=0, help="limit number of matching cases (0 = all)")
    pre_disclose_batch.add_argument("--refresh", dest="refresh", action="store_true", help="refresh knowledge snapshot before checking")
    pre_disclose_batch.add_argument("--no-refresh", dest="refresh", action="store_false", help="reuse existing knowledge snapshot when available")
    pre_disclose_batch.set_defaults(refresh=True)
    pre_disclose_batch.add_argument("--json", action="store_true", help="print raw JSON result")
    pre_disclose_batch.add_argument("--hard-threshold", type=float, default=PRE_DISCLOSE_HARD_THRESHOLD_DEFAULT)
    pre_disclose_batch.add_argument("--soft-threshold", type=float, default=PRE_DISCLOSE_SOFT_THRESHOLD_DEFAULT)
    pre_disclose_batch.add_argument("--max-results", type=int, default=PRE_DISCLOSE_MAX_RESULTS_DEFAULT)
    pre_disclose_batch.add_argument("--live-syzbot", dest="live_syzbot", action="store_true", help="query live syzbot search pages")
    pre_disclose_batch.add_argument("--no-live-syzbot", dest="live_syzbot", action="store_false", help="skip live syzbot search and use local knowledge/git only")
    pre_disclose_batch.set_defaults(live_syzbot=True)

    return p


def resolve_command_target(args: argparse.Namespace) -> str:
    return normalize_target_name(str(getattr(args, "target", "fs") or "fs"))


def main(argv: Optional[Sequence[str]] = None) -> int:
    parser = build_parser()
    args = parser.parse_args(argv)

    try:
        repo_root = find_repo_root(Path.cwd())
    except RuntimeError as exc:
        return fail(str(exc))

    ctx = KernelAuditContext(repo_root, resolve_command_target(args))

    try:
        if args.command == "bootstrap":
            return cmd_bootstrap(ctx, args)
        if args.command == "sync-mainline":
            return cmd_sync_mainline(ctx, args)
        if args.command == "status":
            return cmd_status(ctx, args)
        if args.command == "omx" and args.omx_cmd == "status":
            return cmd_omx_status(ctx, args)
        if args.command == "omx" and args.omx_cmd == "refresh":
            return cmd_omx_refresh(ctx, args)
        if args.command == "omx" and args.omx_cmd == "update":
            return cmd_omx_update(ctx, args)
        if args.command == "orchestrate":
            return cmd_orchestrate(ctx, args)
        if args.command == "refresh":
            return cmd_knowledge_refresh(ctx, args)
        if args.command == "knowledge" and args.knowledge_cmd == "refresh":
            return cmd_knowledge_refresh(ctx, args)
        if args.command == "build-init":
            if str(args.config).strip() != "allmodconfig":
                return fail("build-init currently supports only --config allmodconfig")
            return cmd_build_init(ctx, args)
        if args.command == "build" and args.build_cmd == "init":
            return cmd_build_init(ctx, args)
        if args.command == "build" and args.build_cmd == "repro-backlog":
            return cmd_build_repro_backlog(ctx, args)
        if args.command == "cycle":
            if args.max_iterations is not None and args.max_iterations < 0:
                return fail("--max-iterations must be >= 0")
            return cmd_cycle(ctx, args)
        if args.command == "verify":
            return cmd_verify(ctx, args)
        if args.command == "case" and args.case_cmd == "show":
            return cmd_case_show(ctx, args)
        if args.command == "case" and args.case_cmd == "note":
            return cmd_case_note(ctx, args)
        if args.command == "case" and args.case_cmd == "promote":
            return cmd_case_promote(ctx, args)
        if args.command == "case" and args.case_cmd == "backfill":
            return cmd_case_backfill(ctx, args)
        if args.command == "repro":
            return cmd_repro(ctx, args)
        if args.command == "rootfs" and args.rootfs_cmd == "prepare":
            return cmd_rootfs_prepare(ctx, args)
        if args.command == "report":
            return cmd_report(ctx, args)
        if args.command == "public-report":
            return cmd_public_report(ctx, args)
        if args.command == "public-report-batch":
            return cmd_public_report_batch(ctx, args)
        if args.command == "pre-disclose-check":
            return cmd_pre_disclose_check(ctx, args)
        if args.command == "pre-disclose-batch":
            return cmd_pre_disclose_batch(ctx, args)
    except Exception as exc:
        return fail(str(exc))

    return fail("unknown command")


if __name__ == "__main__":
    raise SystemExit(main())
