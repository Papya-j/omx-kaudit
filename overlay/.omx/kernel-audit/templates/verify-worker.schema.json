{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "verdict",
    "root_cause",
    "proof",
    "trigger_contract",
    "impact",
    "attack_scenario",
    "duplicate_analysis",
    "repro_requirements",
    "auto_repro_supported",
    "manual_constraints",
    "required_config",
    "confidence"
  ],
  "properties": {
    "verdict": {"type": "string", "enum": ["reject", "manual_only", "repro_ready"]},
    "root_cause": {"type": "string"},
    "proof": {"type": "string"},
    "trigger_contract": {"type": "string"},
    "impact": {"type": "string"},
    "attack_scenario": {"type": "string"},
    "duplicate_analysis": {"type": "string"},
    "repro_requirements": {"type": "string"},
    "auto_repro_supported": {"type": "boolean"},
    "manual_constraints": {"type": "string"},
    "required_config": {"type": "array", "items": {"type": "string"}},
    "confidence": {"type": "number", "minimum": 0, "maximum": 1}
  }
}
